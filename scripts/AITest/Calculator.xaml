<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfCSCS"
        mc:Ignorable="d"
        Title="Calculator" Height="430" Width="300"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <!-- Display -->
        <Label Name="lblDisplay"
               DataContext="displayText"
               Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
               HorizontalContentAlignment="Right"
               VerticalContentAlignment="Center"
               FontSize="28" FontWeight="Bold"
               Background="#1C1C1C" Foreground="White"
               Margin="2" Padding="8,0" />

        <!-- Row 1: C (colspan 2), /, * -->
        <Button Name="btnClear"
                Content="C"
                Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                Margin="2" FontSize="18" />
        <Button Name="btnDiv"
                Content="/"
                Grid.Row="1" Grid.Column="2"
                Margin="2" FontSize="18" />
        <Button Name="btnMul"
                Content="*"
                Grid.Row="1" Grid.Column="3"
                Margin="2" FontSize="18" />

        <!-- Row 2: 7, 8, 9, - -->
        <Button Name="btn7"   Content="7" Grid.Row="2" Grid.Column="0" Margin="2" FontSize="18" />
        <Button Name="btn8"   Content="8" Grid.Row="2" Grid.Column="1" Margin="2" FontSize="18" />
        <Button Name="btn9"   Content="9" Grid.Row="2" Grid.Column="2" Margin="2" FontSize="18" />
        <Button Name="btnSub" Content="-" Grid.Row="2" Grid.Column="3" Margin="2" FontSize="18" />

        <!-- Row 3: 4, 5, 6, + -->
        <Button Name="btn4"   Content="4" Grid.Row="3" Grid.Column="0" Margin="2" FontSize="18" />
        <Button Name="btn5"   Content="5" Grid.Row="3" Grid.Column="1" Margin="2" FontSize="18" />
        <Button Name="btn6"   Content="6" Grid.Row="3" Grid.Column="2" Margin="2" FontSize="18" />
        <Button Name="btnAdd" Content="+" Grid.Row="3" Grid.Column="3" Margin="2" FontSize="18" />

        <!-- Row 4: 1, 2, 3, = (rowspan 2) -->
        <Button Name="btn1"      Content="1" Grid.Row="4" Grid.Column="0" Margin="2" FontSize="18" />
        <Button Name="btn2"      Content="2" Grid.Row="4" Grid.Column="1" Margin="2" FontSize="18" />
        <Button Name="btn3"      Content="3" Grid.Row="4" Grid.Column="2" Margin="2" FontSize="18" />
        <Button Name="btnEquals" Content="=" Grid.Row="4" Grid.Column="3" Grid.RowSpan="2"
                Margin="2" FontSize="18" />

        <!-- Row 5: ., 0 (colspan 2) -->
        <Button Name="btnDecimal" Content="." Grid.Row="5" Grid.Column="0" Margin="2" FontSize="18" />
        <Button Name="btn0"       Content="0" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                Margin="2" FontSize="18" />
    </Grid>
</Window>
