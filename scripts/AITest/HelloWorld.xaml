<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfCSCS"
        mc:Ignorable="d"
        Title="Hello World" Height="200" Width="350" WindowStartupLocation="CenterScreen">
    <Grid>
        <Label Content="Enter your name:"
               HorizontalAlignment="Left"
               Margin="10,20,0,0"
               VerticalAlignment="Top" />
        <TextBox DataContext="userName"
                 HorizontalAlignment="Left"
                 Margin="10,45,0,0"
                 VerticalAlignment="Top"
                 Width="310"
                 Height="25"
                 Name="adsdadaaa" />
        <Button Name="btnGreet"
                Content="Greet"
                HorizontalAlignment="Left"
                Margin="10,80,0,0"
                VerticalAlignment="Top"
                Width="310"
                Height="30" />
        <Label DataContext="greetingText"
               HorizontalAlignment="Left"
               Margin="10,120,0,0"
               VerticalAlignment="Top"
               Width="310"
               FontSize="14"
               Name="asdasd" />
    </Grid>
</Window>
