// -----------------------------------------------------------
function ExtractAndSaveAttachments(invoiceDict, docType) {
    try{
        restOfAttachments = {};
        docData           = invoiceDict;
        NKPR_GL_PICTHDR   = 0;
        NKPR_GL_PICTFTR   = 0;
        attachmentCounter = 0;

        sql_max_pic = "SELECT ISNULL(MAX(SY_SL_NUM), 0) AS maxNum FROM " + databaseName + ".dbo.NKSYPICT";
        maxRes      = sqlQuery(sql_max_pic);
        nextPicNum  = 1;
        if (Size(maxRes) >= 2) { nextPicNum = maxRes[1][0]; }

        if(Exists(pdfPathInIMPORTED)){
            nextPicNum++;
            newPdfName = pdfPathInIMPORTED.Replace("p0.pdf", nextPicNum + ".pdf");
            Move(pdfPathInIMPORTED, newPdfName);

            sql_insert_pic = "INSERT INTO " + databaseName + ".dbo.NKSYPICT (SY_SL_NUM, SY_SL_PATH, SY_SL_OPIS, SY_SL_REZ5, SY_SL_CODE, SY_SL_TIP) VALUES (@p1, @p2, @p3, @p4, @p5, @p6);";
            sqlParams      = {};
            sqlParams.Add({"@p1", nextPicNum});
            sqlParams.Add({"@p2", newPdfName});
            sqlParams.Add({"@p3", "Vizualizacija XML-a"});
            sqlParams.Add({"@p4", "D"});
            sqlParams.Add({"@p5", NKPR_GL_CUSCOD});
            sqlParams.Add({"@p6", "IR"}); // izlazni račun
            sqlNonQuery(sql_insert_pic, sqlParams, 60, transactionHndl);
            NKPR_GL_PICTHDR = nextPicNum;
        }

        if (Contains(docData, "AdditionalDocumentReference")) {
            if (ArrayOrDict(docData["AdditionalDocumentReference"]) == "array") {
                for (i = 0; i < Size(docData["AdditionalDocumentReference"]); i++) {
                    nextPicNum++;
                    ProcessSingleAttachment(docData["AdditionalDocumentReference"][i], i + 1);
                }
            } else {
                nextPicNum++;
                ProcessSingleAttachment(docData["AdditionalDocumentReference"], 1);
            }
        }
        return true;
    } catch(error) {
        Mbox("Greška pri obradi attachmenta: " + error);
        return false;
    }
}

function ProcessSingleAttachment(attachmentRef, attachmentIndex) {
    try{
        attachmentID   = "";
        attachmentDesc = "";
        if (Contains(attachmentRef, "ID"))                  { attachmentID   = GetNodeText(attachmentRef["ID"]); }
        if (Contains(attachmentRef, "DocumentDescription")) { attachmentDesc = GetNodeText(attachmentRef["DocumentDescription"]); }

        if (Contains(attachmentRef, "Attachment")) {
            attachment = GetNodeText(attachmentRef["Attachment"]);
            if (Contains(attachment, "EmbeddedDocumentBinaryObject")) {
                embeddedObj = attachment["EmbeddedDocumentBinaryObject"];
                mimeCode = ""; filename = ""; base64Content = "";

                if (Contains(embeddedObj, "@attributes")) {
                    attrs = embeddedObj["@attributes"];
                    if(Contains(attrs, "mimeCode")) { mimeCode = attrs["mimeCode"]; }
                    if(Contains(attrs, "filename"))  { filename = attrs["filename"]; }
                }
                base64Content = GetNodeText(embeddedObj);

                if (base64Content != "" && filename != "") {
                    attachmentNum = SaveAttachmentToDisk(base64Content, filename, attachmentDesc, attachmentID);
                    if (attachmentNum > 0) {
                        if (attachmentIndex == 1 && NKPR_GL_PICTFTR == 0) { NKPR_GL_PICTFTR = attachmentNum; }
                        else { restOfAttachments.Add(attachmentNum); }
                    }
                }
            }
        }
    } catch(error) {
        msg("Greška pri obradi attachmenta: " + error);
    }
}

function SaveAttachmentToDisk(base64Content, filename, description, attachmentID) {
    try{
        if (base64Content == "" || filename == "") { return 0; }

        attachmentDir = IR_IMPORTED_DirectoryPath;
        if (!Exists(attachmentDir)) { MkDir(attachmentDir); }

        fileExtension = ParseFile(filename, "pfExt");
        fullFilePath  = attachmentDir + "p" + (attachmentCounter + 1) + fileExtension;

        if (!Base642File(base64Content, fullFilePath)) {
            msg("Greška pri spremanju attachment datoteke: " + fullFilePath);
            return 0;
        }
        attachmentCounter++;

        // sql_max_pic = "SELECT ISNULL(MAX(SY_SL_NUM), 0) AS maxNum FROM " + databaseName + ".dbo.NKSYPICT";
        // maxRes      = sqlQuery(sql_max_pic);
        // nextPicNum  = 1;
        // if (Size(maxRes) >= 2) { nextPicNum = maxRes[1][0] + 1; }

        newPdfName = fullFilePath.Replace(parsefile(fullFilePath, "pfName"), nextPicNum);
        Move(fullFilePath, newPdfName);

        sql_insert_pic = "INSERT INTO " + databaseName + ".dbo.NKSYPICT (SY_SL_NUM, SY_SL_PATH, SY_SL_OPIS, SY_SL_REZ5, SY_SL_CODE, SY_SL_TIP) VALUES (@p1, @p2, @p3, @p4, @p5, @p6);";
        sqlParams = {};
        sqlParams.Add({"@p1", nextPicNum});
        sqlParams.Add({"@p2", newPdfName});
        if(description.length > 50) { description = Substring(description, 0, 50); }
        sqlParams.Add({"@p3", description});

        slikaIliDokument = "D";
        fileExtLower = fileExtension.Lower();
        if(fileExtLower == ".png" || fileExtLower == ".jpg" || fileExtLower == ".jpeg") { slikaIliDokument = ""; }
        sqlParams.Add({"@p4", slikaIliDokument});
        sqlParams.Add({"@p5", NKPR_GL_CUSCOD});
        sqlParams.Add({"@p6", "IR"}); // izlazni račun
        sqlNonQuery(sql_insert_pic, sqlParams, 60, transactionHndl);

        return nextPicNum;

    } catch(error) {
        Mbox("Greška pri registraciji attachment datoteke: " + error);
        return 0;
    }
}

// -----------------------------------------------------------
function ValidateFiscalYear(NKPR_GL_ESD) {
    try{
        fiscalYear = year(KPSY_FISCAL_YR);
        esdYear    = year(NKPR_GL_ESD);
        return (esdYear == fiscalYear);
    } catch(error) {
        Mbox("Greška prilikom validacije fiskalne godine: " + error);
        return false;
    }
}

function LogNKSYELOG(elogStatusCode, _invoiceId, description = ""){
    sqlQueryString = "INSERT INTO " + databaseName + ".dbo.NKSYELOG
    (sy_elog_num, sy_elog_date, sy_elog_status, sy_elog_person, sy_elog_estring, sy_elog_type, sy_elog_time, sy_elog_desc, sy_elog_rez3, sy_elog_rez)
    VALUES (@p1, @p2, @p3, @p4, @p5, @p6, @p7, @p8, @p9, @p10);";

    sqlParams = {};
    sqlParams.Add({"@p1",  NKPR_GL_NUM});
    sqlParams.Add({"@p2",  NKPR_GL_INVDTE});
    sqlParams.Add({"@p3",  elogStatusCode.Upper()});
    sqlParams.Add({"@p4",  userCode});
    sqlParams.Add({"@p5",  ""});
    sqlParams.Add({"@p6",  "IR"});
    sqlParams.Add({"@p7",  Now("HH:mm:ss")});
    sqlParams.Add({"@p8",  description});
    sqlParams.Add({"@p9",  Now("yyyy-MM-dd")});
    sqlParams.Add({"@p10", _invoiceId});
    sqlQuery(sqlQueryString, sqlParams);
    return;
}

// -----------------------------------------------------------
function ParseDecimal(inputString) {
    return double(inputString);
}

function GetUnitCodeFromUN(unCode) {
    if (unCode == "H87") { return "KOM"; }
    if (unCode == "KGM") { return "KG"; }
    if (unCode == "LTR") { return "LIT"; }
    if (unCode == "MTK") { return "MX2"; }
    if (unCode == "MTQ") { return "MX3"; }
    if (unCode == "TNE") { return "TON"; }
    if (unCode == "GRM") { return "GR"; }
    if (unCode == "HUR") { return "SAT"; }
    if (unCode == "DAY") { return "DAN"; }
    if (unCode == "MTR") { return "MET"; }
    if (unCode == "XCT") { return "KAR"; }
    if (unCode == "XPB") { return "PAL"; }
    if (unCode == "C62") { return "JED"; }
    return "KOM";
}

function LookupTaxCode(taxCategoryID, taxPercent) {
    sql_tax = "SELECT TOP 1 PKFK_TAX_CODE FROM " + databaseName + ".dbo.PKFKPORZ WHERE PKFK_TAX_TARIFA = @p1 AND PKFK_TAX_STOPA = @p2;";
    sqlParams = {};
    sqlParams.Add({"@p1", taxCategoryID});
    sqlParams.Add({"@p2", taxPercent});
    taxRes = sqlQuery(sql_tax, sqlParams);
    if (Size(taxRes) >= 2) { return taxRes[1][0]; }
    return 0;
}

function UnescapeFromXml(text) {
    text = text.Replace("&amp;",  "&");
    text = text.Replace("&lt;",   "<");
    text = text.Replace("&gt;",   ">");
    text = text.Replace("&quot;", "\"");
    text = text.Replace("&apos;", "'");
    return text;
}

// function GetNodeText(node) {
//     if (node == null || node == "") { return ""; }
//     if (ArrayOrDict(node) == "dict") {
//         if (Contains(node, "@text")) {
//             return UnescapeFromXml(node["@text"]);
//         }
//         return node;
//     }
//     return UnescapeFromXml(string(node));
// }
function GetNodeText(node){
    if (Contains(node, "@text")) {
        return UnescapeFromXml(node["@text"]);
    } else {
        return node;
    }
}

function WriteLog(operation, logText, responseCode = 0) {
    try{
        logPath = FILESPATH + "IR\\" + "log\\";
        if (!Exists(logPath)) { MkDir(logPath); }

        logFilePath = logPath + operation + ".log";
        appendText  = Now("yyyy-MM-dd HH:mm:ss") + " --------------------------------\n\n" +
                     "ResponseCode = " + responseCode + "\n\n" +
                     "Log:\n" + logText + "\n\n";
        SaveFile(appendText, logFilePath, "a");
    } catch (ex) {
        Mbox("CRITICAL: Cannot write to log file: " + logPath + "\nError: " + ex);
    }
}

