    SetWidgetOptions("btnPrikazi",  "IsEnabled", "true");
    SetWidgetOptions("btnPreuzmi",  "IsEnabled", "false");
    SetWidgetOptions("StatusLabel", "Content",   "");
    SetWidgetOptions("StatusLabel2","Content",   "");

    cursor("dflt");
    Mbox("Kraj");
}

// Helper function to get next record ID
//this is single user version; for multiuser one, it must be modified with a kind of locking scheme
function GetNextRecordId(tableName) {
    sql_max = "SELECT isnull(MAX(NKPR_GL_NUM),0) AS lastNum FROM " + databaseName + ".dbo." + tableName;
    result = sqlQuery(sql_max);
    if (Size(result) >= 2 && result[1][0] != 0) {
        return (result[1][0] + 1);
    } else {
        // First record
        return 1; // Starting ID
    }
}

