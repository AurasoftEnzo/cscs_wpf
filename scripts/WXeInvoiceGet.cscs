// -----------------------------------------------------------
// WXeInvoiceGet.cscs - UBL XML Outgoing Invoice Import
// -----------------------------------------------------------
// Purpose: Import UBL XML outgoing invoices into NKPRINV/NKPRINVL
// Entry:   WXeInvoiceGet_onDisplay()
// Mirror:  wxeracunget.cscs (incoming); customer/supplier sides swapped
// -----------------------------------------------------------

Import(strTrim(mpath()) + "CSCS.Math.dll");
CreateWindow(strTrim(tpath()) + "WXeInvoiceGet.xaml", strTrim(ipath()) + "icons\\" + "wxeracunget.ico");

DEFINE cntr1 type i;
DEFINE Rbr type i;
DEFINE TEMP_Rbr type i;

DEFINE arrayRbr type i size 100 array 10000;
DEFINE TEMP_arrayRbr type i size 100 array 10000;

DEFINE arrayKupac type a size 500 array 10000;
DEFINE TEMP_arrayKupac type a size 500 array 10000;

DEFINE arrayOibKupca type a size 11 array 10000;
DEFINE TEMP_arrayOibKupca type a size 11 array 10000;

DEFINE arrayDatumIzdavanja type a size 10 array 10000;
DEFINE TEMP_arrayDatumIzdavanja type a size 10 array 10000;

DEFINE arrayDatumPDVa type a size 10 array 10000;
DEFINE TEMP_arrayDatumPDVa type a size 10 array 10000;

DEFINE arrayBrojRacuna type a size 50 array 10000;
DEFINE TEMP_arrayBrojRacuna type a size 50 array 10000;

DEFINE arrayBrojRacunaFina type a size 80 array 10000;
DEFINE TEMP_arrayBrojRacunaFina type a size 80 array 10000;

DEFINE arrayBrojRacunaMer type a size 80 array 10000;
DEFINE TEMP_arrayBrojRacunaMer type a size 80 array 10000;

DEFINE FilterDateFrom type d size 10;
DEFINE FilterDateTo type d size 10;

dtNow = DateTime();
doubleToday = Math.Trunc(DateTimeToDouble(dtNow));
FilterDateFrom = DoubleToDateTime(doubleToday - 60).ToString("yyyy-MM-dd");
FilterDateTo = DoubleToDateTime(doubleToday + 7).ToString("yyyy-MM-dd");

// -----------------------------------------------------------
function WXeInvoiceGet_onDisplay(){
    if(year(FilterDateFrom) < 2026){
        FilterDateFrom = "2026-01-01";
    }
    cursor("wait");
    SetWidgetOptions("btnPreuzmi", "IsEnabled", "false");
    try{
        init();
        SetWindowOptions("WXeInvoiceGetWindow", "title", "Preuzimanje izlaznih e-računa(" + PROVIDER + ") za " + KPSY_COMP_NAME);
    }catch(ex){
        Mbox("Greška pri inicijalizaciji:\n" + ex);
        exit;
    }
    cursor("dflt");
    SetWidgetOptions("StatusLabel", "Content", "");
    SetWidgetOptions("StatusLabel2", "Content", "");
}

function init(){
    args = CommandLineArgs();
    if(Size(args) > 2){
        companyCode = args[2];
        CoSet(companyCode);
        if(Size(args) > 3){
            userCode = args[3];
        }else{
            Mbox("Nedostaje user code u argumentima.");
            exit;
        }
    }else{
        companyCode = Substring(CoGet(), 1, 2);
    }

    // NKSYCCYR
    sqlQueryString = "select SY_CC_USER, SY_CC_DBASE, SY_CC_STATUS from " + strtrim(CommonDBGet()) + ".dbo.NKSYCCYR WHERE SY_CC_CODE = '" + companyCode + "'";
    try{
        sqlResult = sqlQuery(sqlQueryString);
    }catch(ex){
        Mbox("Greška čitanja NKSYCCYR:\n" + ex);
        exit;
    }
    if(size(sqlResult) > 1){
        SY_CC_USER = sqlResult[1][0].trim();
        databaseName = sqlResult[1][1].trim();
        SY_CC_STATUS = sqlResult[1][2].trim();
    }
    if(SY_CC_STATUS != "D"){
        Mbox("Tvrtka " + companyCode + " nije klijent Knjigovodstvenog servisa, i ovaj program ne može koristiti.");
        exit;
    }
    // NKSYSYCO
    sqlQueryString = " SELECT NKSYS_FIELD, NKSYS_VALUE
        FROM " + databaseName + ".dbo.NKSYSYCO
        WHERE NKSYS_MODUL = 'WKSY'
        AND NKSYS_GRUP = 'ERACUN'";
    try{
        sqlResult = sqlQuery(sqlQueryString);
    }catch(ex){
        Mbox("Greška čitanja NKSYSYCO:\n" + ex);
        exit;
    }

    FILESPATH = "";
    PROVIDER = "";
    SCHEMASPATH = "";
    CERTPATH = "";
    //ERPID = "";
    SISTEM_RADA = "";
    APP_RADI = "";
    USE_ASCONTO = "";

    if(size(sqlResult) > 1){
        for(i = 1; i < Size(sqlResult); i++){
            if(sqlResult[i][0].trim() == "FILESPATH")   { FILESPATH   = sqlResult[i][1].trim(); }
            elif(sqlResult[i][0].trim() == "PROVIDER")  { PROVIDER    = sqlResult[i][1].trim(); }
            elif(sqlResult[i][0].trim() == "SCHEMASPATH"){ SCHEMASPATH = sqlResult[i][1].trim(); }
            elif(sqlResult[i][0].trim() == "CERTPATH")  { CERTPATH    = sqlResult[i][1].trim(); }
            //elif(sqlResult[i][0].trim() == "ERPID")  { ERPID    = sqlResult[i][1].trim(); }
            elif(sqlResult[i][0].trim() == "SISTEM_RADA")  { SISTEM_RADA    = sqlResult[i][1].trim(); }
            elif(sqlResult[i][0].trim() == "APP_RADI")  { APP_RADI    = sqlResult[i][1].trim(); }
            elif(sqlResult[i][0].trim() == "USE_ASCONTO")  { USE_ASCONTO    = sqlResult[i][1].trim(); }
        }
    }

    if(SISTEM_RADA == "S"){
        Mbox("Ovaj se program ne može koristiti- Servis za e-račune je uključen!");
        exit;
    } else{
        if(APP_RADI == "U"){
            Mbox("Izlazni e-računi nisu predviđeni za preuzimanje!");
            exit;
        }
    }

    if(USE_ASCONTO == "D"){
        useAsconto = true;
    }else{
        useAsconto = false;
    }

    // KPSYMSTR
    sqlQueryString = " SELECT TOP 1 KPSY_REZERVA, KPSY_COMP_NAME, KPSY_COMP_ADD1, KPSY_GL_RETEARN, KPSY_COMP_CSZ, KPSY_COMP_ZIP,
                    KPSY_COMP_JMBFI, KPSY_COMP_PHONE, KPSY_COMP_EMAIL, KPSY_PO_FREIGHT, KPSY_REZERVAX, KPSY_FISCAL_YR
                        FROM " + databaseName + ".dbo.KPSYMSTR";
    try{
        sqlResult = sqlQuery(sqlQueryString);
    }catch(ex){
        Mbox("Greška čitanja KPSYMSTR:\n" + ex);
        exit;
    }
    if(size(sqlResult) > 1){
        KPSY_REZERVA    = sqlResult[1][0].trim();
        KPSY_COMP_NAME  = sqlResult[1][1].trim();
        KPSY_COMP_ADD1  = sqlResult[1][2].trim();
        KPSY_GL_RETEARN = sqlResult[1][3].trim();
        KPSY_COMP_CSZ   = sqlResult[1][4].trim();
        KPSY_COMP_ZIP   = sqlResult[1][5];
        KPSY_COMP_JMBFI = sqlResult[1][6].trim();
        KPSY_COMP_PHONE = sqlResult[1][7].trim();
        KPSY_COMP_EMAIL = sqlResult[1][8].trim();
        KPSY_PO_FREIGHT = substring(sqlResult[1][9], 0, 2).trim();
        KPSY_REZERVAX   = sqlResult[1][10].trim();
        KPSY_FISCAL_YR  = sqlResult[1][11];
    }
}

