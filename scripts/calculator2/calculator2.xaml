<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wcl="clr-namespace:WpfControlsLibrary;assembly=WpfControlsLibrary"
    mc:Ignorable="d"
    Title="Calculator"
    Height="600"
    Width="320"
    ResizeMode="NoResize"
    Background="#1C1C1E">

    <Window.Resources>
        <!-- Base style for digit buttons -->
        <Style TargetType="Button" x:Key="CalcBtn">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3A3A3C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="38">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Operator buttons: orange -->
        <Style TargetType="Button" x:Key="OpBtn" BasedOn="{StaticResource CalcBtn}">
            <Setter Property="Background" Value="#FF9F0A"/>
        </Style>

        <!-- Top row buttons (C, +/-, %): gray -->
        <Style TargetType="Button" x:Key="TopBtn" BasedOn="{StaticResource CalcBtn}">
            <Setter Property="Background" Value="#636366"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Display — bound to CSCS variable displayStr via FieldName -->
        <wcl:ASEnterBox
            Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
            Name="txtDisplay"
            FieldName="displayStr"
            Size="20"
            FontSize="36"
            Foreground="White"
            Background="#1C1C1E"
            Margin="8,12,8,4"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"/>

        <!-- Row 1: C  +/-  %  ÷ -->
        <Button Grid.Row="1" Grid.Column="0" Name="btnClear"   Content="C"   Style="{StaticResource TopBtn}"/>
        <Button Grid.Row="1" Grid.Column="1" Name="btnSign"    Content="+/-" Style="{StaticResource TopBtn}"/>
        <Button Grid.Row="1" Grid.Column="2" Name="btnPercent" Content="%"   Style="{StaticResource TopBtn}"/>
        <Button Grid.Row="1" Grid.Column="3" Name="btnDiv"     Content="÷"   Style="{StaticResource OpBtn}"/>

        <!-- Row 2: 7  8  9  × -->
        <Button Grid.Row="2" Grid.Column="0" Name="btn7"   Content="7" Style="{StaticResource CalcBtn}"/>
        <Button Grid.Row="2" Grid.Column="1" Name="btn8"   Content="8" Style="{StaticResource CalcBtn}"/>
        <Button Grid.Row="2" Grid.Column="2" Name="btn9"   Content="9" Style="{StaticResource CalcBtn}"/>
        <Button Grid.Row="2" Grid.Column="3" Name="btnMul" Content="×" Style="{StaticResource OpBtn}"/>

        <!-- Row 3: 4  5  6  − -->
        <Button Grid.Row="3" Grid.Column="0" Name="btn4"   Content="4" Style="{StaticResource CalcBtn}"/>
        <Button Grid.Row="3" Grid.Column="1" Name="btn5"   Content="5" Style="{StaticResource CalcBtn}"/>
        <Button Grid.Row="3" Grid.Column="2" Name="btn6"   Content="6" Style="{StaticResource CalcBtn}"/>
        <Button Grid.Row="3" Grid.Column="3" Name="btnSub" Content="−" Style="{StaticResource OpBtn}"/>

        <!-- Row 4: 1  2  3  + -->
        <Button Grid.Row="4" Grid.Column="0" Name="btn1"   Content="1" Style="{StaticResource CalcBtn}"/>
        <Button Grid.Row="4" Grid.Column="1" Name="btn2"   Content="2" Style="{StaticResource CalcBtn}"/>
        <Button Grid.Row="4" Grid.Column="2" Name="btn3"   Content="3" Style="{StaticResource CalcBtn}"/>
        <Button Grid.Row="4" Grid.Column="3" Name="btnAdd" Content="+" Style="{StaticResource OpBtn}"/>

        <!-- Row 5: 0 (spans 2 cols)  .  = -->
        <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Name="btn0"      Content="0" Style="{StaticResource CalcBtn}"/>
        <Button Grid.Row="5" Grid.Column="2"                      Name="btnDot"    Content="." Style="{StaticResource CalcBtn}"/>
        <Button Grid.Row="5" Grid.Column="3"                      Name="btnEquals" Content="=" Style="{StaticResource OpBtn}"/>

        <!-- Row 6: x²  √  xʸ  ʸ√x -->
        <Button Grid.Row="6" Grid.Column="0" Name="btnSq"      Content="x²"  Style="{StaticResource TopBtn}"/>
        <Button Grid.Row="6" Grid.Column="1" Name="btnSqrt"    Content="√"   Style="{StaticResource TopBtn}"/>
        <Button Grid.Row="6" Grid.Column="2" Name="btnPow"     Content="xʸ"  Style="{StaticResource OpBtn}"/>
        <Button Grid.Row="6" Grid.Column="3" Name="btnNthRoot" Content="ʸ√x" Style="{StaticResource OpBtn}"/>
    </Grid>
</Window>
