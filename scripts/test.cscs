
define dateArr type D size 10 array 100;
define groupArr type I size 3 array 100;
define qtyArr type N size 6 array 100;

aCntr = 5;

dateArr[0] = "2026-01-01";
dateArr[1] = "2025-01-01";
dateArr[2] = "2022-01-01";
dateArr[3] = "2024-01-01";
dateArr[4] = "2030-01-01";

groupArr[0] = 3;
groupArr[1] = 3;
groupArr[2] = 3;
groupArr[3] = 1;
groupArr[4] = 1;

qtyArr[0] = 1;
qtyArr[1] = 2;
qtyArr[2] = 3;
qtyArr[3] = 4;
qtyArr[4] = 5;



list_of_array_names = {"groupArr", "dateArr", "qtyArr"};

SORTA groupArr[aCntr]+dateArr[aCntr] NUM aCntr MOVE list_of_array_names CNTR aCntr ASC;

MSG("groupArr:\n" + groupArr + "\n" 
    + "dateArr:\n" + dateArr + "\n" 
    + "qtyArr:\n" + qtyArr);