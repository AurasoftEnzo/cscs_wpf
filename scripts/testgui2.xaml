<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wcl="clr-namespace:WpfControlsLibrary;assembly=WpfControlsLibrary"
        Title="E-Racun Pregled i Ispis" 
        Height="800" Width="811"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#FF2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFBDBDBD"/>
                    <Setter Property="Foreground" Value="#FF757575"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Margin" Value="5,5,5,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#FF2196F3"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Window.Resources>

<GroupBox x:Name="groupbox1" Header="Choose an option" Margin="10"> 
    <Grid x:Name="grid1"> 
        <Grid.RowDefinitions> 
            <RowDefinition Height="50" /> 
            <RowDefinition Height="50" /> 
            <RowDefinition Height="50" /> 
            <RowDefinition Height="50" /> 
            <RowDefinition Height="150" />
            <RowDefinition Height="350" />
        </Grid.RowDefinitions>

        <ToolBarTray x:Name="toolbartray1" Grid.Row="0"> 
            <ToolBar> 
                <Button x:Name="btnToolbar1" Content="Button 1" Width="80" /> 
                <Button x:Name="btnToolbar2" Content="Button 2" Width="80" /> 
                <Separator x:Name="sep1" /> 
                <Button x:Name="btnToolbar3" Content="Button 3" Width="80" /> 
            </ToolBar> 
        </ToolBarTray>

        <DockPanel x:Name = "dockpanel1"
                   Grid.Row="1"                   
                   Width = "400">
            <TextBlock x:Name="txtTitle"                   
                   Text="PREGLED I ISPIS" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Foreground="Red"
                   HorizontalAlignment="Center"
                   Width="200"
                   />
        </DockPanel>
        <RadioButton x:Name="rb1" Grid.Row="2" Content="Option 1" GroupName="MyGroup" DataContext="radiobutton1DC"/> 
        <RadioButton x:Name="rb2" Grid.Row="3" Content="Option 2" GroupName="MyGroup" DataContext="radiobutton2DC" IsChecked="True" /> 

        <GroupBox x:Name="groupbox2" Grid.Row="4" Header="Opcije2" Margin="10"> 
            <Grid x:Name="grid2"> 
                <Grid.RowDefinitions> 
                    <RowDefinition Height="50" /> 
                    <RowDefinition Height="50" /> 
                </Grid.RowDefinitions>

                <RadioButton x:Name="rb3" Grid.Row="0" Content="Option 3" GroupName="MyGroup2" DataContext="radiobutton3DC" IsChecked="True"/> 
                <RadioButton x:Name="rb4" Grid.Row="1" Content="Option 4" GroupName="MyGroup2" DataContext="radiobutton4DC" /> 
            </Grid> 
        </GroupBox>  

        <Grid x:Name="grid3" Grid.Row="5"> 
            <Grid.RowDefinitions> 
                <RowDefinition Height="60" /> 
                <RowDefinition Height="60" /> 
                <RowDefinition Height="60" /> 
                <RowDefinition Height="60" /> 
                <RowDefinition Height="60" /> 
                <RowDefinition Height="60" /> 
            </Grid.RowDefinitions>

            <StackPanel x:Name="stackpanel1"                        
                        Width="300">
                <Border x:Name="border1"
                        BorderBrush="Orange"
                        BorderThickness="2"
                        Background="LightGreen"
                        CornerRadius="10">
                    <ComboBox x:Name="combobox1"
                      Width="150" 
                      Height="40"
                      Margin="5"
                      Grid.Row="0"> 
                        <ComboBoxItem Content="Option 1" /> 
                        <ComboBoxItem Content="Option 2" /> 
                        <ComboBoxItem Content="Option 3" /> 
                    </ComboBox>
                </Border>
            </StackPanel>
            <RichTextBox x:Name = "richtextbox1"
                         Grid.Row="1"
                         Width="200"
                         Height="40"
                         >
                <FlowDocument> 
                    <Paragraph>RichABC</Paragraph> 
                </FlowDocument>
            </RichTextBox>

            <TextBox x:Name="textbox1"
                     Grid.Row="2"
                     Width="200"
                     Height = "40"
                     Margin="10"
                     Text="Hello TextBoxWorld" />
                
            <DatePicker x:Name="datepicker1"
                        Grid.Row="3"
                        Width="200"
                        Height = "40"
                        SelectedDate="2026-03-03">
            </DatePicker>

            <wcl:ASDateEditer x:Name="dateediter1"
                              Grid.Row="4"
                              Width="200"
                              Height="22"
                              ButtonWidth="19"
                              FontSize="14"
                              DisplaySize="8"
                              DataContext="datum1">
            </wcl:ASDateEditer>

            <wcl:ASHorizontalBar x:Name="HorizontalBarLT" 
                                 Grid.Row="5"                                    
                                 Height="32"
                                 Width="200"                                
                                 FontSize="24"                                                                          
                                 FontFamily="Lato"
                                 FontWeight="Bold"
                                 BarColor="#FFC4E08A"
                                 Background="#7E909A" />

        </Grid>   
    </Grid> 

</GroupBox>


</Window>