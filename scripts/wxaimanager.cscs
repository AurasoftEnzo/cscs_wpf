// Note: widget values are read via DataContext-bound script variables.
// SetWidgetOptions is used only for write operations and non-bound controls.


// =============================================================
//  RAG PERIODIC REFRESH
//  Runs in background via AsyncCall, checks heartbeat every
//  30 seconds and updates the status bar.
//  Falls back to local processing if service disappears.
// =============================================================

function RAG_StartPeriodicRefresh() {
    AsyncCall("RAG_RefreshLoop", "RAG_RefreshDone", 0);
}

function RAG_RefreshLoop() {
    Sleep(30000);  // 30 sekundi
    try {
        if (ragServiceActive) {
            if (!RAG_CheckHeartbeat()) {
                // Servis je prestao slati heartbeat
                ragServiceActive = false;
                RunOnMain("RAG_HandleServiceLost");
            } else {
                RunOnMain("RAG_UpdateStatusBar");
            }
        }
    } catch (ex) {
        MSG("RAG_RefreshLoop error: " + ex);
    }
}

function RAG_HandleServiceLost() {
    RAG_UpdateStatusBar();
    SetStatus("RAG servis nije dostupan – prelazak na lokalnu obradu.");
    AsyncCall("Embedding_ProcessPendingAll", "Embedding_ProcessDone", 0);
}

function RAG_RefreshDone(sender, result) {
    // Re-schedule the next periodic refresh
    RAG_StartPeriodicRefresh();
}


// =============================================================
//  HISTORY (SESSION) SEARCH
// =============================================================

function btnHistSearch@clicked() {
    term = GetWidgetOptions("txtHistSearch", "Text");
    term = term.Trim();
    if (term == "") {
        return;
    }
    SetStatus("Tražim '" + term + "' u svim sesijama...");
    SQL_SearchHistory(term);
    histSearchActive = true;
    if (histCount == 0) {
        SetStatus("Nema rezultata za '" + term + "'.");
    } else {
        SetStatus("Pronađeno " + histCount + " sesija za '" + term + "'.");
    }
}

function btnHistSearchClear@clicked() {
    SetWidgetOptions("txtHistSearch", "Text", "");
    histSearchActive = false;
    SQL_LoadHistoryFromDB();
    SetStatus("Pretraga poništena – prikazan puni popis.");
}


// =============================================================
//  CHAT SEARCH
// =============================================================

function doSearch() {
    term = GetWidgetOptions("txtChatSearch", "Text");
    if (term == "") {
        ClearChatSearch();
        SetWidgetOptions("lblSearchCount", "Text", "");
        searchMatchCount = 0;
        return;
    }
    searchMatchCount = SearchChatMessages(term);
    if (searchMatchCount == 0) {
        SetWidgetOptions("lblSearchCount", "Text", "0 rezult.");
    } else {
        SetWidgetOptions("lblSearchCount", "Text", "1/" + searchMatchCount);
    }
}

function ResetChatSearch() {
    ClearChatSearch();
    SetWidgetOptions("txtChatSearch", "Text", "");
    SetWidgetOptions("lblSearchCount", "Text", "");
    searchMatchCount = 0;
}

function btnChatSearch@clicked() {
    doSearch();
}

function btnChatSearchNext@clicked() {
    if (searchMatchCount == 0) {
        return;
    }
    idx = SearchChatNext();
    SetWidgetOptions("lblSearchCount", "Text", idx + "/" + searchMatchCount);
}

function btnChatSearchPrev@clicked() {
    if (searchMatchCount == 0) {
        return;
    }
    idx = SearchChatPrev();
    SetWidgetOptions("lblSearchCount", "Text", idx + "/" + searchMatchCount);
}

function btnChatSearchClear@clicked() {
    ResetChatSearch();
}
