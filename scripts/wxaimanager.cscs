// ============================================================
//  WXAIMANAGER.CSCS
//  AI Chat Manager – CSCS_WPF implementation
//
//
//  Features:
//    - Multi-provider AI chat (OpenAI, Ollama, Azure OpenAI, OpenRouter)
//    - Conversation history (session)
//    - Configurable system prompt, temperature, max tokens
//    - Settings saved to local config file
//    - SQL Server persistence (ChatSession / ChatMessage / ChatChunk)
// ============================================================

include(DownloadScripts() == true ? Download(ServerAddress() + "wxaimanager_SQL.cscs") : strTrim(tpath()) + "wxaimanager_sql.cscs");
include(DownloadScripts() == true ? Download(ServerAddress() + "wxaimanager_attachments.cscs") : strTrim(tpath()) + "wxaimanager_attachments.cscs");
include(DownloadScripts() == true ? Download(ServerAddress() + "wxaimanager_websearch.cscs") : strTrim(tpath()) + "wxaimanager_websearch.cscs");

CreateWindow(strTrim(tpath()) + "wxaimanager.xaml");

// ---- Settings -----------------------------------------------
DEFINE aiProvider type a size 30;
DEFINE aiApiKey type a size 500;
DEFINE aiBaseUrl type a size 300;
DEFINE aiModel type a size 100;
DEFINE aiSystemPrompt type a size 3000;
DEFINE aiTemperatureStr type a size 10;
DEFINE aiMaxTokensStr type a size 10;
DEFINE settingsFilePath type a size 400;

// ---- Current conversation -----------------------------------
DEFINE msgCount type i;
DEFINE msgCountOnLoad type i;
DEFINE msgRole type a size 20  array 200;
DEFINE msgContent type a size 5000 array 200;

// ---- Conversation history (session) -------------------------
DEFINE histCount type i;
DEFINE histLineCntr type r;
DEFINE histActive type r;
DEFINE histMax type r;

DEFINE arrayHistChatId type a size 30 array 50;
DEFINE arrayHistDate type a size 30 array 50;
DEFINE arrayHistTitle type a size 150 array 50;
DEFINE arrayHistText type a size 20000 array 50;

// ---- State --------------------------------------------------
DEFINE isWaiting type l;
DEFINE settingsOpen type l;

// ---- Speech-to-Text (STT) settings --------------------------
DEFINE sttProvider type a size 30;
DEFINE sttApiKey type a size 500;
DEFINE sttBaseUrl type a size 300;
DEFINE sttLanguage type a size 10;
DEFINE isRecording type l;

// ---- Token usage stats (shown in Settings panel) -----------
DEFINE statInputTokens  type a size 30;
DEFINE statOutputTokens type a size 30;
DEFINE statTotalTokens  type a size 30;
DEFINE userCode type a size 30;

// ---- Auto-summarization state -----------------------------
DEFINE sessionSummary type a size 10000;  // SummaryText from ChatSession
DEFINE sessionMsgsSinceSummary type i;             // messages since last summary
DEFINE sessionToksSinceSummary type i;             // prompt tokens since last summary

// ---- Async API temp storage ---------------------------------
DEFINE apiLastResponse type a size 20000;
DEFINE apiLastCode type i;
DEFINE apiLastError type a size 500;
DEFINE summaryApiResponse type a size 10000;
DEFINE summaryApiCode type i;

// ---- Web search -----------------------------------------------
// (webSearchEnabled and webSearchApiKey are DEFINE'd in wxaimanager_websearch.cscs)


// =============================================================
//  WINDOW LIFECYCLE
// =============================================================

function wxaimanager_OnStart() {
    // --- command-line parameters ---
    userCode = "Nepoznati";
    args = CommandLineArgs();

    if (Size(args) > 2) {
        userCode = args[2];   // e.g. ANA
        if (userCode == "") {
            userCode = "Nepoznati";
        }
    }
    settingsFilePath = strTrim(tpath()) + "wxaimanager_cfg.txt";

    // --- SQL persistence setup ---
    WXAI_DB        = "WXAIMANAGEMENT_CHATS";

    chatSqlEnabled = true;

    SQL_InitDatabaseAndTables();
    SQL_InitAttachmentTables();

    chatUserId     = userCode;
    
    SQL_InitNewSession();

    // --- defaults ---
    aiProvider       = "OpenAI";
    aiApiKey         = "";
    aiBaseUrl        = "https://api.openai.com/v1";
    aiModel          = "GPT-4.1";
    aiSystemPrompt   = "You are a helpful assistant.";
    aiTemperatureStr = "0.7";
    aiMaxTokensStr   = "2000";

    //LoadSettings();

    // --- chat state ---
    chatDisplayText  = "";
    msgCount         = 0;
    msgCountOnLoad   = 0;
    histCount        = 0;
    histMax          = 50;
    histActive       = 0;
    histLineCntr     = 0;
    isWaiting        = false;
    settingsOpen     = false;
    userInput        = "";
    statInputTokens  = "---";
    statOutputTokens = "---";
    statTotalTokens  = "---";

    // --- summarization state ---
    sessionSummary          = "";
    sessionMsgsSinceSummary = 0;
    sessionToksSinceSummary = 0;

    // --- web search state ---
    webSearchEnabled = false;
    webSearchApiKey  = "";

    // --- STT state ---
    sttProvider = "Whisper API";
    sttApiKey   = "";
    sttBaseUrl  = "";
    sttLanguage = "hr";
    isRecording = false;

    LoadSettings();


    // --- populate provider ComboBox ---
    comboItems2 = {"OpenAI","Ollama","Azure OpenAI","OpenRouter","Custom"};
    AddWidgetData("cbProvider", comboItems2);
    // SetWidgetOptions("cbProvider", "Text", aiProvider);

    // --- apply saved settings to UI ---
    SetWidgetOptions("txtModel",        "Text", aiModel);
    SetWidgetOptions("txtApiKey",       "Text", aiApiKey);
    SetWidgetOptions("txtBaseUrl",      "Text", aiBaseUrl);
    SetWidgetOptions("txtSystemPrompt", "Text", aiSystemPrompt);
    SetWidgetOptions("txtTemperature",  "Text", aiTemperatureStr);
    SetWidgetOptions("txtMaxTokens",       "Text", aiMaxTokensStr);
    //SetWidgetOptions("txtWebSearchApiKey", "Text", webSearchApiKey);
    SetWidgetOptions("txtSttProvider", "Text", sttProvider);
    SetWidgetOptions("txtSttApiKey",   "Text", sttApiKey);
    SetWidgetOptions("txtSttBaseUrl",  "Text", sttBaseUrl);
    SetWidgetOptions("txtSttLanguage", "Text", sttLanguage);

    // --- hide settings panel initially ---
    SetWidgetOptions("panelSettings", "Visible", false); // should be Collapsed 

    // --- history grid ---
    // DisplayArray("datagridHistory", "close");
    // DisplayArraySetup("datagridHistory", counterFld: histLineCntr, activeElements: histActive, maxElements: histMax);

    // --- status ---
    SetStatus("Spreman. Unesite poruku i pritisnite Pošalji.");
    UpdateProviderLabel();

    // --- welcome ---
    ShowWelcome();

    // --- load history from DB ---
    SQL_LoadHistoryFromDB();
}

function wxaimanager_OnDisplay() {
    // intentionally empty
}

function wxaimanager_OnClose() {
    // intentionally empty – history is in-memory only
}


// =============================================================
//  BUTTON EVENTS
// =============================================================

function btnSend@clicked() {
    if (isWaiting) {
        return;
    }
    // aiProvider, aiModel and userInput are kept in sync via DataContext bindings
    userInput= GetWidgetOptions("txtInput", "Text");    
    inputText = userInput;
    inputText = inputText.Trim();
    if (inputText == "") {
        SetStatus("Unesite poruku za slanje.");
        return;
    }
    // Add user message
    msgRole[msgCount]    = "user";
    msgContent[msgCount] = inputText;
    msgCount++;

    // Display user message
    AppendToDisplay("Vi", inputText);
    // Persist user message to SQL
    SQL_SaveUserMessage(inputText);
    // Clear input
    SetWidgetOptions("txtInput", "Text", "");
    // Send to AI
    //msg('User message processed, sending to AI. Current session ID: ' + currentSessionId);
    SendToAI();

    SaveCurrentChatToHistory();
}

function btnNewChat@clicked() {
    // if (msgCount > 0) {
    //     SaveCurrentChatToHistory();
    // }
    StartNewChat();
}

function btnSettings@clicked() {
    if (settingsOpen) {
        SetWidgetOptions("panelSettings", "Visible", false);
        settingsOpen = false;
        SetWidgetOptions("btnSettings", "Content", "Postavke");
    } else {
        SQL_LoadTokenStats();   // refresh token usage for current provider
        SetWidgetOptions("panelSettings", "Visible", true);
        settingsOpen = true;
        SetWidgetOptions("btnSettings", "Content", "Zatvori postavke");
    }
}

function btnSaveSettings@clicked() {
    SaveSettings();
    SQL_LoadTokenStats();   // provider may have changed, refresh stats
    SetWidgetOptions("panelSettings", "Visible", false);
    settingsOpen = false;
    SetWidgetOptions("btnSettings", "Content", "Postavke");
    UpdateProviderLabel();
    SetStatus("Postavke su uspješno spremljene.");
}

function btnCancelSettings@clicked() {
    SetWidgetOptions("panelSettings", "Visible", false);
    settingsOpen = false;
    SetWidgetOptions("btnSettings", "Content", "Postavke");
    LoadSettings();   // restore controls to last-saved values
    SetStatus("Promjene postavki odbačene.");
}

function btnClearChat@clicked() {
    // if (msgCount > 0) {
    //     SaveCurrentChatToHistory();
    // }
    StartNewChat();
}

function btnAddAttachment@clicked() {
    Attachment_SelectAndUpload();
}

function btnImportFolder@clicked() {
    Attachment_ImportFolder();
}

function btnVoice@clicked() {
    if (isRecording == false) {
        VoiceInputStart();
        isRecording = true;
        SetWidgetOptions("btnVoice", "Content", "⏹");
        SetWidgetOptions("btnVoice", "Background", "#C0392B");
        SetStatus("Snimam govor... Kliknite ⏹ za zaustavljanje.");
    } else {
        effApiKey = sttApiKey;
        if (effApiKey == "") {
            effApiKey = aiApiKey;
        }
        effBaseUrl = sttBaseUrl;
        if (effBaseUrl == "") {
            effBaseUrl = aiBaseUrl;
        }
        VoiceInputStop(sttProvider, effApiKey, effBaseUrl, sttLanguage);
        isRecording = false;
        SetWidgetOptions("btnVoice", "Content", "🎤");
        SetWidgetOptions("btnVoice", "Background", "#276A5C");
        SetStatus("Prepisujem govor...");
    }
}

// Provider ComboBox change
// aiProvider is kept in sync via DataContext="aiProvider" on the ComboBox.
function cbProvider@change(sender, args) {
    UpdateBaseUrlForProvider();
    UpdateProviderLabel();
}


// =============================================================
//  HISTORY DATAGRID
// =============================================================

function datagridHistory@select() {
    try {
        selectedIndex = GetWidgetOptions("datagridHistory", "SelectedIndex");
        
        // MSG(selectedIndex);
        
         rowData = GetSelectedGridRow("datagridHistory");

         if (Size(rowData) < 2) {
             return;
         }
        if (selectedIndex < 0 || selectedIndex >= histCount) {
            return;
        }

         selectedDate = rowData[0];

         // Find matching history entry by date (unique key)
         for (i = 0; i < histCount; i++) {
             if (arrayHistDate[i] == selectedDate) {
                 LoadHistoryItem(i);
                 return;
             }
         }

        // Fallback: date not matched, use array index directly
        LoadHistoryItem(selectedIndex);

    } catch (ex) {
        SetStatus("Greška pri učitavanju razgovora: " + ex);
    }
}


// =============================================================
//  API CALL
// =============================================================

function SendToAI() {
    try {
        // All settings variables are kept in sync via DataContext bindings on the
        // respective TextBox/ComboBox controls – just read them directly.
        if (aiBaseUrl == "") {
            SetStatus("Greška: Base URL nije postavljen. Provjerite postavke.");
            return;
        }

        // Build endpoint URL
        // OpenAI-compatible: POST /chat/completions
        endpoint = aiBaseUrl;
        if (!endpoint.EndsWith("/")) {
            endpoint = endpoint + "/";
        }
        endpoint = endpoint + "chat/completions";

        // ---- Collect attachments for this session ----
        textContext = "";
        visionItems = "";
        binaryFiles = {};

        attachRes = Attachment_QueryForSend(currentSessionId);
        attachCnt = Size(attachRes) - 1;

        if (attachCnt > 0) {
            for (ai = 0; ai < attachCnt; ai++) {
                aRow   = attachRes[ai + 1];
                aName  = aRow[0];   // OriginalFileName
                aMime  = aRow[1];   // MimeType
                aPath  = aRow[2];   // StoragePath
                aText  = aRow[3];   // ExtractedText
                // aStatus = aRow[4];

                aKind = Attachment_ClassifyMime(aMime);

                if (aKind == "text" && aText != "") {
                    // Include extracted text as context block
                    textContext = textContext + "[Prilog: " + aName + "]\n" + aText + "\n\n";
                } elif (aKind == "image") {
                    // Encode image as base64 and add as vision content entry
                    b64 = File2Base64(aPath);
                    if (b64 != "") {
                        visionItems = visionItems
                            + ',{"type":"image_url","image_url":{"url":"data:'
                            + aMime + ';base64,' + b64 + '"}}';
                    }
                } else {
                    // Binary file – collect for multipart upload
                    binaryFiles.Add({aName, aPath, "file"});
                }
            }

            if (textContext != "") {
                textContext = "--- Priloženi dokumenti ---\n" + textContext + "---";
            }
        }

        // ---- Web search context ----
        // WebSearch_Execute handles the enabled/disabled check and temporal
        // keyword auto-trigger internally; it returns "" when nothing is needed.
   //msg("Web search enabled: " + webSearchEnabled);
        webCtx = WebSearch_Execute(inputText);
//msg("Web search context returned: " + webCtx);
        if (webCtx != "") {
            textContext = textContext + webCtx;
        }
        // Per-message toggle: reset checkbox after use
        webSearchEnabled = false;

        // Build JSON payload (enriched with text context and/or vision items)
        jsonBody = BuildApiPayload(textContext, visionItems);
        SetUIBusy(true);
        SetStatus("Šaljem zahtjev AI-u...");

        // Pass API key as bearer token; empty for Ollama / no-auth providers
        authToken = "";
        if (aiApiKey != "") {
            authToken = "Bearer " + aiApiKey;
        }

        headers = {};
        headers["Authorization"] = authToken;

        if (Size(binaryFiles) > 0) {
            // ---- Multipart: JSON payload as text field + binary files ----
            mpBody = {};
            mpBody.Add({"request", jsonBody, "text"});
            for (fi = 0; fi < Size(binaryFiles); fi++) {
                bfRow = binaryFiles[fi];
                mpBody.Add(bfRow);
            }
            WebRequestMPFD("POST", endpoint, mpBody, "noTrackingId",
                           "SendMessageSuccess", "SendMessageFailure",
                           "aiBoundary", headers, 120000, false);
        } else {
            // ---- Standard JSON request ----
            WebRequest2("POST", endpoint, jsonBody, "noTrackingId",
                        "SendMessageSuccess", "SendMessageFailure",
                        "application/json", headers, 120000, false);
        }

    } catch (ex) {
        SetUIBusy(false);
        SetStatus("Greška pri slanju zahtjeva: " + ex);
        AppendToDisplay("GREŠKA", ex);
    }
}

// ----- Async callbacks ---------------------------------------

function SendMessageSuccess(trackingId, responseCode, res) {
    apiLastResponse = res;
    apiLastCode     = int(responseCode);
    RunOnMain("ProcessAIResponse");
}

function SendMessageFailure(trackingId, responseCode, res) {
    apiLastResponse = res;
    apiLastCode     = int(responseCode);
    MSG("API call failed with code " + responseCode + ". Response: " + res);
    //SaveFile(res,"c:\\winx\\api_error_response.txt");

    RunOnMain("ProcessAIError");
}

function SummarizationSuccess(trackingId, responseCode, res) {
    summaryApiResponse = res;
    summaryApiCode     = int(responseCode);
    RunOnMain("ProcessSummarizationResponse");
}

function SummarizationFailure(trackingId, responseCode, res) {
    MSG("Summarization API failed: HTTP " + responseCode);
}

function ProcessSummarizationResponse() {
    try {
        if (summaryApiCode != 200) {
            MSG("Summarization response error: " + summaryApiCode);
            return;
        }
        rObj = DeserializeJson(summaryApiResponse);
        if (Contains(rObj, "choices")) {
            choices = rObj["choices"];
            if (Size(choices) > 0) {
                ch       = choices[0];
                mObj     = ch["message"];
                newSummary = mObj["content"];
                sessionSummary          = newSummary;
                sessionMsgsSinceSummary = 0;
                sessionToksSinceSummary = 0;
                SQL_UpdateSessionSummary(newSummary);
            }
        }
    } catch (ex) {
        MSG("ProcessSummarizationResponse error: " + ex);
    }
}

// Main-thread handlers ----------------------------------------

function ProcessAIResponse() {
    try {
        if (apiLastCode != 200) {
            ProcessAIError();
            return;
        }

        responseObj = DeserializeJson(apiLastResponse);

        // Check for error object in response
        if (Contains(responseObj, "error")) {
            errObj = responseObj["error"];
            if (Contains(errObj, "message")) {
                errMsg = errObj["message"];
            } else {
                errMsg = "Nepoznata API greška";
            }
            AppendToDisplay("API GREŠKA", errMsg);
            SetUIBusy(false);
            SetStatus("API greška: " + errMsg);
            return;
        }
        // Standard OpenAI chat completions response
        if (Contains(responseObj, "choices")) {
            choices = responseObj["choices"];
           if (Size(choices) > 0) {
                choice    = choices[0];
                msgObj    = choice["message"]; 
                content   = msgObj["content"];
                aiModelUsed = "";
                if (Contains(responseObj, "model")) {
                    aiModelUsed = responseObj["model"];
                }
                // Store in conversation
                msgRole[msgCount]    = "assistant";
                msgContent[msgCount] = content;
                msgCount++;
                // Display
                label = "AI";
                if (aiModelUsed != "") {
                    label = "AI (" + aiModelUsed + ")";
                }
                AppendToDisplay(label, content);

                // Extract finish_reason and token usage for SQL logging
                finishReason = "";
                if (Contains(choice, "finish_reason")) {
                    finishReason = choice["finish_reason"];
                }
                promptTokens     = 0;
                completionTokens = 0;
                totalTokens      = 0;
                if (Contains(responseObj, "usage")) {
                    usageObj = responseObj["usage"];
                    if (Contains(usageObj, "prompt_tokens")) {
                        promptTokens = int(usageObj["prompt_tokens"]);
                    }
                    if (Contains(usageObj, "completion_tokens")) {
                        completionTokens = int(usageObj["completion_tokens"]);
                    }
                    if (Contains(usageObj, "total_tokens")) {
                        totalTokens = int(usageObj["total_tokens"]);
                    }
                }
                SQL_SaveAssistantMessage(content, finishReason, promptTokens, completionTokens, totalTokens);

                // Accumulate toward summary trigger (user + assistant = 2 messages)
                sessionMsgsSinceSummary = sessionMsgsSinceSummary + 2;
                sessionToksSinceSummary = sessionToksSinceSummary + promptTokens;
                SQL_CheckAndTriggerSummary();

                SetStatus("Odgovor primljen.");
            }
        } else {
            AppendToDisplay("AI (raw)", apiLastResponse);
            SetStatus("Odgovor primljen (format nepoznat).");
        }

    } catch (ex) {
        AppendToDisplay("GREŠKA parsiranja", ex + "\n\nSirovi odgovor:\n" + apiLastResponse);
        SetStatus("Greška parsiranja odgovora: " + ex);
    }

    SetUIBusy(false);
}

function ProcessAIError() {
    errDetail = "HTTP " + apiLastCode;
    if (apiLastResponse != "") {
        // Try to extract error message from JSON
        try {
            errObj = DeserializeJson(apiLastResponse);
            if (Contains(errObj, "error")) {
                inner = errObj["error"];
                if (Contains(inner, "message")) {
                    errDetail = inner["message"];
                }
            }
        } catch (ex) {
            //errDetail = errDetail + " – " + apiLastResponse;
            errDetail = errDetail + " - " + apiLastResponse;
        }
    }
    AppendToDisplay("API GREŠKA", errDetail);
    SetUIBusy(false);
    SetStatus("API greška: " + errDetail);
}


// =============================================================
//  JSON PAYLOAD BUILDER
// =============================================================

// textContext  – plain text from text attachments / RAG document chunks
// visionItems  – JSON snippet(s) for image_url entries, each starting with ","
//
// Payload order (per spec):
//   1. System prompt
//   2. SummaryText (if available) – as system message
//   3. Last 10 previous messages  – sliding window
//   4+5. RAG document chunks + new user prompt (last message)
function BuildApiPayload(textContext, visionItems) {
    payload  = '{"model": "' + aiModel + '", "messages": [';
    firstMsg = true;

    // 1. System prompt
    if (aiSystemPrompt != "") {
        payload  = payload + '{"role": "system", "content": "' + EscapeForJson(aiSystemPrompt) + '"}';
        firstMsg = false;
    }

    // 2. Incremental summary – context for messages before the sliding window
    if (sessionSummary != "") {
        if (!firstMsg) { payload = payload + ','; }
        summaryCtx = "Sažetak prethodnog razgovora:\n" + sessionSummary;
        payload  = payload + '{"role": "system", "content": "' + EscapeForJson(summaryCtx) + '"}';
        firstMsg = false;
    }

    // 3. Last 10 previous messages (sliding window, excludes current user message)
    msgLast  = msgCount - 1;
    startIdx = 0;
    if (msgLast > 10) {
        startIdx = msgLast - 10;
    }
    for (i = startIdx; i < msgLast; i++) {
        if (!firstMsg) { payload = payload + ','; }
        payload  = payload + '{"role": "' + msgRole[i] + '", "content": "' + EscapeForJson(msgContent[i]) + '"}';
        firstMsg = false;
    }

    // 4+5. RAG document chunks prepended to new user prompt (last message)
    if (msgCount > 0) {
        if (!firstMsg) { payload = payload + ','; }
        lastRole    = msgRole[msgLast];
        lastContent = msgContent[msgLast];

        if (textContext != "") {
            lastContent = textContext + "\n\n" + lastContent;
        }

        if (visionItems != "") {
            // Vision API format: content is a JSON array
            payload = payload + '{"role": "' + lastRole + '", "content": ['
                              + '{"type":"text","text":"' + EscapeForJson(lastContent) + '"}'
                              + visionItems
                              + ']}';
        } else {
            payload = payload + '{"role": "' + lastRole + '", "content": "' + EscapeForJson(lastContent) + '"}';
        }
    }

    payload = payload + ']}';
    return payload;
}

