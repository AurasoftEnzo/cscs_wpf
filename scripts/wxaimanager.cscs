// =============================================================
//  CHAT DISPLAY
// =============================================================

function ShowWelcome() {
    welcomeMsg = "  AI Manager - CSCS_WPF\n";
    welcomeMsg = welcomeMsg + "  Provider: " + aiProvider + "  |  Model: " + aiModel + "\n";
    welcomeMsg = welcomeMsg + "  Unesite poruku u polje ispod i pritisnite Posalji.\n";
    welcomeMsg = welcomeMsg + "  Za promjenu API kljuca i modela koristite Postavke.";
    AppendChatMessage("---", welcomeMsg);
}

function AppendToDisplay(role, content) {
    AppendChatMessage(role, content);
}

function RefreshChatDisplay() {
    // no-op: display is now live via AppendChatMessage
}

function StartNewChat() {
    SQL_InitNewSession();
    chatDisplayText = "";
    msgCount = 0;
    sessionSummary          = "";
    sessionMsgsSinceSummary = 0;
    sessionToksSinceSummary = 0;
    ClearChatMessages();
    ResetChatSearch();
    ShowWelcome();
    KB_UpdateStatusBar();
    SetStatus("Novi razgovor pokrenut.");
}


// =============================================================
//  HISTORY
// =============================================================

function SaveCurrentChatToHistory() {
    if (msgCount <= msgCountOnLoad) {
        return;
    }
    
    // Shift existing history down by 1 (to make room at index 0)
    if (histCount >= 50) {
        // Drop oldest (item at position 49)
        for (i = 49; i > 0; i--) {
            arrayHistChatId[i] = arrayHistChatId[i-1];
            arrayHistDate[i]   = arrayHistDate[i-1];
            arrayHistTitle[i]  = arrayHistTitle[i-1];
            arrayHistText[i]   = arrayHistText[i-1];
        }
    } else {
        // Shift items down (don't drop anything yet)
        for (i = histCount; i > 0; i--) {
            arrayHistChatId[i] = arrayHistChatId[i-1];
            arrayHistDate[i]   = arrayHistDate[i-1];
            arrayHistTitle[i]  = arrayHistTitle[i-1];
            arrayHistText[i]   = arrayHistText[i-1];
        }
        histCount++;
    }

    ts    = Now("dd.MM. HH:mm");
    title = "";
    // Use first user message as title (max 60 chars)
    for (i = 0; i < msgCount; i++) {
        if (msgRole[i] == "user") {
            title = msgContent[i];
            if (title.length > 60) {
                title = Substring(title, 0, 60) + "...";
            }
            break;
        }
    }

    if (title == "") {
        title = "(razgovor bez poruke)";
    }

    // Insert at index 0 (top of list)
    arrayHistChatId[0] = currentSessionId;  // assuming this variable exists
    arrayHistDate[0]   = ts;
    arrayHistTitle[0]  = title;
    arrayHistText[0]   = chatDisplayText;

    UpdateHistoryGrid();
    msgCountOnLoad = msgCount;  // mark current state as saved
}

function LoadHistoryItem(idx) {
    if (idx < 0 || idx >= histCount) {
        return;
    }
    sessId = arrayHistChatId[idx];   // real DB ChatSessionId
    currentSessionId = sessId;
    SQL_ReloadSessionMessages(sessId);   // rebuild msgRole/msgContent arrays
    SQL_LoadSessionSummary(sessId);     // restore auto-summary context
    msgCountOnLoad = msgCount;
    sessionMsgsSinceSummary = 0;
    sessionToksSinceSummary = 0;

    // Restore Knowledge Base association
    kbRes = SQL_GetSessionKnowledgeBase(sessId);
    if (Size(kbRes) > 1) {
        kbRow = kbRes[1];
        currentKBId   = int(kbRow[0]);
        currentKBName = kbRow[1];
    } else {
        currentKBId = 0; currentKBName = "";
    }
    KB_UpdateStatusBar();

    // Rebuild chat display from reloaded messages
    ClearChatMessages();
    ResetChatSearch();
    for (hi = 0; hi < msgCount; hi++) {
        oneRole    = msgRole[hi];
        oneContent = msgContent[hi];
        if (oneRole == "user") {
            oneRole = "Vi";
        } elif (oneRole == "assistant") {
            oneRole = "AI";
        }
        AppendChatMessage(oneRole, oneContent);
    }
    SetStatus("Nastavljam razgovor od " + arrayHistDate[idx] + ".");
}

function UpdateHistoryGrid() {
    if (histCount > 0) {
        histActive = histCount;
        DisplayArray("datagridHistory", "close");
        DisplayArraySetup("datagridHistory", counterFld: histLineCntr, activeElements: histActive, maxElements: histMax);
    }
}


// =============================================================
//  SETTINGS
// =============================================================

function LoadSettings() {
    try {
        if (!Exists(settingsFilePath)) {
            return;
        }
        lines = ReadFile(settingsFilePath);
        for (i = 0; i < Size(lines); i++) {
            line = lines[i].Trim();
            if (line == "") {
                continue;
            }
            pipeIdx = line.IndexOf("|");
            if (pipeIdx < 0) {
                continue;
            }
            key = Substring(line, 0, pipeIdx).Trim();
            val = Substring(line, pipeIdx + 1, line.length - pipeIdx - 1).Trim();

            if (key == "provider") {
                aiProvider = val;
            } elif (key == "apikey") {
                aiApiKey = val;
            } elif (key == "baseurl") {
                aiBaseUrl = val;
            } elif (key == "model") {
                aiModel = val;
            } elif (key == "systemprompt") {
                aiSystemPrompt = val.Replace("\\n", "\n");
            } elif (key == "temperature") {
                aiTemperatureStr = val;
            } elif (key == "maxtokens") {
                aiMaxTokensStr = val;
            } elif (key == "websearchapikey") {
                webSearchApiKey = val;
            } elif (key == "websearchenabled") {
                if(val == "true" || val == "True" || val == "1") {
                    webSearchEnabled = true;
                } else {
                    webSearchEnabled = false;
                }
            } elif (key == "sttprovider") {
                sttProvider = val;
            } elif (key == "sttapikey") {
                sttApiKey = val;
            } elif (key == "sttbaseurl") {
                sttBaseUrl = val;
            } elif (key == "sttlanguage") {
                sttLanguage = val;
            } elif (key == "embeddingmodel") {
                embeddingModel = val;
            } elif (key == "embeddingauto") {
                if(val == "true" || val == "True" || val == "1") {
                    embeddingAutoEnabled = true;
                } else {
                    embeddingAutoEnabled = false;
                }
            }
        }
    } catch (ex) {
        // File may not exist on first run – ignore
    }
}

function SaveSettings() {
    // All variables are kept in sync by DataContext bindings – read them directly.

    sysEscaped = aiSystemPrompt.Replace("\n", "\\n");

    content  = "provider|"     + aiProvider      + "\n";
    content  = content + "apikey|"       + aiApiKey        + "\n";
    content  = content + "baseurl|"      + aiBaseUrl       + "\n";
    content  = content + "model|"        + aiModel         + "\n";
    content  = content + "systemprompt|" + sysEscaped      + "\n";
    content  = content + "temperature|"  + aiTemperatureStr + "\n";
    content  = content + "maxtokens|"        + aiMaxTokensStr                     + "\n";
    content  = content + "websearchapikey|"   + webSearchApiKey                    + "\n";
    webSearchEnabledVal = webSearchEnabled ? "1" : "0";
    content  = content + "websearchenabled|"  + webSearchEnabledVal                + "\n";
    content  = content + "sttprovider|"  + sttProvider + "\n";
    content  = content + "sttapikey|"    + sttApiKey   + "\n";
    content  = content + "sttbaseurl|"   + sttBaseUrl  + "\n";
    content  = content + "sttlanguage|"  + sttLanguage + "\n";
    content  = content + "embeddingmodel|"    + embeddingModel          + "\n";
    embeddingAutoVal = embeddingAutoEnabled ? "1" : "0";
    content  = content + "embeddingauto|"     + embeddingAutoVal        + "\n";

    try {
        SaveFile(content, settingsFilePath, "");
    } catch (ex) {
        MessageBox("Greška pri spremanju postavki:\n" + ex);
    }
}


