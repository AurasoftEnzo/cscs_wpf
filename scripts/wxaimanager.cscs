function SetUIBusy(busy) {
    isWaiting = busy;
    if (busy) {
        SetWidgetOptions("btnSend",     "IsEnabled", "false");
        SetWidgetOptions("btnSend",     "Content",   "Čekam...");
        SetWidgetOptions("btnNewChat",  "IsEnabled", "false");
        Cursor("wait");
    } else {
        SetWidgetOptions("btnSend",     "IsEnabled", "true");
        SetWidgetOptions("btnSend",     "Content",   "Pošalji");
        SetWidgetOptions("btnNewChat",  "IsEnabled", "true");
        Cursor("dflt");
    }
}

function SetStatus(msg) {
    SetWidgetOptions("lblStatus", "Content", msg);
}

function UpdateProviderLabel() {
    SetWidgetOptions("lblProviderInfo", "Content", aiProvider + " / " + aiModel);
}

function UpdateBaseUrlForProvider() {
    prov = aiProvider;
    if (prov == "OpenAI") {
        SetWidgetOptions("txtBaseUrl", "Text", "https://api.openai.com/v1");
        aiBaseUrl = "https://api.openai.com/v1";
    } elif (prov == "Ollama") {
        SetWidgetOptions("txtBaseUrl", "Text", "http://localhost:11434/v1");
        aiBaseUrl = "http://localhost:11434/v1";
    } elif (prov == "OpenRouter") 
    {
        SetWidgetOptions("txtBaseUrl", "Text", "https://openrouter.ai/api/v1");
        aiBaseUrl = "https://openrouter.ai/api/v1";
    }
}
