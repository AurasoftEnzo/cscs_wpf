<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wcl="clr-namespace:WpfControlsLibrary;assembly=WpfControlsLibrary"
        xmlns:local="clr-namespace:WpfCSCS"
        mc:Ignorable="d"
        Title="AI Manager"
        Height="780"
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Name="wxaimanagerWindow"
        Background="#1A2535">

    <Window.Resources>

        <!-- Flat rounded button -->
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark TextBox style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"    Value="#1E2F3D"/>
            <Setter Property="Foreground"    Value="#D0D8E4"/>
            <Setter Property="CaretBrush"    Value="White"/>
            <Setter Property="BorderBrush"   Value="#3D5066"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="6,4"/>
            <Setter Property="FontFamily"    Value="Segoe UI"/>
            <Setter Property="FontSize"      Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Section heading (orange accent) -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E67E22"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <!-- Small muted label -->
        <Style x:Key="MutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="11.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Dark ComboBox with custom template (no theme resource references) -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="#1E2F3D"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#3D5066"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12.5"/>
            <Setter Property="Height"      Value="28"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background"     Value="#1E2F3D"/>
                        <Setter Property="Foreground"     Value="White"/>
                        <Setter Property="BorderBrush"    Value="#3D5066"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="templateRoot" SnapsToDevicePixels="True">
                            <!-- Main border – dark in ALL states -->
                            <Border x:Name="border"
                                    Background="#1E2F3D"
                                    BorderBrush="#3D5066"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Selected content -->
                                    <ContentPresenter x:Name="contentPresenter"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      Margin="{TemplateBinding Padding}"
                                                      TextElement.Foreground="White"
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    <!-- Dropdown arrow toggle -->
                                    <ToggleButton x:Name="toggleButton"
                                                  Grid.Column="1"
                                                  Width="22"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press"
                                                  Focusable="False"
                                                  IsTabStop="False"
                                                  Cursor="Hand"
                                                  Background="Transparent"
                                                  BorderThickness="1,0,0,0"
                                                  BorderBrush="#3D5066">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Grid Background="Transparent">
                                                    <TextBlock x:Name="arrow"
                                                               Text="&#x25BC;"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="7"
                                                               Margin="0,1,0,0"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <!-- Dropdown popup -->
                            <Popup x:Name="popup"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide"
                                   Focusable="False"
                                   StaysOpen="False"
                                   HorizontalOffset="0"
                                   VerticalOffset="2">
                                <Border x:Name="dropDownBorder"
                                        Background="#1E2F3D"
                                        BorderBrush="#3D5066"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer x:Name="scrollViewer"
                                                  Padding="1"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter x:Name="itemsPresenter"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Blue border when focused or dropdown open -->
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#569DE5"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                                    <Condition Property="IsDropDownOpen" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="BorderBrush" Value="#569DE5"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Override system highlight colors so ComboBox dropdown items
             use dark selection instead of default pale blue. -->
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                         Color="#2C3E50"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                         Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                         Color="#3D5066"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                         Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                         Color="#1E2F3D"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"
                         Color="White"/>

    </Window.Resources>

    <!-- ================================================================
         Root grid: 3 rows
           0 – Toolbar
           1 – Content (sidebar + chat area; settings panel overlaid inside)
           2 – Status bar
         ================================================================ -->
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Toolbar       -->
            <RowDefinition Height="*"/>      <!-- Content       -->
            <RowDefinition Height="Auto"/>   <!-- Status bar    -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             ROW 0 – Toolbar
             ============================================================ -->
        <Border Grid.Row="0"
                Background="#263646"
                CornerRadius="8"
                Padding="12,8"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>    <!-- Provider/Model -->
                    <ColumnDefinition Width="*"/>       <!-- Title          -->
                </Grid.ColumnDefinitions>

                <!-- Provider and Model selectors -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Provider:" Style="{StaticResource MutedLabel}" Margin="0,0,6,0"/>
                    <ComboBox Name="cbProvider"
                              DataContext="aiProvider"
                              Width="130"
                              Margin="0,0,14,0"
                              VerticalAlignment="Center"/>

                    <TextBlock Text="Model:" Style="{StaticResource MutedLabel}" Margin="0,0,6,0"/>
                    <TextBox Name="txtModel"
                             DataContext="aiModel"
                             Style="{StaticResource DarkTextBox}"
                             Width="180"
                             Margin="0,0,0,0"
                             ToolTip="Unesite naziv modela (npr. gpt-4o-mini, llama3, ...)"/>
                </StackPanel>

                <!-- Title -->
                <TextBlock Grid.Column="1"
                           Text="AI Manager"
                           Foreground="White"
                           FontFamily="Segoe UI"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

            </Grid>
        </Border>

        <!-- ============================================================
             ROW 1 – Content: sidebar + chat
             ============================================================ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>    <!-- Sidebar       -->
                <ColumnDefinition Width="8"/>      <!-- Spacer        -->
                <ColumnDefinition Width="*"/>      <!-- Chat          -->
                <ColumnDefinition Width="8"/>      <!-- Spacer        -->
                <ColumnDefinition Width="120"/>    <!-- Action panel  -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar: history -->
            <Border Grid.Column="0"
                    Background="#263646"
                    CornerRadius="8"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Header     -->
                        <RowDefinition Height="Auto"/>   <!-- Search bar -->
                        <RowDefinition Height="*"/>      <!-- DataGrid   -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Prošli razgovori"
                               Style="{StaticResource SectionHeader}"
                               Margin="2,2,0,6"/>

                    <!-- History search bar -->
                    <Grid Grid.Row="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="txtHistSearch"
                                 Grid.Column="0"
                                 Background="#1E2F3D"
                                 Foreground="#D0D8E4"
                                 CaretBrush="White"
                                 BorderBrush="#3D5066"
                                 BorderThickness="1"
                                 Padding="6,3"
                                 Height="24"
                                 FontFamily="Segoe UI"
                                 FontSize="11.5"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Pretraži sve sesije u bazi"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="3,0,0,0">
                            <Button Name="btnHistSearch"
                                    Content="&#x1F50D;"
                                    Style="{StaticResource FlatBtn}"
                                    Background="#2980B9"
                                    Width="26" Height="24"
                                    FontFamily="Segoe UI Emoji"
                                    FontSize="12"
                                    Padding="0"
                                    Margin="0,0,2,0"
                                    ToolTip="Traži u svim sesijama"/>
                            <Button Name="btnHistSearchClear"
                                    Content="&#x2715;"
                                    Style="{StaticResource FlatBtn}"
                                    Background="#555F6A"
                                    Width="22" Height="24"
                                    FontSize="10"
                                    Padding="0"
                                    ToolTip="Poništi pretragu – vrati puni popis"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid Grid.Row="2"
                              Name="datagridHistory"
                              Background="Transparent"
                              IsReadOnly="True"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              RowHeight="26"
                              FontSize="11.5"
                              FontFamily="Segoe UI"
                              Foreground="#C8D0DA"
                              RowBackground="#1E2F3D"
                              AlternatingRowBackground="#243444"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2D4057"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              CanUserSortColumns="False"
                              SelectionMode="Single"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background"   Value="#1A2535"/>
                                <Setter Property="Foreground"   Value="#E67E22"/>
                                <Setter Property="FontWeight"   Value="SemiBold"/>
                                <Setter Property="FontSize"     Value="11"/>
                                <Setter Property="Padding"      Value="4,4"/>
                                <Setter Property="BorderBrush"  Value="#2D4057"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Datum" Width="68">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <wcl:ASGridCell FieldName="arrayHistDate"
                                                        Editor="edDefault"
                                                        EditLength="0"
                                                        IsReadOnly="True"
                                                        HorizontalContentAlignment="Left" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Razgovor" Width="*" MinWidth="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <wcl:ASGridCell FieldName="arrayHistTitle"
                                                        Editor="edDefault"
                                                        EditLength="0"
                                                        IsReadOnly="True"
                                                        HorizontalContentAlignment="Left" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Main chat area -->
            <Border Grid.Column="2"
                    Background="#263646"
                    CornerRadius="8"
                    Padding="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Search bar   -->
                        <RowDefinition Height="*"/>      <!-- Chat display -->
                        <RowDefinition Height="Auto"/>   <!-- Input area   -->
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <Border Grid.Row="0"
                            Background="#1E2F3D"
                            Padding="6,5"
                            BorderBrush="#2D4057"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Name="txtChatSearch"
                                     Grid.Column="0"
                                     Background="#263646"
                                     Foreground="#D0D8E4"
                                     CaretBrush="White"
                                     BorderBrush="#3D5066"
                                     BorderThickness="1"
                                     Padding="8,3"
                                     Height="26"
                                     FontFamily="Segoe UI"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Pretraži razgovor (tipkajte i kliknite 🔍)"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="5,0,0,0" VerticalAlignment="Center">
                                <Button Name="btnChatSearch"
                                        Content="&#x1F50D;"
                                        Style="{StaticResource FlatBtn}"
                                        Background="#2980B9"
                                        Width="28" Height="26"
                                        FontFamily="Segoe UI Emoji"
                                        FontSize="13"
                                        Padding="0"
                                        Margin="0,0,3,0"
                                        ToolTip="Traži"/>
                                <Button Name="btnChatSearchPrev"
                                        Content="&#x25B2;"
                                        Style="{StaticResource FlatBtn}"
                                        Background="#4A6A85"
                                        Width="24" Height="26"
                                        FontSize="10"
                                        Padding="0"
                                        Margin="0,0,2,0"
                                        ToolTip="Prethodni rezultat"/>
                                <Button Name="btnChatSearchNext"
                                        Content="&#x25BC;"
                                        Style="{StaticResource FlatBtn}"
                                        Background="#4A6A85"
                                        Width="24" Height="26"
                                        FontSize="10"
                                        Padding="0"
                                        Margin="0,0,5,0"
                                        ToolTip="Sljedeći rezultat"/>
                                <TextBlock Name="lblSearchCount"
                                           Foreground="#8A9BAB"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           MinWidth="38"
                                           Margin="0,0,4,0"/>
                                <Button Name="btnChatSearchClear"
                                        Content="&#x2715;"
                                        Style="{StaticResource FlatBtn}"
                                        Background="#555F6A"
                                        Width="24" Height="26"
                                        FontSize="10"
                                        Padding="0"
                                        ToolTip="Poništi pretragu"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Chat transcript — scrollable panel of message bubbles -->
                    <ScrollViewer Grid.Row="1"
                                  Name="chatScrollViewer"
                                  Background="#1A2535"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalAlignment="Stretch"
                                  PanningMode="VerticalOnly">
                        <StackPanel Name="chatPanel"
                                    Background="#1A2535"/>
                    </ScrollViewer>

                    <!-- Input area -->
                    <Border Grid.Row="2"
                            Background="#1E2F3D"
                            CornerRadius="0,0,7,7"
                            Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0"
                                         Name="txtInput"
                                         DataContext="userInput"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="62"
                                         MaxHeight="130"
                                         Background="#263646"
                                         Foreground="White"
                                         CaretBrush="White"
                                         BorderBrush="#3D5066"
                                         BorderThickness="1"
                                         Padding="10,8"
                                         FontFamily="Segoe UI"
                                         FontSize="13"
                                         VerticalScrollBarVisibility="Auto"
                                         ToolTip="Unesite poruku i pritisnite Pošalji (ili Ctrl+Enter)"/>

                                <CheckBox Grid.Row="1"
                                          Name="cbWebSearch"
                                          DataContext="webSearchEnabled"
                                          Content="Koristi web pretraživanje"
                                          Foreground="#7F8C8D"
                                          FontFamily="Segoe UI"
                                          FontSize="11"
                                          Margin="4,5,0,2"
                                          VerticalAlignment="Center"/>
                            </Grid>

                            <StackPanel Grid.Column="1"
                                        Orientation="Vertical"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Bottom">
                                <Button Name="btnSend"
                                        Content="Pošalji"
                                        Style="{StaticResource FlatBtn}"
                                        Background="#E67E22"
                                        Width="90"
                                        Height="38"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Margin="0,0,0,6"/>
                                <Button Name="btnAbort"
                                        Content="Prekini"
                                        Style="{StaticResource FlatBtn}"
                                        Background="#555F6A"
                                        Width="90"
                                        Height="22"
                                        FontSize="9"
                                        IsEnabled="False"/>
                                <Button Name="btnVoice"
                                        Content="&#x1F3A4;"
                                        Style="{StaticResource FlatBtn}"
                                        Background="#276A5C"
                                        Width="90"
                                        Height="26"
                                        FontSize="14"
                                        FontFamily="Segoe UI Emoji"
                                        Margin="0,6,0,0"
                                        ToolTip="Kliknite za početak / zaustavljanje snimanja glasa (STT)"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

            <!-- Right action panel -->
            <Border Grid.Column="4"
                    Background="#263646"
                    CornerRadius="8"
                    Padding="8,10">
                <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                    <Button Name="btnNewChat"
                            Content="Novi razgovor"
                            Style="{StaticResource FlatBtn}"
                            Background="#27AE60"
                            Width="104"
                            Height="34"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Center"/>
                    <Button Name="btnSettings"
                            Content="Postavke"
                            Style="{StaticResource FlatBtn}"
                            Background="#2980B9"
                            Width="104"
                            Height="34"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Center"/>
                    <Button Name="btnClearChat"
                            Content="Obriši"
                            Style="{StaticResource FlatBtn}"
                            Background="#C0392B"
                            Width="104"
                            Height="34"
                            HorizontalAlignment="Center"/>
                    <Button Name="btnKnowledgeBase"
                            Content="Baza znanja"
                            Style="{StaticResource FlatBtn}"
                            Background="#1ABC9C"
                            Width="104"
                            Height="34"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Center"
                            ToolTip="Upravljaj bazama znanja (Knowledge Base)"/>
                    <Button Name="btnAddAttachment"
                            Content="Prilog"
                            Style="{StaticResource FlatBtn}"
                            Background="#8E44AD"
                            Width="104"
                            Height="34"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"/>
                    <Button Name="btnImportFolder"
                            Content="Uvezi mapu"
                            Style="{StaticResource FlatBtn}"
                            Background="#6C3483"
                            Width="104"
                            Height="34"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Knowledge Base panel: overlay (same pattern as Settings) -->
            <Border Grid.Column="0"
                    Grid.ColumnSpan="5"
                    Panel.ZIndex="10"
                    VerticalAlignment="Top"
                    Name="panelKnowledgeBase"
                    Background="#304D65"
                    CornerRadius="8"
                    Padding="14,12"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Baze znanja (Knowledge Base)"
                               Foreground="#E67E22"
                               FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <Button Name="btnKBNew"
                                Content="+ Nova baza"
                                Style="{StaticResource FlatBtn}"
                                Background="#27AE60"
                                Width="110" Height="30"
                                FontSize="11"
                                Margin="0,0,6,0"/>
                        <Button Name="btnKBUpload"
                                Content="+ Dodaj dokument"
                                Style="{StaticResource FlatBtn}"
                                Background="#2980B9"
                                Width="130" Height="30"
                                FontSize="11"
                                Margin="0,0,6,0"/>
                        <Button Name="btnKBRefresh"
                                Content="&#x21BB;"
                                Style="{StaticResource FlatBtn}"
                                Background="#4A6A85"
                                Width="30" Height="30"
                                FontSize="14"
                                Margin="0,0,6,0"
                                ToolTip="Osvježi popis"/>
                        <Button Name="btnKBClose"
                                Content="&#x2715;"
                                Style="{StaticResource FlatBtn}"
                                Background="#555F6A"
                                Width="30" Height="30"
                                FontSize="12"
                                ToolTip="Zatvori"/>
                    </StackPanel>

                    <!-- KB list + detail side by side -->
                    <Grid Grid.Row="1" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="380"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: KB list -->
                        <Border Grid.Column="0" Background="#263646" CornerRadius="6" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Moje baze znanja"
                                           Foreground="#7F8C8D"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Padding="8,6"/>
                                <DataGrid Grid.Row="1" Name="datagridKB"
                                          Background="Transparent"
                                          IsReadOnly="True"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          BorderThickness="0"
                                          RowHeight="28"
                                          FontSize="11.5"
                                          FontFamily="Segoe UI"
                                          Foreground="#C8D0DA"
                                          RowBackground="#1E2F3D"
                                          AlternatingRowBackground="#243444"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#2D4057"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          CanUserResizeColumns="True"
                                          SelectionMode="Single"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Resources>
                                        <Style TargetType="{x:Type DataGridColumnHeader}">
                                            <Setter Property="Background" Value="#1A2535"/>
                                            <Setter Property="Foreground" Value="#E67E22"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="BorderBrush" Value="#2D4057"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Naziv" Width="*" MinWidth="160">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <wcl:ASGridCell FieldName="kbListName"
                                                                    Editor="edDefault"
                                                                    EditLength="0"
                                                                    IsReadOnly="True"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Dok." Width="48" MinWidth="40">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <wcl:ASGridCell FieldName="kbListDocCount"
                                                                    Editor="edDefault"
                                                                    EditLength="0"
                                                                    IsReadOnly="True"
                                                                    HorizontalContentAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Ažurirano" Width="90" MinWidth="70">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <wcl:ASGridCell FieldName="kbListDate"
                                                                    Editor="edDefault"
                                                                    EditLength="0"
                                                                    IsReadOnly="True"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- Right: selected KB detail / doc list -->
                        <Border Grid.Column="2" Background="#263646" CornerRadius="6" Padding="8,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Name="lblKBDetailTitle"
                                           Text="Odaberi bazu znanja s lijeve strane"
                                           Foreground="#7F8C8D"
                                           FontFamily="Segoe UI" FontSize="11"
                                           TextWrapping="Wrap"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,6">
                                    <Button Name="btnKBSelect"
                                            Content="Koristi ovu bazu za sesiju"
                                            Style="{StaticResource FlatBtn}"
                                            Background="#1ABC9C"
                                            Height="28" FontSize="11"
                                            Margin="0,0,6,0"
                                            Padding="8,2"/>
                                    <Button Name="btnKBDelete"
                                            Content="Obriši bazu"
                                            Style="{StaticResource FlatBtn}"
                                            Background="#C0392B"
                                            Height="28" FontSize="11"
                                            Padding="8,2"/>
                                    <Button Name="btnKBRemoveDoc"
                                            Content="Ukloni dokument"
                                            Style="{StaticResource FlatBtn}"
                                            Background="#E67E22"
                                            Height="28" FontSize="11"
                                            Margin="6,0,0,0"
                                            Padding="8,2"/>
                                </StackPanel>
                                <!-- Document list for selected KB -->
                                <DataGrid Grid.Row="2" Name="datagridKBDocs"
                                          Background="Transparent"
                                          IsReadOnly="True"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          BorderThickness="0"
                                          RowHeight="24"
                                          FontSize="11"
                                          FontFamily="Segoe UI"
                                          Foreground="#C8D0DA"
                                          RowBackground="#1E2F3D"
                                          AlternatingRowBackground="#243444"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#2D4057"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          CanUserResizeColumns="True"
                                          SelectionMode="Single"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Resources>
                                        <Style TargetType="{x:Type DataGridColumnHeader}">
                                            <Setter Property="Background" Value="#1A2535"/>
                                            <Setter Property="Foreground" Value="#E67E22"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="BorderBrush" Value="#2D4057"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Dokument" Width="*" MinWidth="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <wcl:ASGridCell FieldName="kbDocListTitle"
                                                                    Editor="edDefault"
                                                                    EditLength="0"
                                                                    IsReadOnly="True"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Veličina" Width="70" MinWidth="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <wcl:ASGridCell FieldName="kbDocListSize"
                                                                    Editor="edDefault"
                                                                    EditLength="0"
                                                                    IsReadOnly="True"
                                                                    HorizontalContentAlignment="Right"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Status" Width="80" MinWidth="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <wcl:ASGridCell FieldName="kbDocListStatus"
                                                                    Editor="edDefault"
                                                                    EditLength="0"
                                                                    IsReadOnly="True"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <!-- Web import row -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,2">
                                    <TextBox Name="txtWebUrl"
                                             Width="260" Height="26"
                                             Background="#1E2F3D"
                                             Foreground="#C8D0DA"
                                             BorderBrush="#2D4057"
                                             FontFamily="Segoe UI"
                                             FontSize="11"
                                             VerticalContentAlignment="Center"
                                             Padding="6,0"
                                             ToolTip="Unesite URL web stranice za uvoz u bazu znanja"/>
                                    <Button Name="btnKBWebImport"
                                            Content="Uvezi web"
                                            Style="{StaticResource FlatBtn}"
                                            Background="#8E44AD"
                                            Height="26" FontSize="11"
                                            Margin="6,0,0,0"
                                            Padding="8,2"/>
                                </StackPanel>
                                <!-- Status bar inside KB panel -->
                                <TextBlock Grid.Row="4" Name="lblKBStatus"
                                           Foreground="#7F8C8D"
                                           FontFamily="Segoe UI" FontSize="10"
                                           Margin="0,2,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Settings panel: overlay at top of content row, spanning all columns.
                 Because it shares Row 1 (*) with the sidebar and chat area it never
                 creates a blank gap below them – datagridHistory and txtChat always
                 fill the available height regardless of settings visibility. -->
            <Border Grid.Column="0"
                    Grid.ColumnSpan="5"
                    Panel.ZIndex="10"
                    VerticalAlignment="Top"
                    Name="panelSettings"
                    Background="#304D65"
                    CornerRadius="8"
                    Padding="14,12"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 0: API Key + Base URL + Temperature -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="API Ključ:" Style="{StaticResource SectionHeader}"/>
                        <TextBox Name="txtApiKey"
                                 DataContext="aiApiKey"
                                 Style="{StaticResource DarkTextBox}"
                                 Margin="0,0,0,10"
                                 ToolTip="Vaš OpenAI / OpenRouter / Azure API ključ. Ostavite prazno za Ollama."/>

                        <TextBlock Text="Base URL:" Style="{StaticResource SectionHeader}"/>
                        <TextBox Name="txtBaseUrl"
                                 DataContext="aiBaseUrl"
                                 Style="{StaticResource DarkTextBox}"
                                 Margin="0,0,0,10"
                                 ToolTip="Npr. https://api.openai.com/v1  ili  http://localhost:11434/v1"/>

                        <TextBlock Text="Temperature (0.0 – 2.0):" Style="{StaticResource SectionHeader}"/>
                        <TextBox Name="txtTemperature"
                                 DataContext="aiTemperatureStr"
                                 Style="{StaticResource DarkTextBox}"
                                 Width="80"
                                 HorizontalAlignment="Left"
                                 ToolTip="Vrijednosti: 0.0 = deterministički, 1.0 = uravnoteženo, 2.0 = kreativno"/>

                        <TextBlock Text="Max Tokens:" Style="{StaticResource SectionHeader}" Margin="0,10,0,5"/>
                        <TextBox Name="txtMaxTokens"
                                 DataContext="aiMaxTokensStr"
                                 Style="{StaticResource DarkTextBox}"
                                 Width="80"
                                 HorizontalAlignment="Left"
                                 ToolTip="Maksimalan broj tokena u odgovoru (npr. 2000, 4096)"/>

                        <TextBlock Text="Tavily API ključ (web pretraživanje):" Style="{StaticResource SectionHeader}" Margin="0,10,0,5"/>
                        <TextBox Name="txtWebSearchApiKey"
                                 DataContext="webSearchApiKey"
                                 Style="{StaticResource DarkTextBox}"
                                 ToolTip="Besplatni API ključ za Tavily web pretraživanje. Registracija na: tavily.com"/>

                        <Separator Margin="0,12,0,8" Background="#3D5D75"/>
                        <TextBlock Text="Govorni unos (STT):" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Provider (Whisper API / Windows STT):" Style="{StaticResource SectionHeader}"/>
                        <TextBox Name="txtSttProvider"
                                 DataContext="sttProvider"
                                 Style="{StaticResource DarkTextBox}"
                                 Margin="0,0,0,6"
                                 ToolTip="Whisper API  (cloud, preporučeno)  ili  Windows STT  (offline)"/>
                        <TextBlock Text="STT API ključ (prazno = koristi AI API ključ):" Style="{StaticResource SectionHeader}"/>
                        <TextBox Name="txtSttApiKey"
                                 DataContext="sttApiKey"
                                 Style="{StaticResource DarkTextBox}"
                                 Margin="0,0,0,6"
                                 ToolTip="Ostavite prazno za korištenje AI API ključa za Whisper"/>
                        <TextBlock Text="STT Base URL (prazno = koristi AI Base URL):" Style="{StaticResource SectionHeader}"/>
                        <TextBox Name="txtSttBaseUrl"
                                 DataContext="sttBaseUrl"
                                 Style="{StaticResource DarkTextBox}"
                                 Margin="0,0,0,6"
                                 ToolTip="Npr. https://api.openai.com/v1 – Ostavite prazno za korištenje AI Base URL"/>
                        <TextBlock Text="Jezik prepoznavanja (hr, en, de, fr...):" Style="{StaticResource SectionHeader}"/>
                        <TextBox Name="txtSttLanguage"
                                 DataContext="sttLanguage"
                                 Style="{StaticResource DarkTextBox}"
                                 Width="60"
                                 HorizontalAlignment="Left"
                                 ToolTip="BCP-47 jezična oznaka: hr = Hrvatski, en = Engleski, de = Njemački"/>
                    </StackPanel>

                    <!-- Column 2: System Prompt -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Sistemski prompt (System Prompt):" Style="{StaticResource SectionHeader}"/>
                        <TextBox Name="txtSystemPrompt"
                                 DataContext="aiSystemPrompt"
                                 Style="{StaticResource DarkTextBox}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Height="130"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 ToolTip="Uputa AI-u o načinu odgovaranja. Npr: You are a helpful assistant."/>

                        <TextBlock Margin="0,10,0,4"
                                   Foreground="#7F8C8D"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   TextWrapping="Wrap">
                            Primjeri modela: gpt-4o-mini · gpt-4o · gpt-3.5-turbo (OpenAI)&#x0a;llama3 · mistral · codellama (Ollama)&#x0a;meta-llama/... · anthropic/... (OpenRouter)
                        </TextBlock>
                    </StackPanel>

                    <!-- Column 4: Save + Cancel buttons -->
                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                        <Button Name="btnSaveSettings"
                                Content="Spremi postavke"
                                Style="{StaticResource FlatBtn}"
                                Background="#27AE60"
                                Width="140"
                                Height="44"
                                FontSize="13"
                                Margin="0,0,0,10"/>
                        <Button Name="btnCancelSettings"
                                Content="Odustani"
                                Style="{StaticResource FlatBtn}"
                                Background="#555F6A"
                                Width="140"
                                Height="36"
                                FontSize="12"/>
                    </StackPanel>

                    <!-- Row 1: Token usage statistics for current provider -->
                    <Border Grid.Row="1" Grid.ColumnSpan="5"
                            Margin="0,12,0,0"
                            Background="#22384D"
                            CornerRadius="6"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Header: "Tokeni (PROVIDER)" -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Tokeni  (" Foreground="#7F8C8D"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <wcl:ASEnterBox FieldName="aiProvider"
                                               ButtonSize="0"
                                               Foreground="#BDC3C7"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Height="18"
                                               Width="80"
                                               Background="Transparent"
                                               BorderBrush="Transparent"
                                               VerticalAlignment="Center"
                                               IsReadOnly="True"
                                               IsTabStop="False"
                                               Focusable="False"/>
                                <TextBlock Text="):" Foreground="#7F8C8D"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Input tokens -->
                            <Border Grid.Column="2" Background="#1E2F3D"
                                    CornerRadius="5" Padding="12,5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Ulazni: " Foreground="#7F8C8D"
                                               FontFamily="Segoe UI" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <wcl:ASEnterBox FieldName="statInputTokens"
                                                   ButtonSize="0"
                                                   Foreground="#27AE60"
                                                   FontFamily="Segoe UI"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Height="20"
                                                   Width="70"
                                                   Background="#1E2F3D"
                                                   BorderBrush="Transparent"
                                                   VerticalAlignment="Center"
                                                   IsReadOnly="True"
                                                   IsTabStop="False"
                                                   Focusable="False"/>
                                </StackPanel>
                            </Border>

                            <!-- Output tokens -->
                            <Border Grid.Column="4" Background="#1E2F3D"
                                    CornerRadius="5" Padding="12,5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Izlazni: " Foreground="#7F8C8D"
                                               FontFamily="Segoe UI" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <wcl:ASEnterBox FieldName="statOutputTokens"
                                                   ButtonSize="0"
                                                   Foreground="#E67E22"
                                                   FontFamily="Segoe UI"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Height="20"
                                                   Width="70"
                                                   Background="#1E2F3D"
                                                   BorderBrush="Transparent"
                                                   VerticalAlignment="Center"
                                                   IsReadOnly="True"
                                                   IsTabStop="False"
                                                   Focusable="False"/>
                                </StackPanel>
                            </Border>

                            <!-- Total tokens -->
                            <Border Grid.Column="6" Background="#1E2F3D"
                                    CornerRadius="5" Padding="12,5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Ukupno: " Foreground="#7F8C8D"
                                               FontFamily="Segoe UI" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <wcl:ASEnterBox FieldName="statTotalTokens"
                                                   ButtonSize="0"
                                                   Foreground="#3498DB"
                                                   FontFamily="Segoe UI"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Height="20"
                                                   Width="70"
                                                   Background="#1E2F3D"
                                                   BorderBrush="Transparent"
                                                   VerticalAlignment="Center"
                                                   IsReadOnly="True"
                                                   IsTabStop="False"
                                                   Focusable="False"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

        </Grid>

        <!-- ============================================================
             ROW 2 – Status bar
             ============================================================ -->
        <Border Grid.Row="2"
                Background="#263646"
                CornerRadius="8"
                Padding="12,5"
                Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0"
                       Name="lblStatus"
                       Content="Inicijalizacija..."
                       Foreground="#C8D0DA"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       Padding="0"/>

                <TextBlock Grid.Column="1"
                           Name="lblRagStatus"
                           Text="RAG: -"
                           Foreground="#7F8C8D"
                           FontFamily="Segoe UI"
                           FontSize="11.5"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>

                <Button Grid.Column="2"
                        Name="btnStopRAG"
                        Content="⏹"
                        Width="22" Height="20"
                        FontSize="10"
                        Padding="0"
                        Margin="0,0,10,0"
                        ToolTip="Zaustavi RAG servis"
                        VerticalAlignment="Center"/>

                <TextBlock Grid.Column="3"
                           Name="lblKBStatusBar"
                           Text="KB: -"
                           Foreground="#7F8C8D"
                           FontFamily="Segoe UI"
                           FontSize="11.5"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0"/>

                <TextBlock Grid.Column="4"
                           Name="lblProviderInfo"
                           Text="- / -"
                           Foreground="#7F8C8D"
                           FontFamily="Segoe UI"
                           FontSize="11.5"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
