// ============================================================
//  WXAIMANAGER_EMBEDDINGS.CSCS
//  Vector embedding generation and RAG search for AI Manager
//
//  Included by wxaimanager.cscs via:
//    include(DownloadScripts() == true
//        ? Download(ServerAddress() + "wxaimanager_embeddings.cscs")
//        : strTrim(tpath()) + "wxaimanager_embeddings.cscs");
//
//  Tables used:
//    dbo.ChatChunk  – embedding columns added in Phase 1
//
//  Workflow:
//    1. ProcessAIResponse() → AsyncCall → Embedding_ProcessPendingSession()
//    2. Embedding_ProcessPendingSession() reads pending ChatChunks,
//       calls Embedding_Generate() for each, updates rows.
//    3. Embedding_SearchSimilar() is used in SendToAI() for RAG (Phase 3).
//
//  API support:
//    - OpenAI:      POST {baseUrl}/embeddings, model="text-embedding-3-small"
//    - Ollama:      POST {baseUrl}/embeddings, model="nomic-embed-text"
//    - OpenRouter:  POST {baseUrl}/embeddings, various models
// ============================================================

// ---- Embedding settings (saved with other settings) ---------
DEFINE embeddingModel type a size 100;   // embedding model name
DEFINE embeddingAutoEnabled type l;             // auto-embed after each message

// ---- RAG service state (shared with wxaimanager.cscs) -------
DEFINE ragServiceActive type l;             // true = servis radi u zasebnom procesu
DEFINE ragServicePid type r;             // Process ID servisa (0 = nije aktivan)
DEFINE ragLastHeartbeat type a size 50;     // ISO vrijeme zadnjeg heartbeata
DEFINE ragServiceStatus type a size 20;     // running / stopped / local


// =============================================================
//  INITIALIZATION
//  Called from wxaimanager_OnStart() after SQL init.
//  Also fires background processing of any pending chunks.
// =============================================================

function InitEmbeddings() {
    embeddingModel       = "text-embedding-3-small";
    embeddingAutoEnabled = true;
    ragServiceActive     = false;
    ragServicePid        = 0;
    ragLastHeartbeat     = "";
    ragServiceStatus     = "local";

//msg ("Initializing embeddings with model: " + embeddingModel + ", auto-embed: " + embeddingAutoEnabled + ", RAG service active: " + ragServiceActive);
    // Pokušaj pokrenuti RAG servis u zasebnom procesu (CHAIN)
    RAG_TryStartService();

//msg ("RAG service active: " + ragServiceActive);
    if (ragServiceActive) {
        // Servis radi u zasebnom procesu – embedding generira on
//  msg ("RAG service is active in separate process. Embeddings will be generated by the service.");      
        RAG_UpdateStatusBar();
        SetStatus("RAG servis aktivan (zaseban proces).");
    } else {
        // Fallback: lokalna obrada preko AsyncCall
        RAG_UpdateStatusBar();
        SetStatus("RAG obrada: lokalno (servis nije dostupan).");
        AsyncCall("Embedding_ProcessPendingAll", "Embedding_ProcessDone", 0);
    }
}


// =============================================================
//  RAG SERVICE MANAGEMENT
// =============================================================

// ------------------------------------------------------------
//  RAG_TryStartService()
//  Pokušava pokrenuti ragservice.cscs u zasebnom procesu
//  pomoću CHAIN NEWRUNTIME. Ako uspije, provjerava heartbeat.
//  Ako ne uspije, postavlja ragServiceActive = false i
//  nastavlja s lokalnom obradom.
// ------------------------------------------------------------
function RAG_TryStartService() {
    serviceScript = strTrim(tpath()) + "ragservice.cscs";

    if (!Exists(serviceScript)) {
        return;     // servis skripta ne postoji → lokalno
    }

    try {
        // Pokreni servis u zasebnom WpfCSCS procesu

        ragServicePid = CHAIN serviceScript NEWRUNTIME WITH WXAI_DB aiBaseUrl aiApiKey embeddingModel;

        // Čekaj da servis upiše prvi heartbeat (max 5 sekundi)
        for (wi = 0; wi < 10; wi++) {
            Sleep(500);
            if (RAG_CheckHeartbeat()) {
                ragServiceActive = true;
                return;
            }
        }

        // Heartbeat nije stigao – servis možda nije uspio
        ragServicePid = 0;
        MSG("RAG_TryStartService: CHAIN uspio, ali heartbeat nije pronađen.");

    } catch (ex) {
        // CHAIN nije uspio (npr. ne postoji ragservice.cscs)
        ragServicePid = 0;
        MSG("RAG_TryStartService: CHAIN nije uspio – " + ex);
    }
}

// ------------------------------------------------------------
//  RAG_CheckHeartbeat()
//  Čita RAGServiceStatus tablicu. Ako heartbeat postoji i
//  status je 'running', servis je aktivan.
//  Postavlja ragServiceStatus i vraća true/false.
// ------------------------------------------------------------
function RAG_CheckHeartbeat() {
    if (!chatSqlEnabled) {
        return false;
    }

    try {
        hbSql = "SELECT Status, LastHeartbeatUtc, PendingCount, EmbeddedCount, FailedCount "
              + "FROM " + WXAI_DB + ".dbo.RAGServiceStatus "
              + "WHERE ServiceId = 'rag-main' AND Status = 'running'";

        hbRes = sqlQuery(hbSql);

        if (Size(hbRes) > 1) {
            hbRow            = hbRes[1];
            ragServiceStatus = hbRow[0];     // 'running'
            ragLastHeartbeat = hbRow[1];     // LastHeartbeatUtc
            return true;
        }
    } catch (ex) {
        MSG("RAG_CheckHeartbeat error: " + ex);
    }

    ragServiceActive = false;
    return false;
}

// ------------------------------------------------------------
//  RAG_StopService()
//  Zaustavlja RAG servis (zasebni proces) pomoću Kill(pid).
//  Postavlja ragServiceActive = false i ažurira status bar.
// ------------------------------------------------------------
function RAG_StopService() {
    if (ragServiceActive && ragServicePid > 0) {
        try {
            Kill(ragServicePid);
        } catch (ex) {
            MSG("RAG_StopService: Kill nije uspio – " + ex);
        }
        ragServiceActive = false;
        ragServicePid    = 0;
        ragServiceStatus = "stopped";
        RAG_UpdateStatusBar();
        SetStatus("RAG servis zaustavljen.");
    }
}

// ------------------------------------------------------------
//  RAG_UpdateStatusBar()
//  Ažurira lblRagStatus u status baru.
//  Boje:
//    "RAG: Servis (čeka:X ✓:Y ✗:Z)" – zeleno
//    "RAG: Lokalno"                   – narančasto
// ------------------------------------------------------------
function RAG_UpdateStatusBar() {
    if (ragServiceActive) {
        // Čitaj statuse iz heartbeata za prikaz brojki
        try {
            hbSql = "SELECT PendingCount, EmbeddedCount, FailedCount "
                  + "FROM " + WXAI_DB + ".dbo.RAGServiceStatus "
                  + "WHERE ServiceId = 'rag-main' AND Status = 'running'";
            hbRes = sqlQuery(hbSql);
      // msg ("RAG_UpdateStatusBar: Heartbeat query executed, rows: " + (Size(hbRes) - 1));     
            if (Size(hbRes) > 1) {
                hbRow = hbRes[1];
                pS = int(hbRow[0]);
                eS = int(hbRow[1]);
                fS = int(hbRow[2]);
           //msg ("RAG_UpdateStatusBar: Heartbeat stats - pending: " + pS + ", embedded: " + eS + ", failed: " + fS);     
                SetWidgetOptions("lblRagStatus", "Content",
                    "RAG: Servis (čeka:" + pS + " ✓:" + eS + " ✗:" + fS + ")");
            //msg ("RAG_UpdateStatusBar: Status bar updated with heartbeat stats.");        
                //SetWidgetOptions("lblRagStatus", "Foreground", "#27AE60");
                return;
            }
        } catch (ex) { }
    //msg ("RAG_UpdateStatusBar: RAG servis aktivan, ali nije moguće dohvatiti heartbeat stats – " + ex);    
        SetWidgetOptions("lblRagStatus", "Content", "RAG: Servis");
        SetWidgetOptions("lblRagStatus", "Color", "#27AE60");

    } else {
        // Lokalna obrada – prikaži kratke info iz Embedding_GetStats
        statTxt = "RAG: Lokalno";
        if (currentSessionId > 0) {
            localStats = Embedding_GetStats(currentSessionId);
            if (localStats != "") {
                statTxt = "RAG: Lokalno (" + localStats + ")";
            }
        }
        SetWidgetOptions("lblRagStatus", "Content", statTxt);
        SetWidgetOptions("lblRagStatus", "Color", "#E67E22");
    }
}


// =============================================================
//  Embedding_Generate(text)
//  Calls the /embeddings API endpoint synchronously.
//  Returns a CSCS list of floats on success, or an empty list
//  on failure. Supports both OpenAI and Ollama response formats.
//
//  OpenAI format:  { "data": [{ "embedding": [0.xxx, ...] }] }
//  Ollama format:  { "embeddings": [[0.xxx, ...]] }
// =============================================================

function Embedding_Generate(text) {
    emptyResult = {};

    if (aiBaseUrl == "" || text == "") {
        return emptyResult;
    }

    // Build endpoint URL: POST {baseUrl}/embeddings
    embEndpoint = aiBaseUrl;
    if (!embEndpoint.EndsWith("/")) {
        embEndpoint = embEndpoint + "/";
    }
    embEndpoint = embEndpoint + "embeddings";

    // Build JSON payload
    embPayload = '{"model":"' + embeddingModel + '","input":"' + EscapeForJson(text) + '"}';

    embHeaders = {};
    if (aiApiKey != "") {
        embHeaders["Authorization"] = "Bearer " + aiApiKey;
    }

    try {
        rawResult = WebRequest2("POST", embEndpoint, embPayload, "", "", "",
                                "application/json", embHeaders, 30000, false);

        if (rawResult == "") {
            return emptyResult;
        }

        rObj = DeserializeJson(rawResult);

        // Check for API error
        if (Contains(rObj, "error")) {
            errObj = rObj["error"];
            if (Contains(errObj, "message")) {
                MSG("Embedding_Generate API error: " + errObj["message"]);
            }
            return emptyResult;
        }

        // --- Parse OpenAI format: data[0].embedding ---
        if (Contains(rObj, "data")) {
            dataArr = rObj["data"];
            if (Size(dataArr) > 0) {
                firstData = dataArr[0];
                if (Contains(firstData, "embedding")) {
                    return firstData["embedding"];   // CSCS list of floats
                }
            }
        }

        // --- Parse Ollama format: embeddings[0] ---
        if (Contains(rObj, "embeddings")) {
            embArr = rObj["embeddings"];
            if (Size(embArr) > 0) {
                return embArr[0];   // CSCS list of floats
            }
        }

        return emptyResult;

    } catch (ex) {
        MSG("Embedding_Generate error: " + ex);
        return emptyResult;
    }
}


// =============================================================
//  Embedding_VectorToJson(vecList)
//  Converts a CSCS list of floats to a JSON string array.
//  Example: [0.001, 0.002, 0.003]  →  "[0.001,0.002,0.003]"
// =============================================================

function Embedding_VectorToJson(vecList) {
    result = "[";
    vecSize = Size(vecList);
    for (vi = 0; vi < vecSize; vi++) {
        if (vi > 0) { result = result + ","; }
        result = result + vecList[vi];
    }
    result = result + "]";
    return result;
}


// =============================================================
//  Embedding_ProcessPendingSession(sessId)
//  Reads all pending ChatChunks for one session, generates
//  embeddings, and updates each row.
//
//  Status transitions:
//    'pending'  →  'embedded'   (on success)
//    'pending'  →  'failed'     (on API error)
//    'pending'  →  'skipped'    (empty text)
//
//  Called via AsyncCall from ProcessAIResponse().
// =============================================================

function Embedding_ProcessPendingSession(sessId) {
    if (!chatSqlEnabled || sessId == 0) {
        return;
    }

    try {
        qp = {};
        qp.Add({"@sid", sessId});

        selSql = "SELECT ChatChunkId, ChunkText "
               + "FROM " + WXAI_DB + ".dbo.ChatChunk "
               + "WHERE ChatSessionId = @sid AND EmbeddingStatus = 'pending' "
               + "ORDER BY ChunkOrder ASC";

        pendingRes = sqlQuery(selSql, qp);
        pendingCnt = Size(pendingRes) - 1;

        if (pendingCnt == 0) {
            return;
        }

        for (pi = 0; pi < pendingCnt; pi++) {
            pRow     = pendingRes[pi + 1];
            chunkId  = int(pRow[0]);
            chunkTxt = pRow[1];

            // Empty text → skip
            if (chunkTxt == "") {
                try {
                    up = {};
                    up.Add({"@id", chunkId});
                    sqlNonQuery("UPDATE " + WXAI_DB + ".dbo.ChatChunk "
                              + "SET EmbeddingStatus = 'skipped' "
                              + "WHERE ChatChunkId = @id", up);
                } catch (ex2) {
                    MSG("Embedding_ProcessPendingSession skip error: " + ex2);
                }
                continue;
            }

            // ---- Check for cached embedding (same hash, already embedded) ----
            cacheParams = {};
            cacheParams.Add({"@txt", chunkTxt});
            cacheParams.Add({"@id",  chunkId});
            cacheSql = "SELECT TOP 1 EmbeddingVectorJson, EmbeddingModel, TokenCount "
                     + "FROM " + WXAI_DB + ".dbo.ChatChunk "
                     + "WHERE ChunkHash = CONVERT(VARCHAR(64), "
                     + "    HASHBYTES('SHA2_256', CONVERT(NVARCHAR(MAX), @txt)), 2) "
                     + "  AND EmbeddingStatus = 'embedded' "
                     + "  AND EmbeddingVectorJson IS NOT NULL "
                     + "  AND ChatChunkId != @id "
                     + "ORDER BY EmbeddedAtUtc DESC";
            cacheRes = sqlQuery(cacheSql, cacheParams);

            if (Size(cacheRes) > 1) {
                // Cached embedding found — copy it, skip API call
                cacheRow    = cacheRes[1];
                cachedVec   = cacheRow[0];
                cachedModel = cacheRow[1];
                cachedToks  = int(cacheRow[2]);
                try {
                    upCache = {};
                    upCache.Add({"@id",    chunkId});
                    upCache.Add({"@vec",   cachedVec});
                    upCache.Add({"@model", cachedModel});
                    upCache.Add({"@tok",   cachedToks});
                    sqlNonQuery("UPDATE " + WXAI_DB + ".dbo.ChatChunk "
                              + "SET EmbeddingVectorJson = @vec, "
                              + "    EmbeddingStatus = 'embedded', "
                              + "    EmbeddingModel = @model, "
                              + "    VectorStore = 'sql-json', "
                              + "    TokenCount = @tok, "
                              + "    ChunkHash = CONVERT(VARCHAR(64), "
                              + "        HASHBYTES('SHA2_256', CONVERT(NVARCHAR(MAX), ChunkText)), 2), "
                              + "    EmbeddedAtUtc = SYSUTCDATETIME() "
                              + "WHERE ChatChunkId = @id", upCache);
                } catch (exCache) {
                    MSG("Embedding_ProcessPendingSession cache copy error: " + exCache);
                }
                continue;   // skip API call
            }

            // ---- Generate embedding via API ----
            vecList = Embedding_Generate(chunkTxt);
            vecSize = Size(vecList);

            if (vecSize == 0) {
                // API error → mark as failed (will retry on next restart)
                try {
                    up2 = {};
                    up2.Add({"@id", chunkId});
                    sqlNonQuery("UPDATE " + WXAI_DB + ".dbo.ChatChunk "
                              + "SET EmbeddingStatus = 'failed' "
                              + "WHERE ChatChunkId = @id", up2);
                } catch (ex3) {
                    MSG("Embedding_ProcessPendingSession fail error: " + ex3);
                }
                continue;
            }

            // ---- Success: serialize and persist ----
            tokenEst = int(chunkTxt.length / 4) + 1;   // rough token estimate
            vecJson  = Embedding_VectorToJson(vecList);

            try {
                up3 = {};
                up3.Add({"@id",      chunkId});
                up3.Add({"@vecJson", vecJson});
                up3.Add({"@model",   embeddingModel});
                up3.Add({"@tok",     tokenEst});

                sqlNonQuery("UPDATE " + WXAI_DB + ".dbo.ChatChunk "
                          + "SET EmbeddingVectorJson = @vecJson, "
                          + "    EmbeddingStatus = 'embedded', "
                          + "    EmbeddingModel = @model, "
                          + "    VectorStore = 'sql-json', "
                          + "    TokenCount = @tok, "
                          + "    ChunkHash = CONVERT(VARCHAR(64), "
                          + "        HASHBYTES('SHA2_256', CONVERT(NVARCHAR(MAX), ChunkText)), 2), "
                          + "    EmbeddedAtUtc = SYSUTCDATETIME() "
                          + "WHERE ChatChunkId = @id", up3);
            } catch (ex4) {
                MSG("Embedding_ProcessPendingSession update error: " + ex4);
            }
        }

    } catch (ex) {
        MSG("Embedding_ProcessPendingSession error: " + ex);
    }
}


// =============================================================
//  Embedding_ProcessPendingAll()
//  Processes ALL pending ChatChunks across all sessions.
//  Called once at startup to catch up on any chunks that were
//  left pending (e.g. from a previous session where the
//  background task didn't complete).
// =============================================================

function Embedding_ProcessPendingAll() {
    if (!chatSqlEnabled) {
        return;
    }

    try {
        selSql = "SELECT DISTINCT ChatSessionId "
               + "FROM " + WXAI_DB + ".dbo.ChatChunk "
               + "WHERE EmbeddingStatus = 'pending' "
               + "ORDER BY ChatSessionId ASC";

        sessRes = sqlQuery(selSql);
        sessCnt = Size(sessRes) - 1;

        if (sessCnt == 0) {
            return;
        }

        for (si = 0; si < sessCnt; si++) {
            oneSessId = int(sessRes[si + 1][0]);
            Embedding_ProcessPendingSession(oneSessId);
        }

    } catch (ex) {
        MSG("Embedding_ProcessPendingAll error: " + ex);
    }
}


// =============================================================
//  AsyncCall callback (no-op)
// =============================================================

function Embedding_ProcessDone(sender, result) {
    // Embeddings processed in background – update status bar
    try {
        RAG_UpdateStatusBar();
    } catch (ex) {
        // Silently ignore – status bar update is non-critical
    }
}


// =============================================================
//  Embedding_SearchSimilar(query, topN, sessId)
//  Performs semantic search over embedded chat chunks.
//
//  1. Generates an embedding vector for the query text.
//  2. Loads all 'embedded' chunks for the given session.
//  3. Computes cosine similarity between query vector and each
//     stored vector using the C# CosineSimilarity function.
//  4. Returns the top-N most relevant chunks as formatted text
//     that can be prepended to the AI prompt (RAG context).
//
//  Parameters:
//    query  – user's input text
//    topN   – number of most relevant chunks to return
//    sessId – ChatSessionId (0 = skip, no context)
//
//  Returns: Formatted string or "" if no relevant chunks found.
// =============================================================

function Embedding_SearchSimilar(query, topN, sessId) {
    if (!chatSqlEnabled || sessId == 0 || query == "") {
        return "";
    }

    // 1. Generate query embedding
    queryVec = Embedding_Generate(query);
    vecDim = Size(queryVec);
    if (vecDim == 0) {
        return "";
    }

    // 2. Load all embedded chunks for this session
    try {
        qp = {};
        qp.Add({"@sid", sessId});

        selSql = "SELECT ChunkText, EmbeddingVectorJson, ChunkOrder "
               + "FROM " + WXAI_DB + ".dbo.ChatChunk "
               + "WHERE ChatSessionId = @sid "
               + "  AND EmbeddingStatus = 'embedded' "
               + "  AND EmbeddingVectorJson IS NOT NULL "
               + "ORDER BY ChunkOrder ASC";

        chunksRes = sqlQuery(selSql, qp);
        chunksCnt = Size(chunksRes) - 1;

        if (chunksCnt == 0) {
            return "";
        }

        // 3. Compute similarity for each chunk
        // Use parallel arrays: scores[], texts[] (index 0 = first chunk)
        // We can't use dynamic arrays easily in CSCS, so we use fixed-size with a count
        MAX_CANDIDATES = 200;
        scores = {};
        texts  = {};
        orders = {};
        matchCnt = 0;

        for (ci = 0; ci < chunksCnt; ci++) {
            cRow     = chunksRes[ci + 1];
            cText    = cRow[0];
            cVecJson = cRow[1];
            cOrder   = int(cRow[2]);

            // Parse stored JSON vector back to list
            storedVec = DeserializeJson(cVecJson);

            // Quick sanity: dimension must match
            if (Size(storedVec) != vecDim) {
                continue;
            }

            // Compute cosine similarity (C# function)
            simScore = CosineSimilarity(queryVec, storedVec);

            // Keep only scores above threshold (ignore very low similarity)
            if (simScore < 0.15) {
                continue;
            }

            // Store in arrays
            if (matchCnt < MAX_CANDIDATES) {
                scores.Add(simScore);
                texts.Add(cText);
                orders.Add(cOrder);
                matchCnt++;
            }
        }

        if (matchCnt == 0) {
            return "";
        }

        // 4. Select top-N by simple selection sort on scores
        // Build result indices
        resultCnt = topN;
        if (resultCnt > matchCnt) {
            resultCnt = matchCnt;
        }

        // Copy scores to a working array and find top indices
        // Use a simple approach: mark used indices
        used = {};
        resultText = "--- Relevantno iz povijesti razgovora (semantički) ---\n";

        for (ri = 0; ri < resultCnt; ri++) {
            bestIdx  = -1;
            bestScore = -1;

            for (ci = 0; ci < matchCnt; ci++) {
                // Skip already selected
                isUsed = false;
                for (ui = 0; ui < Size(used); ui++) {
                    if (used[ui] == ci) {
                        isUsed = true;
                        break;
                    }
                }
                if (isUsed) { continue; }

                if (scores[ci] > bestScore) {
                    bestScore = scores[ci];
                    bestIdx   = ci;
                }
            }

            if (bestIdx >= 0) {
                used.Add(bestIdx);
                resultText = resultText + "[" + orders[bestIdx] + "] " + texts[bestIdx] + "\n\n";
            }
        }

        resultText = resultText + "---\n";
        return resultText;

    } catch (ex) {
        MSG("Embedding_SearchSimilar error: " + ex);
        return "";
    }
}


// =============================================================
//  Embedding_GetStats(sessId)
//  Returns a formatted string with embedding stats for display.
// =============================================================

function Embedding_GetStats(sessId) {
    if (!chatSqlEnabled || sessId == 0) {
        return "";
    }

    try {
        qp = {};
        qp.Add({"@sid", sessId});

        statsSql = "SELECT "
                 + "  COUNT(*) AS Total, "
                 + "  SUM(CASE WHEN EmbeddingStatus = 'embedded' THEN 1 ELSE 0 END) AS Embedded, "
                 + "  SUM(CASE WHEN EmbeddingStatus = 'pending'  THEN 1 ELSE 0 END) AS Pending, "
                 + "  SUM(CASE WHEN EmbeddingStatus = 'failed'   THEN 1 ELSE 0 END) AS Failed "
                 + "FROM " + WXAI_DB + ".dbo.ChatChunk "
                 + "WHERE ChatSessionId = @sid";

        statsRes = sqlQuery(statsSql, qp);
        if (Size(statsRes) > 1) {
            sRow = statsRes[1];
            return "Embedding: " + sRow[1] + "/" + sRow[0]
                 + " gotovo, " + sRow[2] + " čeka, " + sRow[3] + " grešaka";
        }
    } catch (ex) {
        MSG("Embedding_GetStats error: " + ex);
    }
    return "";
}


// =============================================================
//  Embedding_SearchSimilarAcrossKb(query, topN, kbId)
//  Performs semantic search over embedded DocumentChunks for
//  a given Knowledge Base. Returns formatted context text.
//  Falls back to ChatChunk search if kbId is 0.
// =============================================================

function Embedding_SearchSimilarAcrossKb(query, topN, kbId) {
    if (!chatSqlEnabled || kbId == 0 || query == "") {
        return "";
    }

    queryVec = Embedding_Generate(query);
    vecDim = Size(queryVec);
    if (vecDim == 0) { return ""; }

    try {
        qp = {};
        qp.Add({"@kb", kbId});

        selSql = "SELECT c.ChunkText, c.EmbeddingVectorJson, c.ChunkOrder, d.Title "
               + "FROM " + WXAI_DB + ".dbo.DocumentChunk c "
               + "JOIN " + WXAI_DB + ".dbo.Document d ON c.DocumentId = d.DocumentId "
               + "WHERE d.KnowledgeBaseId = @kb "
               + "  AND c.EmbeddingStatus = 'embedded' "
               + "  AND c.EmbeddingVectorJson IS NOT NULL "
               + "ORDER BY c.DocumentId, c.ChunkOrder";

        chunksRes = sqlQuery(selSql, qp);
        chunksCnt = Size(chunksRes) - 1;
        if (chunksCnt == 0) { return ""; }

        MAX_CANDIDATES = 500;
        scores = {}; texts = {}; titles = {};
        matchCnt = 0;

        for (ci = 0; ci < chunksCnt; ci++) {
            cRow     = chunksRes[ci + 1];
            cText    = cRow[0];
            cVecJson = cRow[1];
            cOrder   = int(cRow[2]);
            cTitle   = cRow[3];

            storedVec = DeserializeJson(cVecJson);
            if (Size(storedVec) != vecDim) { continue; }

            simScore = CosineSimilarity(queryVec, storedVec);
            if (simScore < 0.15) { continue; }

            if (matchCnt < MAX_CANDIDATES) {
                scores.Add(simScore);
                texts.Add(cText);
                titles.Add(cTitle);
                matchCnt++;
            }
        }

        if (matchCnt == 0) { return ""; }

        resultCnt = topN;
        if (resultCnt > matchCnt) { resultCnt = matchCnt; }

        used = {};
        resultText = "--- Relevantno iz baze znanja (semantički) ---\n";

        for (ri = 0; ri < resultCnt; ri++) {
            bestIdx = -1; bestScore = -1;
            for (ci = 0; ci < matchCnt; ci++) {
                isUsed = false;
                for (ui = 0; ui < Size(used); ui++) {
                    if (used[ui] == ci) { isUsed = true; break; }
                }
                if (isUsed) { continue; }
                if (scores[ci] > bestScore) { bestScore = scores[ci]; bestIdx = ci; }
            }
            if (bestIdx >= 0) {
                used.Add(bestIdx);
                srcInfo = "";
                if (titles[bestIdx] != "") { srcInfo = " [" + titles[bestIdx] + "]"; }
                resultText = resultText + srcInfo + "\n" + texts[bestIdx] + "\n\n";
            }
        }
        resultText = resultText + "---\n";
        return resultText;

    } catch (ex) {
        MSG("Embedding_SearchSimilarAcrossKb error: " + ex);
        return "";
    }
}


// =============================================================
//  Embedding_ProcessPendingDocumentChunks(kbId)
//  Processes ALL pending DocumentChunks for a Knowledge Base.
//  Can be called with kbId=0 to process all pending doc chunks.
// =============================================================

function Embedding_ProcessPendingDocumentChunks(kbId) {
    if (!chatSqlEnabled) { return; }

    try {
        qp = {};
        whereClause = "";
        if (kbId > 0) {
            qp.Add({"@kb", kbId});
            whereClause = " AND d.KnowledgeBaseId = @kb";
        }

        selSql = "SELECT c.DocumentChunkId, c.ChunkText, c.DocumentId "
               + "FROM " + WXAI_DB + ".dbo.DocumentChunk c "
               + "JOIN " + WXAI_DB + ".dbo.Document d ON c.DocumentId = d.DocumentId "
               + "WHERE c.EmbeddingStatus = 'pending'" + whereClause + " "
               + "ORDER BY c.DocumentId, c.ChunkOrder";

        pendingRes = sqlQuery(selSql, qp);
        pendingCnt = Size(pendingRes) - 1;
        if (pendingCnt == 0) { return; }

        for (pi = 0; pi < pendingCnt; pi++) {
            pRow     = pendingRes[pi + 1];
            chunkId  = int(pRow[0]);
            chunkTxt = pRow[1];
            docId    = int(pRow[2]);

            if (chunkTxt == "") {
                try {
                    up = {}; up.Add({"@id", chunkId});
                    sqlNonQuery("UPDATE " + WXAI_DB + ".dbo.DocumentChunk "
                              + "SET EmbeddingStatus = 'skipped' WHERE DocumentChunkId = @id", up);
                } catch (ex2) { MSG("Embedding_ProcessPendingDocumentChunks skip error: " + ex2); }
                continue;
            }

            // ---- Check for cached embedding (same hash) ----
            cacheParams = {};
            cacheParams.Add({"@txt", chunkTxt});
            cacheParams.Add({"@id",  chunkId});
            cacheSql = "SELECT TOP 1 EmbeddingVectorJson, EmbeddingModel "
                     + "FROM " + WXAI_DB + ".dbo.DocumentChunk "
                     + "WHERE ChunkHash = CONVERT(VARCHAR(64), "
                     + "    HASHBYTES('SHA2_256', CONVERT(NVARCHAR(MAX), @txt)), 2) "
                     + "  AND EmbeddingStatus = 'embedded' "
                     + "  AND EmbeddingVectorJson IS NOT NULL "
                     + "  AND DocumentChunkId != @id "
                     + "ORDER BY EmbeddedAtUtc DESC";
            cacheRes = sqlQuery(cacheSql, cacheParams);

            if (Size(cacheRes) > 1) {
                cacheRow    = cacheRes[1];
                cachedVec   = cacheRow[0];
                cachedModel = cacheRow[1];
                try {
                    upCache = {};
                    upCache.Add({"@id", chunkId});
                    upCache.Add({"@vec", cachedVec});
                    upCache.Add({"@model", cachedModel});
                    sqlNonQuery("UPDATE " + WXAI_DB + ".dbo.DocumentChunk "
                              + "SET EmbeddingVectorJson = @vec, "
                              + "    EmbeddingStatus = 'embedded', "
                              + "    EmbeddingModel = @model, "
                              + "    VectorStore = 'sql-json', "
                              + "    ChunkHash = CONVERT(VARCHAR(64), "
                              + "        HASHBYTES('SHA2_256', CONVERT(NVARCHAR(MAX), ChunkText)), 2), "
                              + "    EmbeddedAtUtc = SYSUTCDATETIME() "
                              + "WHERE DocumentChunkId = @id", upCache);
                } catch (exCache) { MSG("Embedding_ProcessPendingDocumentChunks cache error: " + exCache); }
                continue;
            }

            // ---- Generate embedding via API ----
            vecList = Embedding_Generate(chunkTxt);
            vecSize = Size(vecList);

            if (vecSize == 0) {
                try {
                    up2 = {}; up2.Add({"@id", chunkId});
                    sqlNonQuery("UPDATE " + WXAI_DB + ".dbo.DocumentChunk "
                              + "SET EmbeddingStatus = 'failed' WHERE DocumentChunkId = @id", up2);
                } catch (ex3) { MSG("Embedding_ProcessPendingDocumentChunks fail error: " + ex3); }
                continue;
            }

            tokenEst = int(chunkTxt.length / 4) + 1;
            vecJson  = Embedding_VectorToJson(vecList);

            try {
                up3 = {};
                up3.Add({"@id",      chunkId});
                up3.Add({"@vecJson", vecJson});
                up3.Add({"@model",   embeddingModel});
                up3.Add({"@tok",     tokenEst});
                sqlNonQuery("UPDATE " + WXAI_DB + ".dbo.DocumentChunk "
                          + "SET EmbeddingVectorJson = @vecJson, "
                          + "    EmbeddingStatus = 'embedded', "
                          + "    EmbeddingModel = @model, "
                          + "    VectorStore = 'sql-json', "
                          + "    TokenCount = @tok, "
                          + "    ChunkHash = CONVERT(VARCHAR(64), "
                          + "        HASHBYTES('SHA2_256', CONVERT(NVARCHAR(MAX), ChunkText)), 2), "
                          + "    EmbeddedAtUtc = SYSUTCDATETIME() "
                          + "WHERE DocumentChunkId = @id", up3);
            } catch (ex4) { MSG("Embedding_ProcessPendingDocumentChunks update error: " + ex4); }
        }
    } catch (ex) {
        MSG("Embedding_ProcessPendingDocumentChunks error: " + ex);
    }
}
