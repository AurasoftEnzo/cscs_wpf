    // A4
    SetWidgetOptions("lblA4_og", "Content", kpi_a4_og_str);
    SetWidgetOptions("lblA4_lg", "Content", lani_h + ": " + kpi_a4_lg_str);
    setTrendEllipse("EllipseA4", kpi_a4_trend);

    // A5
    SetWidgetOptions("lblA5_og", "Content", kpi_a5_og_str);
    SetWidgetOptions("lblA5_lg", "Content", lani_h + ": " + kpi_a5_lg_str);
    setTrendEllipse("EllipseA5", kpi_a5_trend);

    // A6
    SetWidgetOptions("lblA6_og", "Content", kpi_a6_og_str);
    SetWidgetOptions("lblA6_lg", "Content", lani_h + ": " + kpi_a6_lg_str);
    setTrendEllipse("EllipseA6", kpi_a6_trend);

    // A7
    SetWidgetOptions("lblA7_og", "Content", kpi_a7_og_str);
    SetWidgetOptions("lblA7_lg", "Content", lani_h + ": " + kpi_a7_lg_str);
    setTrendEllipse("EllipseA7", kpi_a7_trend);

    // A8
    SetWidgetOptions("lblA8_og", "Content", kpi_a8_og_str);
    SetWidgetOptions("lblA8_lg", "Content", lani_h + ": " + kpi_a8_lg_str);
    setTrendEllipse("EllipseA8", kpi_a8_trend);

    // A9
    SetWidgetOptions("lblA9_og", "Content", kpi_a9_og_str);
    SetWidgetOptions("lblA9_lg", "Content", lani_h + " → " + ovagod_h);
    setTrendEllipse("EllipseA9", kpi_a9_trend);

    // A10
    SetWidgetOptions("lblA10_og", "Content", kpi_a10_og_str);
    SetWidgetOptions("lblA10_lg", "Content", lani_h + ": " + kpi_a10_lg_str);
    setTrendEllipse("EllipseA10", kpi_a10_trend);
}

// trend: '+' = green, '-' = red, '=' = gray
function setTrendEllipse(ellipseName, trend)
{
    if (trend == "+")
    {
        SetWidgetOptions(ellipseName, "Color", "#27AE60");
    }
    elif (trend == "-")
    {
        SetWidgetOptions(ellipseName, "Color", "#E74C3C");
    }
    else
    {
        SetWidgetOptions(ellipseName, "Color", "#95A5A6");
    }
}

