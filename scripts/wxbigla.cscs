// displayKpiValues  (runs on main thread via RunOnMain)
// Sets all KPI label text values and trend ellipse colors
// -----------------------------------------------------------------------

function displayKpiValues()
{

    // A1
    SetWidgetOptions("lblA1_og", "Content", kpi_a1_og_str);
    SetWidgetOptions("lblA1_lg", "Content", lani_h + ": " + kpi_a1_lg_str);
    setTrendEllipse("EllipseA1", kpi_a1_trend);
    // A2
    SetWidgetOptions("lblA2_og", "Content", kpi_a2_og_str);
    SetWidgetOptions("lblA2_lg", "Content", lani_h + ": " + kpi_a2_lg_str);
    setTrendEllipse("EllipseA2", kpi_a2_trend);
    // A3
    SetWidgetOptions("lblA3_og", "Content", kpi_a3_og_str);
    SetWidgetOptions("lblA3_lg", "Content", lani_h + ": " + kpi_a3_lg_str);
