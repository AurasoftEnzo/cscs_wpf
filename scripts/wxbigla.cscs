// -----------------------------------------------------------------------
// gbPrihodi / gbRashodi - open monthly chart modal windows
// -----------------------------------------------------------------------

function gbPrihodi@clicked()
{
    if (pripremljeno)
    {
        result = modalWindow(strTrim(tpath()) + "wxbiglaa.xaml");
    }
    else
    {
        MessageBox("Molim pripremite osnovne podatke prije nastavka!");
        setFocus("gbPripremi");
    }
}

function gbRashodi@clicked()
{
    if (pripremljeno)
    {
        result = modalWindow(strTrim(tpath()) + "wxbiglab.xaml");
    }
    else
    {
        MessageBox("Molim pripremite osnovne podatke prije nastavka!");
        setFocus("gbPripremi");
    }
}

// -----------------------------------------------------------------------
// gbExit
// -----------------------------------------------------------------------

function gbExit@clicked(){
    // save_logs("I", userCode, WhoAmI());

    if(Size(args) > 2)
    {
        //comming from tas
        // quit;
        CloseWindow(strtrim(tpath()) + "wxbigla.xaml");
    }
    else
    {    
        //comming from mainmenu
        quit;
    }

    // CloseWindow(strtrim(tpath()) + "wxbigla.xaml");
    // quit();
}
