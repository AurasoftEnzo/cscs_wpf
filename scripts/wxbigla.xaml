<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wcl="clr-namespace:WpfControlsLibrary;assembly=WpfControlsLibrary"
        mc:Ignorable="d"
        Title="General Ledger Dashboard"
        Height="700"
        Width="1200"
        MinHeight="600"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#2C3E50"
        Name="wxbiglaWindow">

    <Window.Resources>
        <!-- Flat button style reused from WXBIMKA pattern -->
        <Style TargetType="Button" x:Key="FlatButtonStyle">
            <Setter Property="Background" Value="DarkCyan" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="wcl:ASEnterBox">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <!-- Transparent GroupBox overlay – double-click opens KPI drill-down -->
        <Style x:Key="DrillOverlayStyle" TargetType="GroupBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Panel.ZIndex" Value="10"/>
            <Setter Property="ToolTip" Value="Dvaput kliknite za detalje konta"/>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Fill">
        <!-- Outer grid: Col 0 = 160 px sidebar, Col 1 = content -->
        <Grid Width="1200" Height="700" Background="#2C3E50">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ================================================================
                 SIDEBAR  (Column 0)
                 ================================================================ -->
            <Grid Grid.Column="0" Background="#1A252F">
                <Grid.RowDefinitions>
                    <RowDefinition Height="110" />  <!-- Logo -->
                    <RowDefinition Height="*" />    <!-- Controls -->
                    <RowDefinition Height="Auto" /> <!-- Company name -->
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Image x:Name="Logo" Grid.Row="0" Margin="8,8,8,8" />

                <!-- Sidebar controls -->
                <StackPanel Grid.Row="1" Margin="8,4,8,0">

                    <!-- Year -->
                    <TextBlock Text="Poslovna godina" FontSize="11" Foreground="#BDC3C7"
                               FontFamily="Lato" Margin="0,6,0,1"/>
                    <wcl:ASEnterBox x:Name="edOvaGodina"
                                    FieldName="ovagod_h"
                                    Height="24" FontSize="13" FontWeight="Bold"
                                    Foreground="White" Background="#2C3E50"
                                    BorderBrush="#7F8C8D" IsReadOnly="True"
                                    IsTabStop="False" Focusable="False" />

                    <!-- Month Od -->
                    <TextBlock Text="Mj. od" FontSize="11" Foreground="#BDC3C7"
                               FontFamily="Lato" Margin="0,8,0,1"/>
                    <wcl:ASEnterBox x:Name="edMjesecOd"
                                    FieldName="mjesecOd"
                                    Size="2"
                                    Height="24" FontSize="13"
                                    Foreground="White" Background="#2C3E50"
                                    BorderBrush="#7F8C8D" />

                    <!-- Month Do -->
                    <TextBlock Text="Mj. do" FontSize="11" Foreground="#BDC3C7"
                               FontFamily="Lato" Margin="0,8,0,1"/>
                    <wcl:ASEnterBox x:Name="edMjesecDo"
                                    FieldName="mjesecDo"
                                    Size="2"
                                    Height="24" FontSize="13"
                                    Foreground="White" Background="#2C3E50"
                                    BorderBrush="#7F8C8D" />

                    <!-- Account Od -->
                    <TextBlock Text="Konto od" FontSize="11" Foreground="#BDC3C7"
                               FontFamily="Lato" Margin="0,8,0,1"/>
                    <wcl:ASEnterBox x:Name="edKontoOd"
                                    FieldName="konto_od"
                                    Size="15"
                                    Height="24" FontSize="12"
                                    Foreground="White" Background="#2C3E50"
                                    BorderBrush="#7F8C8D" />

                    <!-- Account Do -->
                    <TextBlock Text="Konto do" FontSize="11" Foreground="#BDC3C7"
                               FontFamily="Lato" Margin="0,8,0,1"/>
                    <wcl:ASEnterBox x:Name="edKontoDo"
                                    FieldName="konto_do"
                                    Size="15"
                                    Height="24" FontSize="12"
                                    Foreground="White" Background="#2C3E50"
                                    BorderBrush="#7F8C8D" />

                    <!-- Pripremi button -->
                    <Button x:Name="gbPripremi"
                            Content="Pripremi"
                            Style="{StaticResource FlatButtonStyle}"
                            Background="#E67E22"
                            Foreground="White"
                            FontFamily="Lato" FontSize="17"
                            Height="44" Margin="0,18,0,0"
                            TabIndex="1" />

                    <!-- Prihodi chart button -->
                    <Button x:Name="gbPrihodi"
                            Content="Prihodi"
                            Style="{StaticResource FlatButtonStyle}"
                            Background="#1A6B3C"
                            Foreground="White"
                            FontFamily="Lato" FontSize="17"
                            Height="40" Margin="0,10,0,0"
                            TabIndex="2" />

                    <!-- Rashodi chart button -->
                    <Button x:Name="gbRashodi"
                            Content="Rashodi"
                            Style="{StaticResource FlatButtonStyle}"
                            Background="#7B241C"
                            Foreground="White"
                            FontFamily="Lato" FontSize="17"
                            Height="40" Margin="0,6,0,0"
                            TabIndex="3" />

                    <!-- Dodatni pokazatelji button -->
                    <Button x:Name="gbDodatni"
                            Content="Dodatni"
                            Style="{StaticResource FlatButtonStyle}"
                            Background="#1B4F72"
                            Foreground="White"
                            FontFamily="Lato" FontSize="17"
                            Height="40" Margin="0,6,0,0"
                            TabIndex="4" />

                    <!-- Exit button -->
                    <Button x:Name="gbExit"
                            Content="Izlaz"
                            Style="{StaticResource FlatButtonStyle}"
                            Background="#AC3E31"
                            Foreground="White"
                            FontFamily="Lato" FontSize="17"
                            Height="40" Margin="0,10,0,0"
                            TabIndex="5" />
                </StackPanel>

                <!-- Company name at bottom of sidebar -->
                <TextBlock x:Name="CompName"
                           Grid.Row="2"
                           DataContext="NazivFirme"
                           Text="Naziv firme"
                           FontFamily="Lato" FontSize="11" FontWeight="Bold"
                           Foreground="#E74C3C"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="6,4,6,8" />
            </Grid>

            <!-- ================================================================
                 CONTENT AREA  (Column 1) — 5 rows × 2 cols of KPI cards
                 ================================================================ -->
            <Grid Grid.Column="1" Margin="10,8,10,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />   <!-- Header row -->
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Header label -->
                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                           Text="Financijski pokazatelji"
                           FontFamily="Lato" FontSize="16" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="6,0,0,0" />

                <!--
                     KPI card template (repeated 10 times)
                     Each card:  Rectangle background
                                 Code label  (A1, A2 …)
                                 Name label
                                 Trend Ellipse
                                 Large OG value label
                                 Small LG value label
                     -->

                <!-- A1  Gross Profit -->
                <Grid Grid.Row="1" Grid.Column="0" Margin="5,4,5,4">
                    <ToolTipService.ToolTip><ToolTip Content="Prihodi (Klasa 6) - Troškovi (Klasa 4)"/></ToolTipService.ToolTip>
                    <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                    <Grid Margin="10,8,10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="A1" FontSize="11" FontWeight="Bold"
                                       Foreground="#E67E22" FontFamily="Lato"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Bruto dobit" FontSize="12" Foreground="#BDC3C7"
                                       FontFamily="Lato" VerticalAlignment="Center" />
                            <Ellipse x:Name="EllipseA1" Width="12" Height="12"
                                     Fill="#95A5A6" Margin="6,0,0,0"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                        <Label x:Name="lblA1_og" Grid.Row="1"
                               Content="—"
                               FontFamily="Lato" FontSize="22" FontWeight="Bold"
                               Foreground="White"
                               HorizontalContentAlignment="Right"
                               VerticalContentAlignment="Center"
                               Padding="0" />
                        <Label x:Name="lblA1_lg" Grid.Row="2"
                               Content="—"
                               FontFamily="Lato" FontSize="11"
                               Foreground="#7F8C8D"
                               HorizontalContentAlignment="Right"
                               Padding="0" />
                        <TextBlock Grid.Row="3" Text="Preporučeno: &gt; 0"
                                   FontFamily="Lato" FontSize="10" Foreground="#2ECC71"
                                   HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                    </Grid>
                    <GroupBox x:Name="gbDrillA1" Style="{StaticResource DrillOverlayStyle}"/>
                </Grid>

                <!-- A2  Net Profit Margin -->
                <Grid Grid.Row="1" Grid.Column="1" Margin="5,4,5,4">
                    <ToolTipService.ToolTip><ToolTip Content="Neto dobit (Klasa 95) / Prihodi (Klasa 6) x 100"/></ToolTipService.ToolTip>
                    <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                    <Grid Margin="10,8,10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="A2" FontSize="11" FontWeight="Bold"
                                       Foreground="#E67E22" FontFamily="Lato"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Neto marža" FontSize="12" Foreground="#BDC3C7"
                                       FontFamily="Lato" VerticalAlignment="Center" />
                            <Ellipse x:Name="EllipseA2" Width="12" Height="12"
                                     Fill="#95A5A6" Margin="6,0,0,0"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                        <Label x:Name="lblA2_og" Grid.Row="1"
                               Content="—"
                               FontFamily="Lato" FontSize="22" FontWeight="Bold"
                               Foreground="White"
                               HorizontalContentAlignment="Right"
                               VerticalContentAlignment="Center"
                               Padding="0" />
                        <Label x:Name="lblA2_lg" Grid.Row="2"
                               Content="—"
                               FontFamily="Lato" FontSize="11"
                               Foreground="#7F8C8D"
                               HorizontalContentAlignment="Right"
                               Padding="0" />
                        <TextBlock Grid.Row="3" Text="Preporučeno: &gt; 5 %"
                                   FontFamily="Lato" FontSize="10" Foreground="#2ECC71"
                                   HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                    </Grid>
                    <GroupBox x:Name="gbDrillA2" Style="{StaticResource DrillOverlayStyle}"/>
                </Grid>

                <!-- A3  Current Ratio -->
                <Grid Grid.Row="2" Grid.Column="0" Margin="5,4,5,4">
                    <ToolTipService.ToolTip><ToolTip Content="Kratkotrajna imovina (Klasa 1) / Kratkoročne obveze (Klasa 2)"/></ToolTipService.ToolTip>
                    <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                    <Grid Margin="10,8,10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="A3" FontSize="11" FontWeight="Bold"
                                       Foreground="#E67E22" FontFamily="Lato"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Tekuća likvidnost" FontSize="12" Foreground="#BDC3C7"
                                       FontFamily="Lato" VerticalAlignment="Center" />
                            <Ellipse x:Name="EllipseA3" Width="12" Height="12"
                                     Fill="#95A5A6" Margin="6,0,0,0"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                        <Label x:Name="lblA3_og" Grid.Row="1"
                               Content="—"
                               FontFamily="Lato" FontSize="22" FontWeight="Bold"
                               Foreground="White"
                               HorizontalContentAlignment="Right"
                               VerticalContentAlignment="Center"
                               Padding="0" />
                        <Label x:Name="lblA3_lg" Grid.Row="2"
                               Content="—"
                               FontFamily="Lato" FontSize="11"
                               Foreground="#7F8C8D"
                               HorizontalContentAlignment="Right"
                               Padding="0" />
                        <TextBlock Grid.Row="3" Text="Preporučeno: &gt; 1.5"
                                   FontFamily="Lato" FontSize="10" Foreground="#2ECC71"
                                   HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                    </Grid>
                    <GroupBox x:Name="gbDrillA3" Style="{StaticResource DrillOverlayStyle}"/>
                </Grid>

                <!-- A4  Quick Ratio -->
                <Grid Grid.Row="2" Grid.Column="1" Margin="5,4,5,4">
                    <ToolTipService.ToolTip><ToolTip Content="(Klasa 1 - Zalihe) / Kratkoročne obveze (Klasa 2)"/></ToolTipService.ToolTip>
                    <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                    <Grid Margin="10,8,10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="A4" FontSize="11" FontWeight="Bold"
                                       Foreground="#E67E22" FontFamily="Lato"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Brza likvidnost" FontSize="12" Foreground="#BDC3C7"
                                       FontFamily="Lato" VerticalAlignment="Center" />
                            <Ellipse x:Name="EllipseA4" Width="12" Height="12"
                                     Fill="#95A5A6" Margin="6,0,0,0"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                        <Label x:Name="lblA4_og" Grid.Row="1"
                               Content="—"
                               FontFamily="Lato" FontSize="22" FontWeight="Bold"
                               Foreground="White"
                               HorizontalContentAlignment="Right"
                               VerticalContentAlignment="Center"
                               Padding="0" />
                        <Label x:Name="lblA4_lg" Grid.Row="2"
                               Content="—"
                               FontFamily="Lato" FontSize="11"
                               Foreground="#7F8C8D"
                               HorizontalContentAlignment="Right"
                               Padding="0" />
                        <TextBlock Grid.Row="3" Text="Preporučeno: &gt; 1.0"
                                   FontFamily="Lato" FontSize="10" Foreground="#2ECC71"
                                   HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>                    </Grid>
                    <GroupBox x:Name="gbDrillA4" Style="{StaticResource DrillOverlayStyle}"/>
                </Grid>

                <!-- A5  ROE -->
                <Grid Grid.Row="3" Grid.Column="0" Margin="5,4,5,4">
                    <ToolTipService.ToolTip><ToolTip Content="Neto dobit (Klasa 95) / Kapital (Klasa 3)"/></ToolTipService.ToolTip>
                    <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                    <Grid Margin="10,8,10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="A5" FontSize="11" FontWeight="Bold"
                                       Foreground="#E67E22" FontFamily="Lato"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Povrat na kapital (ROE)" FontSize="12" Foreground="#BDC3C7"
                                       FontFamily="Lato" VerticalAlignment="Center" />
                            <Ellipse x:Name="EllipseA5" Width="12" Height="12"
                                     Fill="#95A5A6" Margin="6,0,0,0"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                        <Label x:Name="lblA5_og" Grid.Row="1"
                               Content="—"
                               FontFamily="Lato" FontSize="22" FontWeight="Bold"
                               Foreground="White"
                               HorizontalContentAlignment="Right"
                               VerticalContentAlignment="Center"
                               Padding="0" />
                        <Label x:Name="lblA5_lg" Grid.Row="2"
                               Content="—"
                               FontFamily="Lato" FontSize="11"
                               Foreground="#7F8C8D"
                               HorizontalContentAlignment="Right"
                               Padding="0" />
                        <TextBlock Grid.Row="3" Text="Preporučeno: &gt; 10 %"
                                   FontFamily="Lato" FontSize="10" Foreground="#2ECC71"
                                   HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                    </Grid>
                    <GroupBox x:Name="gbDrillA5" Style="{StaticResource DrillOverlayStyle}"/>
                </Grid>

                <!-- A6  AR Turnover -->
                <Grid Grid.Row="3" Grid.Column="1" Margin="5,4,5,4">
                    <ToolTipService.ToolTip><ToolTip Content="Prihodi (Klasa 6) / Potraživanja (Klasa 12)"/></ToolTipService.ToolTip>
                    <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                    <Grid Margin="10,8,10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="A6" FontSize="11" FontWeight="Bold"
                                       Foreground="#E67E22" FontFamily="Lato"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Obrtaj potraživanja" FontSize="12" Foreground="#BDC3C7"
                                       FontFamily="Lato" VerticalAlignment="Center" />
                            <Ellipse x:Name="EllipseA6" Width="12" Height="12"
                                     Fill="#95A5A6" Margin="6,0,0,0"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                        <Label x:Name="lblA6_og" Grid.Row="1"
                               Content="—"
                               FontFamily="Lato" FontSize="22" FontWeight="Bold"
                               Foreground="White"
                               HorizontalContentAlignment="Right"
                               VerticalContentAlignment="Center"
                               Padding="0" />
                        <Label x:Name="lblA6_lg" Grid.Row="2"
                               Content="—"
                               FontFamily="Lato" FontSize="11"
                               Foreground="#7F8C8D"
                               HorizontalContentAlignment="Right"
                               Padding="0" />
                        <TextBlock Grid.Row="3" Text="Preporučeno: &gt; 6"
                                   FontFamily="Lato" FontSize="10" Foreground="#2ECC71"
                                   HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                    </Grid>
                    <GroupBox x:Name="gbDrillA6" Style="{StaticResource DrillOverlayStyle}"/>
                </Grid>

                <!-- A7  Inventory Turnover -->
                <Grid Grid.Row="4" Grid.Column="0" Margin="5,4,5,4">
                    <ToolTipService.ToolTip><ToolTip Content="Troškovi (Klasa 4) / Zalihe (Klasa 31-39)"/></ToolTipService.ToolTip>
                    <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                    <Grid Margin="10,8,10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="A7" FontSize="11" FontWeight="Bold"
                                       Foreground="#E67E22" FontFamily="Lato"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Obrtaj zaliha" FontSize="12" Foreground="#BDC3C7"
                                       FontFamily="Lato" VerticalAlignment="Center" />
                            <Ellipse x:Name="EllipseA7" Width="12" Height="12"
                                     Fill="#95A5A6" Margin="6,0,0,0"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                        <Label x:Name="lblA7_og" Grid.Row="1"
                               Content="—"
                               FontFamily="Lato" FontSize="22" FontWeight="Bold"
                               Foreground="White"
                               HorizontalContentAlignment="Right"
                               VerticalContentAlignment="Center"
                               Padding="0" />
                        <Label x:Name="lblA7_lg" Grid.Row="2"
                               Content="—"
                               FontFamily="Lato" FontSize="11"
                               Foreground="#7F8C8D"
                               HorizontalContentAlignment="Right"
                               Padding="0" />
                        <TextBlock Grid.Row="3" Text="Preporučeno: &gt; 4"
                                   FontFamily="Lato" FontSize="10" Foreground="#2ECC71"
                                   HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                    </Grid>
                    <GroupBox x:Name="gbDrillA7" Style="{StaticResource DrillOverlayStyle}"/>
                </Grid>

                <!-- A8  Debt-to-Equity -->
                <Grid Grid.Row="4" Grid.Column="1" Margin="5,4,5,4">
                    <ToolTipService.ToolTip><ToolTip Content="Obveze (Klasa 2) / Kapital (Klasa 3)"/></ToolTipService.ToolTip>
                    <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                    <Grid Margin="10,8,10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="A8" FontSize="11" FontWeight="Bold"
                                       Foreground="#E67E22" FontFamily="Lato"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Zaduženost (D/E)" FontSize="12" Foreground="#BDC3C7"
                                       FontFamily="Lato" VerticalAlignment="Center" />
                            <Ellipse x:Name="EllipseA8" Width="12" Height="12"
                                     Fill="#95A5A6" Margin="6,0,0,0"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                        <Label x:Name="lblA8_og" Grid.Row="1"
                               Content="—"
                               FontFamily="Lato" FontSize="22" FontWeight="Bold"
                               Foreground="White"
                               HorizontalContentAlignment="Right"
                               VerticalContentAlignment="Center"
                               Padding="0" />
                        <Label x:Name="lblA8_lg" Grid.Row="2"
                               Content="—"
                               FontFamily="Lato" FontSize="11"
                               Foreground="#7F8C8D"
                               HorizontalContentAlignment="Right"
                               Padding="0" />
                        <TextBlock Grid.Row="3" Text="Preporučeno: &lt; 1.0"
                                   FontFamily="Lato" FontSize="10" Foreground="#F39C12"
                                   HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                    </Grid>
                    <GroupBox x:Name="gbDrillA8" Style="{StaticResource DrillOverlayStyle}"/>
                </Grid>

                <!-- A9  Revenue Growth YoY -->
                <Grid Grid.Row="5" Grid.Column="0" Margin="5,4,5,4">
                    <ToolTipService.ToolTip><ToolTip Content="(Prihodi OG - Prihodi LG) / Prihodi LG x 100"/></ToolTipService.ToolTip>
                    <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                    <Grid Margin="10,8,10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
