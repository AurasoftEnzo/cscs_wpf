<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wcl="clr-namespace:WpfControlsLibrary;assembly=WpfControlsLibrary"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        mc:Ignorable="d"
        Name="wxbiglaWindowB"
        Title="Rashodi po Mjesecima"
        Height="560"
        Width="1060"
        WindowStartupLocation="CenterScreen"
        MinHeight="440" MinWidth="760"
        Background="#2C3E50">

    <Window.Resources>
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.70"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="1040" Height="530" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="#1A252F"
                    CornerRadius="6,6,0,0"
                    Padding="14,0">
                <TextBlock Text="Rashodi (klase 4 i 5) po Mjesecima"
                           Foreground="White"
                           FontFamily="Lato" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Chart area -->
            <Border Grid.Row="1"
                    Background="#263646"
                    Padding="10,4,10,4">
                <lvc:CartesianChart x:Name="ChartRashodi"
                                    LegendPosition="Right"
                                    Margin="4,8,4,4"/>
            </Border>

            <!-- Footer with close button -->
            <Border Grid.Row="2"
                    Background="#1A252F"
                    CornerRadius="0,0,6,6"
                    Padding="14,4">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="gbZatvoriRashodi"
                            Content="Zatvori"
                            Style="{StaticResource FlatButtonStyle}"
                            Background="#AC3E31"
                            Foreground="White"
                            FontFamily="Lato" FontSize="15"
                            Width="100" Height="32"
                            TabIndex="1"/>
                </StackPanel>
            </Border>
        </Grid>
    </Viewbox>
</Window>
