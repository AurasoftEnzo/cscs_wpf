<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wcl="clr-namespace:WpfControlsLibrary;assembly=WpfControlsLibrary"
        mc:Ignorable="d"
        Name="wxbiglaWindowC"
        Title="Dodatni pokazatelji"
        Height="660"
        Width="1060"
        WindowStartupLocation="CenterScreen"
        MinHeight="540" MinWidth="760"
        Background="#2C3E50">

    <Window.Resources>
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.70"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="1040" Height="630" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="#1A252F"
                    CornerRadius="6,6,0,0"
                    Padding="14,0">
                <TextBlock Text="Dodatni financijski pokazatelji (B1–B6)"
                           Foreground="White"
                           FontFamily="Lato" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- 6 KPI cards  3 rows × 2 cols -->
            <Border Grid.Row="1" Background="#263646" Padding="4,4,4,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- B1  Rast troškova -->
                    <Grid Grid.Row="0" Grid.Column="0" Margin="5,4,5,4">
                        <ToolTipService.ToolTip><ToolTip Content="(Rashodi OG - Rashodi LG) / Rashodi LG × 100  |  Klasa 4+5"/></ToolTipService.ToolTip>
                        <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                        <Grid Margin="10,8,10,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="B1" FontSize="11" FontWeight="Bold"
                                           Foreground="#E67E22" FontFamily="Lato"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Rast troškova" FontSize="12" Foreground="#BDC3C7"
                                           FontFamily="Lato" VerticalAlignment="Center" />
                                <Ellipse x:Name="EllipseB1" Width="12" Height="12"
                                         Fill="#95A5A6" Margin="6,0,0,0"
                                         VerticalAlignment="Center" />
                            </StackPanel>
                            <Label x:Name="lblB1_og" Grid.Row="1"
                                   Content="—"
                                   FontFamily="Lato" FontSize="22" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalContentAlignment="Right"
                                   VerticalContentAlignment="Center"
                                   Padding="0" />
                            <Label x:Name="lblB1_lg" Grid.Row="2"
                                   Content="—"
                                   FontFamily="Lato" FontSize="11"
                                   Foreground="#7F8C8D"
                                   HorizontalContentAlignment="Right"
                                   Padding="0" />
                            <TextBlock Grid.Row="3" Text="Preporučeno: &lt; 0 %"
                                       FontFamily="Lato" FontSize="10" Foreground="#F39C12"
                                       HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                        </Grid>
                    </Grid>

                    <!-- B2  Kamatno pokriće (Interest Coverage) -->
                    <Grid Grid.Row="0" Grid.Column="1" Margin="5,4,5,4">
                        <ToolTipService.ToolTip><ToolTip Content="EBIT (Neto dobit + Kamate Kl.51) / Kamatni troškovi (Kl. 51)"/></ToolTipService.ToolTip>
                        <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                        <Grid Margin="10,8,10,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="B2" FontSize="11" FontWeight="Bold"
                                           Foreground="#E67E22" FontFamily="Lato"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Kamatno pokriće" FontSize="12" Foreground="#BDC3C7"
                                           FontFamily="Lato" VerticalAlignment="Center" />
                                <Ellipse x:Name="EllipseB2" Width="12" Height="12"
                                         Fill="#95A5A6" Margin="6,0,0,0"
                                         VerticalAlignment="Center" />
                            </StackPanel>
                            <Label x:Name="lblB2_og" Grid.Row="1"
                                   Content="—"
                                   FontFamily="Lato" FontSize="22" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalContentAlignment="Right"
                                   VerticalContentAlignment="Center"
                                   Padding="0" />
                            <Label x:Name="lblB2_lg" Grid.Row="2"
                                   Content="—"
                                   FontFamily="Lato" FontSize="11"
                                   Foreground="#7F8C8D"
                                   HorizontalContentAlignment="Right"
                                   Padding="0" />
                            <TextBlock Grid.Row="3" Text="Preporučeno: &gt; 3"
                                       FontFamily="Lato" FontSize="10" Foreground="#2ECC71"
                                       HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                        </Grid>
                    </Grid>

                    <!-- B3  Obrtaj dugotrajne imovine (Fixed Asset Turnover) -->
                    <Grid Grid.Row="1" Grid.Column="0" Margin="5,4,5,4">
                        <ToolTipService.ToolTip><ToolTip Content="Prihodi (Kl. 6) / Dugotrajna imovina (Kl. 0)"/></ToolTipService.ToolTip>
                        <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                        <Grid Margin="10,8,10,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="B3" FontSize="11" FontWeight="Bold"
                                           Foreground="#E67E22" FontFamily="Lato"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Obrtaj dugotrajne imovine" FontSize="12" Foreground="#BDC3C7"
                                           FontFamily="Lato" VerticalAlignment="Center" />
                                <Ellipse x:Name="EllipseB3" Width="12" Height="12"
                                         Fill="#95A5A6" Margin="6,0,0,0"
                                         VerticalAlignment="Center" />
                            </StackPanel>
                            <Label x:Name="lblB3_og" Grid.Row="1"
                                   Content="—"
                                   FontFamily="Lato" FontSize="22" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalContentAlignment="Right"
                                   VerticalContentAlignment="Center"
                                   Padding="0" />
                            <Label x:Name="lblB3_lg" Grid.Row="2"
                                   Content="—"
                                   FontFamily="Lato" FontSize="11"
                                   Foreground="#7F8C8D"
                                   HorizontalContentAlignment="Right"
                                   Padding="0" />
                            <TextBlock Grid.Row="3" Text="Preporučeno: &gt; 1"
                                       FontFamily="Lato" FontSize="10" Foreground="#2ECC71"
                                       HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                        </Grid>
                    </Grid>

                    <!-- B4  Cash Conversion Cycle (CCC) -->
                    <Grid Grid.Row="1" Grid.Column="1" Margin="5,4,5,4">
                        <ToolTipService.ToolTip><ToolTip Content="DZO + DSO - DPO (u danima)  |  DZO=(Zalihe/Rashodi)×365  DSO=(Potraž./Prihodi)×365  DPO=(AP/Rashodi)×365"/></ToolTipService.ToolTip>
                        <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                        <Grid Margin="10,8,10,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="B4" FontSize="11" FontWeight="Bold"
                                           Foreground="#E67E22" FontFamily="Lato"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Cash Conversion Cycle" FontSize="12" Foreground="#BDC3C7"
                                           FontFamily="Lato" VerticalAlignment="Center" />
                                <Ellipse x:Name="EllipseB4" Width="12" Height="12"
                                         Fill="#95A5A6" Margin="6,0,0,0"
                                         VerticalAlignment="Center" />
                            </StackPanel>
                            <Label x:Name="lblB4_og" Grid.Row="1"
                                   Content="—"
                                   FontFamily="Lato" FontSize="22" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalContentAlignment="Right"
                                   VerticalContentAlignment="Center"
                                   Padding="0" />
                            <Label x:Name="lblB4_lg" Grid.Row="2"
                                   Content="—"
                                   FontFamily="Lato" FontSize="11"
                                   Foreground="#7F8C8D"
                                   HorizontalContentAlignment="Right"
                                   Padding="0" />
                            <TextBlock Grid.Row="3" Text="Preporučeno: &lt; 90 d"
                                       FontFamily="Lato" FontSize="10" Foreground="#F39C12"
                                       HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                        </Grid>
                    </Grid>

                    <!-- B5  Return on Assets (ROA) -->
                    <Grid Grid.Row="2" Grid.Column="0" Margin="5,4,5,4">
                        <ToolTipService.ToolTip><ToolTip Content="Neto dobit (Kl. 95) / Ukupna imovina (Kl. 0 + Kl. 1) × 100"/></ToolTipService.ToolTip>
                        <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                        <Grid Margin="10,8,10,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="B5" FontSize="11" FontWeight="Bold"
                                           Foreground="#E67E22" FontFamily="Lato"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Prinos na imovinu (ROA)" FontSize="12" Foreground="#BDC3C7"
                                           FontFamily="Lato" VerticalAlignment="Center" />
                                <Ellipse x:Name="EllipseB5" Width="12" Height="12"
                                         Fill="#95A5A6" Margin="6,0,0,0"
                                         VerticalAlignment="Center" />
                            </StackPanel>
                            <Label x:Name="lblB5_og" Grid.Row="1"
                                   Content="—"
                                   FontFamily="Lato" FontSize="22" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalContentAlignment="Right"
                                   VerticalContentAlignment="Center"
                                   Padding="0" />
                            <Label x:Name="lblB5_lg" Grid.Row="2"
                                   Content="—"
                                   FontFamily="Lato" FontSize="11"
                                   Foreground="#7F8C8D"
                                   HorizontalContentAlignment="Right"
                                   Padding="0" />
                            <TextBlock Grid.Row="3" Text="Preporučeno: &gt; 5 %"
                                       FontFamily="Lato" FontSize="10" Foreground="#2ECC71"
                                       HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                        </Grid>
                    </Grid>

                    <!-- B6  EBITDA Margin -->
                    <Grid Grid.Row="2" Grid.Column="1" Margin="5,4,5,4">
                        <ToolTipService.ToolTip><ToolTip Content="(Neto dobit + Kamate Kl.51 + Amortizacija Kl.42) / Prihodi (Kl. 6) × 100"/></ToolTipService.ToolTip>
                        <Rectangle RadiusX="8" RadiusY="8" Fill="#34495E" />
                        <Grid Margin="10,8,10,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="B6" FontSize="11" FontWeight="Bold"
                                           Foreground="#E67E22" FontFamily="Lato"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="EBITDA marža" FontSize="12" Foreground="#BDC3C7"
                                           FontFamily="Lato" VerticalAlignment="Center" />
                                <Ellipse x:Name="EllipseB6" Width="12" Height="12"
                                         Fill="#95A5A6" Margin="6,0,0,0"
                                         VerticalAlignment="Center" />
                            </StackPanel>
                            <Label x:Name="lblB6_og" Grid.Row="1"
                                   Content="—"
                                   FontFamily="Lato" FontSize="22" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalContentAlignment="Right"
                                   VerticalContentAlignment="Center"
                                   Padding="0" />
                            <Label x:Name="lblB6_lg" Grid.Row="2"
                                   Content="—"
                                   FontFamily="Lato" FontSize="11"
                                   Foreground="#7F8C8D"
                                   HorizontalContentAlignment="Right"
                                   Padding="0" />
                            <TextBlock Grid.Row="3" Text="Preporučeno: &gt; 15 %"
                                       FontFamily="Lato" FontSize="10" Foreground="#2ECC71"
                                       HorizontalAlignment="Right" Margin="0,2,0,0" FontStyle="Italic"/>
                        </Grid>
                    </Grid>

                </Grid>
            </Border>

            <!-- Footer with close button -->
            <Border Grid.Row="2"
                    Background="#1A252F"
                    CornerRadius="0,0,6,6"
                    Padding="14,4">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="gbZatvoriDodatni"
                            Content="Zatvori"
                            Style="{StaticResource FlatButtonStyle}"
                            Background="#AC3E31"
                            Foreground="White"
                            FontFamily="Lato" FontSize="15"
                            Width="100" Height="32"
                            TabIndex="1"/>
                </StackPanel>
            </Border>

        </Grid>
    </Viewbox>
</Window>
