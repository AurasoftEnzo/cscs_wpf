// -------------------- INITIALIZE GUI --------------------
function InitializeGUI() {
    // Load XAML
    // AddOrSetScript("mainWindow", "WXeracunPrint.xaml", "");
    CreateWindow(strtrim(tpath()) + "wxeracunprint.xaml");

    // Get controls
    // txtXmlPath = GetWidget("txtXmlPath");
    // btnBrowse = GetWidget("btnBrowse");
    // btnLoad = GetWidget("btnLoad");
    // btnExportPDF = GetWidget("btnExportPDF");
    // btnPrint = GetWidget("btnPrint");
    // btnClose = GetWidget("btnClose");
    // lblStatus = GetWidget("lblStatus");
    
    // Set initial state
    SetWidgetOptions("lblStatus", "Text", "Spremno. Odaberite XML datoteku e-računa.");
    // SetEnabled(btnLoad, false);
    // SetEnabled(btnExportPDF, false);
    // SetEnabled(btnPrint, false);
    SetWidgetOptions("btnLoad", "IsEnabled", "false");
    SetWidgetOptions("btnExportPDF", "IsEnabled", "false");
    SetWidgetOptions("btnPrint", "IsEnabled", "false");
}

// Bind events
// AddWidgetHandler(btnBrowse, "", "OnBrowseClick");
// AddWidgetHandler(btnLoad, "", "OnLoadClick");
//AddWidgetHandler(btnExportPDF, "", "OnExportPDFClick");
// AddWidgetHandler(btnPrint, "", "OnPrintClick");
