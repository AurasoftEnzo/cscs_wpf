// -------------------- HELPER FUNCTIONS --------------------

function FormatDate(dateStr, format) {
    if (dateStr == "") { return ""; }
    
    // Parse ISO date (yyyy-MM-dd)
    parts = dateStr.Split("-");
    if (Size(parts) != 3) { return dateStr; }
    
    year = parts[0];
    month = parts[1];
    day = parts[2];
    
    if (format == "dd.MM.yyyy") {
        return day + "." + month + "." + year;
    }
    
    return dateStr;
}

function ParseDouble(str) {
    if (str == "") { return 0.0; }
    return Double(str);
}

