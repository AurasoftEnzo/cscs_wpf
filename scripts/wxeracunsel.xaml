<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wcl="clr-namespace:WpfControlsLibrary;assembly=WpfControlsLibrary"
        xmlns:local="clr-namespace:WpfCSCS"
        mc:Ignorable="d"
        Title="Slanje izlaznih e-računa"
        Height="670"
        Width="1100"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Name="wxeracunselWindow"
        Background="#1A2535">

    <Window.Resources>

        <!-- Flat rounded button -->
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <!-- ================================================================
         Root: 3 rows – DataGrid | Action bar | Status row
         ================================================================ -->
    <Grid Margin="10,8,10,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>     <!-- DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Action bar -->
            <RowDefinition Height="Auto"/>  <!-- Status -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             ROW 0 – DataGrid
             ============================================================ -->
        <Border Grid.Row="0"
                Background="#263646"
                CornerRadius="8"
                Margin="0,0,0,8"
                Padding="1">
            <DataGrid x:Name="datagridListaRacuna"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#2D4057"
                      CanUserReorderColumns="True"
                      CanUserSortColumns="True"
                      Background="Transparent"
                      IsReadOnly="True"
                      RowHeight="23"
                      FontSize="13"
                      FontFamily="Segoe UI"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      BorderThickness="0"
                      AlternationCount="2"
                      RowBackground="#1E2F3D"
                      AlternatingRowBackground="#243444"
                      Foreground="#D0D8E4"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      TabIndex="2">
                <DataGrid.Resources>
                    <!-- Dark blue header -->
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Background"      Value="#1B4F72"/>
                        <Setter Property="Foreground"      Value="White"/>
                        <Setter Property="FontSize"        Value="13"/>
                        <Setter Property="FontWeight"      Value="SemiBold"/>
                        <Setter Property="FontFamily"      Value="Segoe UI"/>
                        <Setter Property="BorderBrush"     Value="#0E2D45"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="Padding"         Value="8,5"/>
                    </Style>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="Foreground" Value="#D0D8E4"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>

                    <DataGridTemplateColumn Header="Selekt" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arraySelekt"
                                                HorizontalContentAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="R. br." Width="55">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayRbr"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Br. računa" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayInvNum"
                                                HorizontalContentAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Oznaka" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayOznaka"
                                                HorizontalContentAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Kupac" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayKupac"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Dat. računa" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayDatumRacuna"
                                                HorizontalContentAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Iznos" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayIznos"
                                                HorizontalContentAlignment="Right"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Status" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayStatus"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ============================================================
             ROW 1 – Action bar  (Pošalji · Izlaz · Clock)
             ============================================================ -->
        <Border Grid.Row="1"
                Background="#263646"
                CornerRadius="8"
                Margin="0,0,0,8"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>      <!-- Pošalji centre -->
                    <ColumnDefinition Width="Auto"/>   <!-- Izlaz + clock right -->
                </Grid.ColumnDefinitions>

                <!-- Pošalji -->
                <Button Grid.Column="0"
                        Name="btnPosalji"
                        Content="Pošalji"
                        Style="{StaticResource FlatBtn}"
                        Background="#1B4F72"
                        FontSize="19" FontWeight="Bold"
                        Height="42" Width="240"
                        TabIndex="0"
                        HorizontalAlignment="Center"/>

                <!-- Izlaz + clock -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnIzlaz"
                            Content="Izlaz"
                            Style="{StaticResource FlatBtn}"
                            Background="#4A235A"
                            FontSize="19" FontWeight="Bold"
                            Height="42" Width="140"
                            TabIndex="1"
                            Margin="0,0,10,0"/>
                    <Image x:Name="asImage" DataContext="Sat"
                           Height="38" Width="42"
                           VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================
             ROW 2 – Status labels
             ============================================================ -->
        <Border Grid.Row="2"
                Background="#263646"
                CornerRadius="8"
                Padding="14,6">
            <StackPanel>
                <Label Name="StatusLabel"
                       Content=""
                       FontSize="16" FontFamily="Segoe UI"
                       Foreground="#C8D0DA"
                       HorizontalContentAlignment="Center"
                       Height="30" Padding="0"/>
                <Label Name="StatusLabel2"
                       Content=""
                       FontSize="16" FontFamily="Segoe UI"
                       Foreground="#C8D0DA"
                       HorizontalContentAlignment="Center"
                       Height="30" Padding="0"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
