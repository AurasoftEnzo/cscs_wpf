<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wcl="clr-namespace:WpfControlsLibrary;assembly=WpfControlsLibrary"
        mc:Ignorable="d"
        Title="Bruto bilanca - XLSX" Height="300" Width="600"
        MinHeight="250" MinWidth="500"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="#FFF0F0F0"
        Name="trialBalanceWindow">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="#4472C4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border BorderThickness="0"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="wcl:ASEnterBox">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20,20,20,2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   Text="Trial Balance / Probna Bilanca"
                   FontSize="18" FontWeight="Bold"
                   Foreground="#4472C4"
                   Margin="0,0,0,15"/>

        <!-- Output folder -->
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Output folder:"
                   VerticalAlignment="Center"
                   FontSize="13" FontWeight="SemiBold"/>
        <wcl:ASEnterBox Grid.Row="1" Grid.Column="1"
                         x:Name="tbOutputFolder"
                         FieldName="outputFolder"
                         Text="c:\cscs_wpf\scripts"
                         Margin="5,0,5,0"/>
        <Button Grid.Row="1" Grid.Column="2"
                Content="Browse..."
                Width="80" Height="28"
                x:Name="btnBrowse"/>

        <!-- File name -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="File name:"
                   VerticalAlignment="Center"
                   FontSize="13" FontWeight="SemiBold"
                   Margin="0,10,0,0"/>
        <wcl:ASEnterBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                         x:Name="tbFileName"
                         FieldName="outputFileName"
                         Text="TrialBalance.xlsx"
                         Margin="5,10,5,0"/>

        <!-- Company code -->
        <TextBlock Grid.Row="3" Grid.Column="0"
                   Text="Company:"
                   VerticalAlignment="Center"
                   FontSize="13" FontWeight="SemiBold"
                   Margin="0,10,0,0"/>
        <wcl:ASEnterBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                         x:Name="tbCompany"
                         FieldName="companyCode"
                         Text="D1"
                         Margin="5,10,5,0"/>

        <!-- Year -->
        <TextBlock Grid.Row="4" Grid.Column="0"
                   Text="Fiscal year:"
                   VerticalAlignment="Center"
                   FontSize="13" FontWeight="SemiBold"
                   Margin="0,10,0,0"/>
        <wcl:ASNumericBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                           x:Name="nbYear"
                           FieldName="ovagod_h"
                           Value="2025"
                           ButtonSize="0"
                           Dec="0"
                           Margin="5,10,5,0"/>

        <!-- Status message -->
        <TextBlock Grid.Row="5" Grid.ColumnSpan="3"
                   x:Name="txtStatus"
                   Text=""
                   VerticalAlignment="Bottom"
                   FontSize="12"
                   Foreground="#666666"
                   Margin="0,15,0,10"/>

        <!-- Generate button -->
        <Button Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2"
                Content="Generate Trial Balance"
                x:Name="btnGenerate"
                Style="{StaticResource ActionButton}"
                HorizontalAlignment="Right"
                Margin="0,0,5,0"/>
    </Grid>
</Window>
