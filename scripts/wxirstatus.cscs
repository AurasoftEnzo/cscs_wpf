function wxirstatus_onDisplay(){
    cursor("wait");
    
    filterStatusNijePoslan = true;
    filterStatusInterniRacun = true;
    filterStatusNijeUSustavuPdva = true;
    filterStatusIzvoz = true;
    filterStatusZaprimljen = true;
    filterStatusPotvrdenoZaprimanje = true;
    filterStatusPrihvacen = true;
    filterStatusOdbijen = true;
    filterStatusPlacanjeZaprimljeno = true;
    filterStatusDjelomicnoPlaceno = true;
    filterStatusPlaceno = true;

    // OIBFilter = "";

    DisableBtns();
    // SetWidgetOptions("StatusLabel", "Content", "Preuzimam listu izlaznih e-računa.");
    // SetWidgetOptions("StatusLabel2", "Content", "Molim pričekajte...");

    try{
        init();
        SetWindowOptions("wxirstatusWindow", "title", "Pregled statusa izlaznih e-računa(" + PROVIDER + ") za " + KPSY_COMP_NAME);
        // ✅ Enable sorting and resizing programmatically
        SetWidgetOptions("datagridListaRacuna", "CanUserSortColumns", "true");
        SetWidgetOptions("datagridListaRacuna", "CanUserResizeColumns", "true");
    }catch(ex){
        MessageBox("Greška pri inicijalizaciji:\n" + ex);
        // ??? LOG? ne?
        exit;
    }
    
    cursor("dflt");
    EnableBtns();
    // SetWidgetOptions("StatusLabel", "Content", "");
    // SetWidgetOptions("StatusLabel2", "Content", "");
}

