function getWinxList(){
    try{
        sql = "select
            NKPR_GL_NUM,
            NKPR_GL_CUSNME,
            NKPR_GL_JMBG,
            NKPR_GL_DATPRI,
            CASE
                WHEN NKPR_GL_DRZAVA != '" + KPSY_PO_FREIGHT + "' OR NKPR_GL_SIFDVZ != '" + KPSY_DOM_VALUTA + "' THEN 'Izvoz' 
                WHEN nkpr_gl_cuscod = sy_sp_vl_firma OR nkpr_gl_oznaka = 'VN' THEN 'Interni račun'
                WHEN nksc_tax_dn = 'X' OR nksc_tax_dn = '' THEN 'Nije u sustavu PDV-a'
                ELSE 'Nije poslan' 
            END as StatusRacuna
            FROM " + databaseName + ".dbo.NKPRINV 
            LEFT JOIN " + databaseName + ".dbo.KPSYSTEM on 1 = 1
            left join NKSCPART ON NKSC_PARTCODE = NKPR_GL_CUSCOD
            WHERE NKPR_GL_ESD BETWEEN '" + FilterDateFrom + "' AND '" + FilterDateTo + "' 
            ORDER BY NKPR_GL_NUM";
        sqlResult = SqlQuery(sql);
        
        progressMax = (Size(sqlResult) - 1) * (1 + 1/*fina list*/ + 1/*fina fisk status*/ + 1/*joining arrays*/);

        for(i = 1; i < Size(sqlResult); i++){
            AddRacunToWinxArrays(
                string(sqlResult[i][0]), // broj racuna
                sqlResult[i][1].trim(), // kupac
                sqlResult[i][2].trim(),  // OIB kupca
                sqlResult[i][3],  // datum slanja
                sqlResult[i][4]   // status racuna
            );
            Progress(1);
        }
    }catch(ex){
        MessageBox("Greška pri dohvatu liste računa iz baze:\n" + ex);
        // !!! LOG !!!
        exit;
    }
    
}

function joinDataWithWinx(){
    CopyWinxArraysToFinalArrays();

    for(indexRacunaProvider = 0; indexRacunaProvider <= RbrProvider; indexRacunaProvider++){
        indexRacunaFinal = FIND_INDEX(arrayFinalBrojRacuna, string(arrayProviderBrojRacuna[indexRacunaProvider]));
        if(indexRacunaFinal >= 0){
            JoinProviderRacunToFinalArrays(indexRacunaFinal, indexRacunaProvider);
        }
        
        Progress(1);
    }
}

function CopyWinxArraysToFinalArrays(){
    RbrFinal = RbrWinx;
    for(i = 0; i < RbrWinx; i++){
        arrayFinalBrojRacuna[i] = arrayWinxBrojRacuna[i];
        arrayFinalKupac[i] = arrayWinxKupac[i];
        arrayFinalOibKupca[i] = arrayWinxOibKupca[i];
        arrayFinalDatumSlanja[i] = arrayWinxDatumSlanja[i];

        arrayFinalStatusRacuna[i] = arrayWinxStatusRacuna[i];

        arrayFinalRbr[i] = arrayWinxRbr[i];
    }
}

function JoinProviderRacunToFinalArrays(iFinal, iProvider){
    // arrayFinalKupac[iFinal] = arrayProviderKupac[iProvider];
    arrayFinalOibKupca[iFinal] = arrayProviderOibKupca[iProvider];
    arrayFinalStatusRacuna[iFinal] = arrayProviderStatusRacuna[iProvider];
    arrayFinalDatumIzdavanja[iFinal] = arrayProviderDatumIzdavanja[iProvider];
    arrayFinalDatumKnjizenja[iFinal] = arrayProviderDatumKnjizenja[iProvider];
    // arrayFinalBrojRacuna[iFinal] = arrayProviderBrojRacuna[iProvider];
    arrayFinalIdRacunaPosrednika[iFinal] = arrayProviderIdRacunaPosrednika[iProvider];
    arrayFinalStatusFiskalizacije[iFinal] = arrayProviderStatusFiskalizacije[iProvider];
    arrayFinalReportPaymentStatus[iFinal] = arrayProviderReportPaymentStatus[iProvider];
    arrayFinalPlaceno[iFinal] = arrayProviderPlaceno[iProvider];
    arrayFinalZaPlacanje[iFinal] = arrayProviderZaPlacanje[iProvider];
    //arrayFinalKupacUAMS[iFinal] = arrayProviderKupacUAMS[iProvider];

    if (PROVIDER == "MER" || PROVIDER == "MERDEMO") {
        arrayFinalBrojRacunaMer[iFinal] = arrayProviderBrojRacunaMer[iProvider];
    } elif (PROVIDER == "FINA" || PROVIDER == "FINADEMO") {
        arrayFinalBrojRacunaFina[iFinal] = arrayProviderBrojRacunaFina[iProvider];
    } else {
        MessageBox("Nepoznat provider: " + PROVIDER + ". Podržani su: MER, FINA, MERDEMO, FINADEMO");
        exit;
    }
}

