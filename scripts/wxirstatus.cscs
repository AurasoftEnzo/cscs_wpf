function LogResponse(responseCode, response) {
    if(!DIR_EXISTS(FILESPATH + "IRStatus\\" + "responses\\")){
        MAKE_DIR(FILESPATH + "IRStatus\\" + "responses\\");
    }

    logFilePath = FILESPATH + "IRStatus\\" + "responses\\" + "queryinbox" + ".response";
    appendText = Now("yyyy-MM-dd HH:mm:ss") + " -----------------------------------\n\n" + "StatusCode = " + responseCode + "\n\n" + "Response:\n" + response + "\n\n";
    try {
        SaveFile(appendText, logFilePath, "a");        
    } catch (ex) {
        MessageBox("CRITICAL: Cannot write to log file: " + logPath + "\nError: " + ex);
    }
}

function LogException(exText) {
    try{
        logDir = FILESPATH + "IRStatus\\" + "log\\";
        if(!DIR_EXISTS(logDir)){
            MAKE_DIR(logDir);
        }

        logFilePath = logDir + "wxirstatus.error.log";
        appendText = Now("yyyy-MM-dd HH:mm:ss") + " | " + exText + "\n";
        SaveFile(appendText, logFilePath, "a");
    }catch(logEx){
        MSG("LogException failed: " + logEx);
    }
}

// Export state
exportedXlsxPath = "";
exportErrorText = "";

function GetRandom8Digits(){
    raw = UUID().Replace("-", "");
    digits = "";

    for(i = 0; i < raw.length; i++){
        ch = Substring(raw, i, 1);
        if(ch >= "0" && ch <= "9"){
            digits += ch;
        }
        if(digits.length >= 8){
            break;
        }
    }

    if(digits.length < 8){
        digits += Now("HHmmssff");
    }

    return Substring(digits, 0, 8);
}

function Export2XLSX@clicked(){
    if(RbrFinal <= 0){
        Mbox("Nema podataka za export.");
        return;
    }

    cursor("wait");
    SetWidgetOptions("Export2XLSX", "IsEnabled", "false");
    // SetWidgetOptions("StatusLabel", "Content", "Export u XLSX je u tijeku...");
    // SetWidgetOptions("StatusLabel2", "Content", "Molim pričekajte...");

    AsyncCall("StartExport2XLSX", "EndExport2XLSX");
}


function StartExport2XLSX(){
    exportErrorText = "";
    exportedXlsxPath = "";

    try{
        exportFolder = FILESPATH + "IRStatus\\" + "exports\\";
        if(!Exists(exportFolder)){
            MkDir(exportFolder);
        }

        random8 = GetRandom8Digits();
        exportedXlsxPath = exportFolder + "Wxirstatus_" + random8 + ".xlsx";

        random8 = GetRandom8Digits();
        exportedXlsxPath = exportFolder + "Wxurstatus_" + random8 + ".xlsx";

        // Create and open workbook
        XFileNew(exportedXlsxPath);
        XFileOpen(exportedXlsxPath);
        XSheetRename(1, "URStatus");

        // Header row
        XCellWriteString(1, 1, 1, "Rbr");
        XCellWriteString(1, 2, 1, "Kupac");
        XCellWriteString(1, 3, 1, "OIB_kupca");
        XCellWriteString(1, 4, 1, "StatusRacuna");
        XCellWriteString(1, 5, 1, "Dat_izdav");
        XCellWriteString(1, 6, 1, "Dat_PDV");
        XCellWriteString(1, 7, 1, "Broj_racuna");
        XCellWriteString(1, 8, 1, "Fiskaliziran");
        XCellWriteString(1, 9, 1, "Status_placanja");
        XCellWriteString(1, 10, 1, "ID_racuna");

        // Header style
        for(col = 1; col <= 10; col++){
            XBackgroundColor(1, col, 1, 53, 91, 178);
            XFontColor(1, col, 1, 255, 255, 255);
            XFontFormat(1, col, 1, true, false, false, false, false, false);
        }

        // Data rows
        for(i = 0; i < RbrFinal; i++){
            row = i + 2;

            XCellWriteInteger(1, 1, row, arrayFinalRbr[i]);
            XCellWriteString(1, 2, row, arrayFinalKupac[i]);
            XCellWriteString(1, 3, row, arrayFinalOibKupca[i]);
            XCellWriteString(1, 4, row, arrayFinalStatusRacuna[i]);
            XCellWriteString(1, 5, row, arrayFinalDatumIzdavanja[i]);
            XCellWriteString(1, 6, row, arrayFinalDatumKnjizenja[i]);
            XCellWriteString(1, 7, row, arrayFinalBrojRacuna[i]);
            XCellWriteString(1, 8, row, arrayFinalStatusFiskalizacije[i]);
            XCellWriteString(1, 9, row, arrayFinalReportPaymentStatus[i]);
            XCellWriteString(1, 10, row, arrayFinalIdRacunaPosrednika[i]);
        }

        XColumnsAutoFit(1);
        XFileSave();
    }catch(ex){
        exportErrorText = ex;
        LogException("Export2XLSX error: " + ex);
        exportedXlsxPath = "";
    }
}

function EndExport2XLSX(){
    cursor("dflt");
    SetWidgetOptions("Export2XLSX", "IsEnabled", "true");
    // SetWidgetOptions("StatusLabel", "Content", "");
    // SetWidgetOptions("StatusLabel2", "Content", "");

    if(exportErrorText != ""){
        Mbox("Greška kod exporta u XLSX:\n" + exportErrorText);
        return;
    }

    if(exportedXlsxPath != ""){
        try{
            RunExec(exportedXlsxPath);
        }catch(ex){
            Mbox("XLSX je kreiran:\n" + exportedXlsxPath);
        }
    }
}

function btnOsvjezi@clicked(){
    try{
        Cursor("wait");
        DisableBtns();
        DisplayArray("datagridListaRacuna", "close");

        AsyncCall("filter", "endFilter");
    }catch(ex){
        MessageBox("Greška prilikom osvježavanja:\n" + ex);
        // !!! LOG !!!
    }
}

function filter(){
    RbrFiltered = 0;

    for(iFinal = 0; iFinal < RbrFinal; iFinal++){

        if(OIBFilter.trim() != "" && OIBFilter.trim() != arrayFinalOibKupca[iFinal].trim()){
            continue;
        }

        //filter by status
        if((filterStatusNijePoslan && arrayFinalStatusRacuna[iFinal] == "Nije poslan")
            || (filterStatusInterniRacun && arrayFinalStatusRacuna[iFinal] == "Interni račun")
            || (filterStatusNijeUSustavuPdva && arrayFinalStatusRacuna[iFinal] == "Nije u sustavu PDV-a")
            || (filterStatusIzvoz && arrayFinalStatusRacuna[iFinal] == "Izvoz")

            || (filterStatusZaprimljen && arrayFinalStatusRacuna[iFinal] == "Zaprimljen")
            || (filterStatusPotvrdenoZaprimanje && arrayFinalStatusRacuna[iFinal] == "Potvrđeno zaprimanje")

            || (filterStatusPrihvacen && arrayFinalStatusRacuna[iFinal] == "Prihvaćen")
            || (filterStatusOdbijen && arrayFinalStatusRacuna[iFinal] == "Odbijen")

            || (filterStatusPlacanjeZaprimljeno && arrayFinalStatusRacuna[iFinal] == "Plaćanje zaprimljeno")
            || (filterStatusDjelomicnoPlaceno && arrayFinalStatusRacuna[iFinal] == "Djelomično plaćeno")
            || (filterStatusPlaceno && arrayFinalStatusRacuna[iFinal] == "Plaćeno")
        ){
            AddFinalRacunToFilteredArrays(iFinal);
        }
    }
}

function endFilter(){
    if(RbrFiltered != 0){
        DisplayArraySetup("datagridListaRacuna", counterFld: cntr1, activeElements: RbrFiltered, maxElements: 10000);
    }
    EnableBtns();
    Cursor("dflt");
}

function AddFinalRacunToFilteredArrays(iFinal){
    arrayFilteredKupac[RbrFiltered] = arrayFinalKupac[iFinal];
    arrayFilteredOibKupca[RbrFiltered] = arrayFinalOibKupca[iFinal];
    arrayFilteredStatusRacuna[RbrFiltered] = arrayFinalStatusRacuna[iFinal];
    arrayFilteredDatumIzdavanja[RbrFiltered] = arrayFinalDatumIzdavanja[iFinal];
    arrayFilteredDatumKnjizenja[RbrFiltered] = arrayFinalDatumKnjizenja[iFinal];
    arrayFilteredDatumSlanja[RbrFiltered] = arrayFinalDatumSlanja[iFinal];
    arrayFilteredBrojRacuna[RbrFiltered] = arrayFinalBrojRacuna[iFinal];
    arrayFilteredIdRacunaPosrednika[RbrFiltered] = arrayFinalIdRacunaPosrednika[iFinal];
    arrayFilteredStatusFiskalizacije[RbrFiltered] = arrayFinalStatusFiskalizacije[iFinal];
    arrayFilteredReportPaymentStatus[RbrFiltered] = arrayFinalReportPaymentStatus[iFinal];
    arrayFilteredPlaceno[RbrFiltered] = arrayFinalPlaceno[iFinal];
    arrayFilteredZaPlacanje[RbrFiltered] = arrayFinalZaPlacanje[iFinal];
    //arrayFilteredKupacUAMS[RbrFiltered] = arrayFinalKupacUAMS[iFinal];

    if (PROVIDER == "MER" || PROVIDER == "MERDEMO") {
        arrayFilteredBrojRacunaMer[RbrFiltered] = arrayFinalBrojRacunaMer[iFinal];
    } elif (PROVIDER == "FINA" || PROVIDER == "FINADEMO") {
        arrayFilteredBrojRacunaFina[RbrFiltered] = arrayFinalBrojRacunaFina[iFinal];
    } else {
        MessageBox("Nepoznat provider: " + PROVIDER + ". Podržani su: MER, FINA, MERDEMO, FINADEMO");
        exit;
    }

    arrayFilteredRbr[RbrFiltered] = ++RbrFiltered;
}



//-----------------------------------------------------------

function datagridListaRacuna@select(){
    try{
        invoiceArray = GetSelectedGridRow("datagridListaRacuna");
        
        if(Size(invoiceArray) <=  11){
            return;
        }

        invoiceID = invoiceArray[11];

        tempFolder = FILESPATH + "IRStatus\\" + "Temp\\" + userCode + "\\";
        if (!Exists(tempFolder)) {
            MkDir(tempFolder);
        }

        if(invoiceID != ""){
            if(PROVIDER == "MER" || PROVIDER == "MERDEMO"){
                isDownloaded = MER_DownloadTempXml(invoiceID);   
            } elif(PROVIDER == "FINA" || PROVIDER == "FINADEMO"){
                isDownloaded = FINA_DownloadTempXml(invoiceID);  
            } else {
                MessageBox("Nepoznat provider: " + PROVIDER + ". Podržani su: MER, FINA, MERDEMO, FINADEMO");
                exit;
            }

            //pozvat wxeracunprint.cscs skriptu
            if(isDownloaded){
                CHAIN strtrim(tpath())+"\\wxeracunprint.cscs" NEWRUNTIME WITH xmlFilePath, pdfFilePath;
            }
        }
    }catch(ex){
        MessageBox("Greška prilikom selektiranja računa:\n" + ex);
        // !!! LOG !!!
        exit;
    }
}


function FINA_DownloadTempXml(_invoiceID){
    try{
        ack = FINA_GET_B2B_OUTGOING_INVOICE(
            ERAC_SERVER + "B2BFinaInvoiceWebService/services/B2BFinaInvoiceWebService",
            ERAC_DESC, // "e-invoice" / NE "e-racun-winx" !
            CERTPATH + ERAC_USERT, // servisni certifikat
            CERTPATH + ERAC_PASST, // p12 certifikat (klijentski)
            ERAC_PASS, // password za p12 certifikat

            UUID(), // messageId
            "9934:" + companyOIB, // OIB primatelja (VLASTITI)
            _invoiceID // invoiceId
        );

        if(Contains(ack, "ErrorCode")){
            Mbox("Greška pri preuzimanju računa " + _invoiceId + ":\n" + "ack:" + "\n" + ack);
            return false;
        }

        uuid = UUID();
        xmlFilePath = tempFolder + uuid + ".xml";
        pdfFilePath = tempFolder + uuid + ".pdf";

        //Save XML
        SaveFile(ack["ItemContent"], xmlFilePath);

        // Save PDF
        if(Contains(ack, "Base64PdfDocumentString")){
            Base642File(ack["Base64PdfDocumentString"], pdfFilePath);
        }

        return true;
    }catch(ex){
        Mbox("Račun " + _invoiceID + "\nNepoznata greška:\n" + ex);
        LogException(ex); // !!! 
        return false;
    }
}

function MER_DownloadTempXml(_invoiceID){
    Mbox("TREBA IMPLEMENTIRATI!");
}



function wxirstatus_OnClose(){
    // Cleanup temp files
    try{
        tempFolder = FILESPATH + "IRStatus\\" + "Temp\\" + userCode + "\\";
        if(Exists(tempFolder)){
            Delete(tempFolder);
        }
    }catch(ex){
        MessageBox("Greška prilikom čišćenja temp foldera:\n" + ex);
        // !!! LOG !!!
    }
}