<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wcl="clr-namespace:WpfControlsLibrary;assembly=WpfControlsLibrary"
        xmlns:local="clr-namespace:WpfCSCS"
        mc:Ignorable="d"
        Title="Pregled statusa ulaznih e-računa"
        Height="670"
        Width="1000"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Name="wxurstatusWindow">
    <Grid>

        <DataGrid GridLinesVisibility="All"
          HorizontalGridLinesBrush="#FFD7D6D6"
                  VerticalGridLinesBrush="#FFD7D6D6"
                        CanUserReorderColumns="True"
            CanUserSortColumns="True"
          Background="White"
          Margin="0,14,0,0"
          IsReadOnly="true"
        RowHeight="22"
          FontSize="15"
          x:Name="datagridListaRacuna"
          HorizontalScrollBarVisibility="Auto"
          VerticalScrollBarVisibility="Auto"
          TabIndex="4" 
            BorderBrush="DarkGray"
            BorderThickness="1"
         Height="410" Width="960"  VerticalAlignment="Top" HorizontalAlignment="Center"
                  AlternationCount="2"
AlternatingRowBackground="AliceBlue"
                  FrozenColumnCount="2"
                  >
            <DataGrid.Resources>
                <Style TargetType="{x:Type DataGridColumnHeader}">
                    <Setter Property="Background"
                    Value="#FF355BB2" />
                    <Setter Property="Foreground"
                    Value="White" />
                    <Setter Property="FontSize" Value="17"/>

                    <Setter Property="BorderBrush" Value="White"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="R. br."
                Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredRbr" CanUserSort="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Dobavljač"
                Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredDobavljac" CanUserSort="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="OIB dobavlj."
                    Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredOibDobavljaca" HorizontalContentAlignment="Center" CanUserSort="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Status računa"
    Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredStatusRacuna" CanUserSort="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Dat. izdav."
                Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredDatumIzdavanja" HorizontalContentAlignment="Center" CanUserSort="True" EditLength="8"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Dat. PDV"
            Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredDatumPDVa" HorizontalContentAlignment="Center" CanUserSort="True" EditLength="8"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Broj računa"
                Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredBrojRacuna" CanUserSort="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Fiskaliziran?"
    Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredStatusFiskalizacije" HorizontalContentAlignment="Center" CanUserSort="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Odbijen?"
    Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredReportRejectionStatus" CanUserSort="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Broj eRačuna"
                Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredBrPon" HorizontalContentAlignment="Right" CanUserSort="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTemplateColumn Header="Broj ul. računa"
                Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredGlNum" HorizontalContentAlignment="Right" CanUserSort="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                
                <DataGridTemplateColumn Header="Iznos"
Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredZaPlacanje" HorizontalContentAlignment="Right" CanUserSort="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                
                <DataGridTemplateColumn Header="ID računa"
Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayFilteredIdRacunaPosrednika" HorizontalContentAlignment="Right" CanUserSort="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!--<DataGridTemplateColumn Header="R. br."
                                Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayRbr" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Broj računa"
                Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayBrojRacuna"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Status računa"
                    Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayStatusRacuna" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Kupac"
                                Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayKupac" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Dat. izdavanja"
                                Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayDatumIzdavanja" HorizontalContentAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Dat. knjiženja"
                            Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayDatumKnjizenja" HorizontalContentAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="OIB kupca"
                    Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <wcl:ASGridCell FieldName="arrayOibKupca" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->

            </DataGrid.Columns>
        </DataGrid>

        <Button
            Content="Prikaži"
            Name="btnPrikazi"
            TabIndex="3"
            FontSize="35"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="300,434,0,0"
            Width="385"
            Height="70" />

        <Button
            Content="Export2XLSX"
            Name="Export2XLSX"
            FontSize="22"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="760,434,0,0"
            Width="210"
            Height="70" />

        <!--<Label Content="" Name="StatusLabel" FontSize="25" HorizontalContentAlignment="Center" Height="50" Width="775" Margin="110,534,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <Label Content="" Name="StatusLabel2" FontSize="25" HorizontalContentAlignment="Center" Height="45" Width="780" Margin="0,579,0,0" VerticalAlignment="Top" HorizontalAlignment="Center"/>-->

        <Image x:Name="asImage" DataContext="Sat" Height="90" Width="100" Margin="680,534,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <wcl:ASDateEditer
            DisplaySize="8"
            DisplayDate="01/01/26"
            ButtonWidth="19"
            x:Name="dateEditerFrom"
            DataContext="FilterDateFrom"
            FontSize="20"
            TabIndex="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top" Margin="70,434,0,0" Width="130" Height="30" />
        <Label Content="Od:" FontSize="20" HorizontalContentAlignment="Center" Height="35" Width="65" Margin="10,429,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>

        <wcl:ASDateEditer
            TabIndex="2"
            DisplaySize="8"
            DisplayDate="01/01/26"
            ButtonWidth="19"
            x:Name="dateEditerTo"
            DataContext="FilterDateTo"
            FontSize="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Top" Margin="70,474,0,0" Width="130" Height="30" />
        <Label Content="Do:" FontSize="20" HorizontalContentAlignment="Center" Height="35" Width="65" Margin="10,469,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>


        <!-- FILTER -->
        <Border BorderBrush="DarkGray" Background="AliceBlue" BorderThickness="1" Margin="10,514,10,10"/>
        <Label Content="Filtriranje" FontWeight="Bold" FontSize="20" HorizontalAlignment="Left" Margin="15,514,0,0" VerticalAlignment="Top" Height="40" Width="110"/>
        <Label Content="OIB:" FontSize="20" HorizontalAlignment="Left" Margin="15,579,0,0" VerticalAlignment="Top" Height="40" Width="45"/>
        <TextBox DataContext="OIBFilter" FontSize="16" Name="tbOIBFilter" HorizontalAlignment="Left" Margin="60,589,0,0" TextWrapping="NoWrap" Text="" VerticalAlignment="Top" Width="130" Height="25"/>
        <Label Content="Statusi:" FontWeight="Bold" FontSize="20" HorizontalAlignment="Left" Margin="205,514,0,0" VerticalAlignment="Top" Height="40" Width="85"/>

        <CheckBox Content="Zaprimljen" DataContext="filterStatusZaprimljen" Name="cbZaprimljen" HorizontalAlignment="Left" Margin="378,544,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Potvrđeno zaprimanje" DataContext="filterStatusPotvrdenoZaprimanje" Name="cbPotvrdenoZaprimanje" HorizontalAlignment="Left" Margin="378,560,0,0" VerticalAlignment="Top"/>

        <CheckBox Content="Likvidiran" DataContext="filterStatusLikvidiran" Name="cbLikvidiran" HorizontalAlignment="Left" Margin="225,553,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Nije likvidiran" DataContext="filterStatusNijeLikvidiran" Name="cbNijeLikvidiran" HorizontalAlignment="Left" Margin="225,570,0,0" VerticalAlignment="Top"/>

        <CheckBox Content="Prihvaćen" DataContext="filterStatusPrihvacen" Name="cbPrihvacen" HorizontalAlignment="Left" Margin="378,586,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Odbijen" DataContext="filterStatusOdbijen" Name="cbOdbijen" HorizontalAlignment="Left" Margin="378,602,0,0" VerticalAlignment="Top"/>

        <CheckBox Content="Plaćanje zaprimljeno" DataContext="filterStatusPlacanjeZaprimljeno" Name="cbPlacanjeZaprimljeno" HorizontalAlignment="Left" Margin="527,555,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Djelomično plaćeno" DataContext="filterStatusDjelomicnoPlaceno" Name="cbDjelomicnoPlaceno" HorizontalAlignment="Left" Margin="527,572,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Plaćeno" DataContext="filterStatusPlaceno" Name="cbPlaceno" HorizontalAlignment="Left" Margin="527,589,0,0" VerticalAlignment="Top"/>

        <!--<CheckBox Content="Nije u sustavu PDV-a" DataContext="filterStatusNijeUSustavuPdva" x:Name="cbNijeUSustavuPdva" HorizontalAlignment="Left" Margin="225,586,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Izvoz" DataContext="filterStatusIzvoz" x:Name="cbIzvoz" HorizontalAlignment="Left" Margin="225,602,0,0" VerticalAlignment="Top"/>-->

        <Label Content="Fiskaliziran:" FontWeight="Bold" FontSize="20" HorizontalAlignment="Left" Margin="645,514,0,0" VerticalAlignment="Top" Height="40" Width="134"/>
        <CheckBox Content="Da" DataContext="filterStatusFiskaliziranDa" x:Name="cbFiskaliziranDa" HorizontalAlignment="Left" Margin="706,549,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Ne" DataContext="filterStatusFiskaliziranNe" x:Name="cbFiskaliziranNe" HorizontalAlignment="Left" Margin="706,566,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Greška" DataContext="filterStatusFiskaliziranGreska" x:Name="cbFiskaliziranGreska" HorizontalAlignment="Left" Margin="706,583,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Prazno" DataContext="filterStatusFiskaliziranPrazno" x:Name="cbFiskaliziranPrazno" HorizontalAlignment="Left" Margin="706,599,0,0" VerticalAlignment="Top"/>

        <Label Content="Odbijen:" FontWeight="Bold" FontSize="20" HorizontalAlignment="Left" Margin="789,514,0,0" VerticalAlignment="Top" Height="40" Width="134"/>
        <CheckBox Content="Da" DataContext="filterStatusOdbijenDa" x:Name="cbOdbijenDa" HorizontalAlignment="Left" Margin="837,548,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Ne" DataContext="filterStatusOdbijenNe" x:Name="cbOdbijenNe" HorizontalAlignment="Left" Margin="837,565,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Greška" DataContext="filterStatusOdbijenGreska" x:Name="cbOdbijenGreska" HorizontalAlignment="Left" Margin="837,582,0,0" VerticalAlignment="Top"/>
        <CheckBox Content="Prazno" DataContext="filterStatusOdbijenPrazno" x:Name="cbOdbijenPrazno" HorizontalAlignment="Left" Margin="837,598,0,0" VerticalAlignment="Top"/>

        <CheckBox Content="Sve" DataContext="filterStatusSve" x:Name="cbSve" HorizontalAlignment="Left" Margin="288,528,0,0" VerticalAlignment="Top"/>


        <!--<Button
            Content="Osvježi"
            x:Name="btnOsvjezi"
            FontSize="25"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="695,559,0,0"
            Width="275"
            Height="55" />-->
        <!--<CheckBox Content="CheckBox" HorizontalAlignment="Left" Margin="84,569,0,0" VerticalAlignment="Top"/>-->


    </Grid>
</Window>