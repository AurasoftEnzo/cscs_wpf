<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wcl="clr-namespace:WpfControlsLibrary;assembly=WpfControlsLibrary"
        xmlns:local="clr-namespace:WpfCSCS"
        mc:Ignorable="d"
        Title="Pregled statusa ulaznih e-računa"
        Height="670"
        Width="1000"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Name="wxurstatusWindow"
        Background="#1A2535">

    <Window.Resources>

        <!-- Flat rounded button -->
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CheckBox – light text on dark background -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"               Value="#C8D0DA"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="12.5"/>
            <Setter Property="Margin"                   Value="0,3,14,0"/>
            <Setter Property="Cursor"                   Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Section heading (orange accent) -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E67E22"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

    </Window.Resources>

    <!-- ================================================================
         Root: 3 rows – DataGrid | Action bar | Filter panel
         ================================================================ -->
    <Grid Margin="10,8,10,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>     <!-- DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Action bar -->
            <RowDefinition Height="Auto"/>  <!-- Filter -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             ROW 0 – DataGrid
             ============================================================ -->
        <Border Grid.Row="0"
                Background="#263646"
                CornerRadius="8"
                Margin="0,0,0,8"
                Padding="1">
            <DataGrid x:Name="datagridListaRacuna"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#2D4057"
                      CanUserReorderColumns="True"
                      CanUserSortColumns="True"
                      Background="Transparent"
                      IsReadOnly="True"
                      RowHeight="23"
                      FontSize="13"
                      FontFamily="Segoe UI"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      BorderThickness="0"
                      FrozenColumnCount="2"
                      AlternationCount="2"
                      RowBackground="#1E2F3D"
                      AlternatingRowBackground="#243444"
                      Foreground="#D0D8E4"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      TabIndex="4">
                <DataGrid.Resources>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Background"      Value="#4871CF"/>
                        <Setter Property="Foreground"      Value="White"/>
                        <Setter Property="FontSize"        Value="13"/>
                        <Setter Property="FontWeight"      Value="SemiBold"/>
                        <Setter Property="FontFamily"      Value="Segoe UI"/>
                        <Setter Property="BorderBrush"     Value="#2C3E50"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="Padding"         Value="8,5"/>
                    </Style>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="Foreground" Value="#D0D8E4"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>

                    <DataGridTemplateColumn Header="R. br." Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredRbr" CanUserSort="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Dobavljač" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredDobavljac" CanUserSort="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="OIB dobavlj." Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredOibDobavljaca"
                                                HorizontalContentAlignment="Center" CanUserSort="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Status računa" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredStatusRacuna" CanUserSort="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Dat. izdav." Width="85">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredDatumIzdavanja"
                                                HorizontalContentAlignment="Center"
                                                CanUserSort="True" EditLength="8"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Dat. PDV" Width="85">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredDatumPDVa"
                                                HorizontalContentAlignment="Center"
                                                CanUserSort="True" EditLength="8"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Broj računa" Width="185">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredBrojRacuna" CanUserSort="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Fiskaliziran?" Width="115">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredStatusFiskalizacije" CanUserSort="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Odbijen?" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredReportRejectionStatus" CanUserSort="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Broj eRačuna" Width="115">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredBrPon"
                                                HorizontalContentAlignment="Right" CanUserSort="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Broj ul. računa" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredGlNum"
                                                HorizontalContentAlignment="Right" CanUserSort="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Iznos" Width="105">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredZaPlacanje"
                                                HorizontalContentAlignment="Right" CanUserSort="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ID računa" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <wcl:ASGridCell FieldName="arrayFilteredIdRacunaPosrednika"
                                                HorizontalContentAlignment="Center" CanUserSort="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ============================================================
             ROW 1 – Action bar  (Od / Do dates · Prikaži · Export · Clock)
             ============================================================ -->
        <Border Grid.Row="1"
                Background="#263646"
                CornerRadius="8"
                Margin="0,0,0,8"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- dates -->
                    <ColumnDefinition Width="*"/>      <!-- Prikaži centre -->
                    <ColumnDefinition Width="Auto"/>   <!-- Export + clock right -->
                </Grid.ColumnDefinitions>

                <!-- Date range -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Od:" Foreground="#BDC3C7" FontFamily="Segoe UI" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <wcl:ASDateEditer x:Name="dateEditerFrom"
                                      DataContext="FilterDateFrom"
                                      Background="#1E2F3D"
                                        Foreground="White"
                                      DisplaySize="8" DisplayDate="01/01/26" ButtonWidth="20"
                                      FontSize="19" TabIndex="1"
                                      Width="100" Height="28"
                                      VerticalAlignment="Center" Margin="0,0,22,0"/>
                    <TextBlock Text="Do:" Foreground="#BDC3C7" FontFamily="Segoe UI" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <wcl:ASDateEditer x:Name="dateEditerTo"
                                      DataContext="FilterDateTo"
                                      Background="#1E2F3D"
                                        Foreground="White"
                                      DisplaySize="8" DisplayDate="01/01/26" ButtonWidth="20"
                                      FontSize="19" TabIndex="2"
                                      Width="100" Height="28"
                                      VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Prikaži -->
                <Button Grid.Column="1"
                        Name="btnPrikazi"
                        Content="Prikaži"
                        Style="{StaticResource FlatBtn}"
                        Background="#4871CF"
                        FontSize="19" FontWeight="Bold"
                        Height="42" Width="240"
                        TabIndex="3"
                        HorizontalAlignment="Center"/>

                <!-- Export + clock -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Name="Export2XLSX"
                            Content="Export → XLSX"
                            Style="{StaticResource FlatBtn}"
                            Background="#2E4A6E"
                            FontSize="14" FontWeight="SemiBold"
                            Height="42" Width="155"
                            IsTabStop="False"
                            Margin="0,0,10,0"/>
                    <Image x:Name="asImage" DataContext="Sat"
                           Height="38" Width="42"
                           VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================
             ROW 2 – Filter panel
             ============================================================ -->
        <Border Grid.Row="2"
                Background="#263646"
                CornerRadius="8"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>   <!-- OIB + Sve -->
                    <ColumnDefinition Width="*"/>     <!-- Statusi -->
                    <ColumnDefinition Width="100"/>   <!-- Fiskaliziran -->
                    <ColumnDefinition Width="110"/>   <!-- Odbijen -->
                </Grid.ColumnDefinitions>

                <!-- Col 0 · OIB & Sve -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Filtriranje" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="OIB:" Foreground="#BDC3C7" FontFamily="Segoe UI"
                               FontSize="12" Margin="0,0,0,3"/>
                    <TextBox Name="tbOIBFilter"
                             DataContext="OIBFilter"
                             Text=""
                             FontSize="13" FontFamily="Segoe UI"
                             Background="#1E2F3D" Foreground="White"
                             CaretBrush="White"
                             BorderBrush="#3D5166" BorderThickness="1"
                             Padding="4,2"
                             Width="96" Height="24"
                             HorizontalAlignment="Left"/>
                    
                </StackPanel>

                <!-- Col 1 · Statusi -->
                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Statusi:" Style="{StaticResource SectionHeader}"/>
                    <CheckBox Content="Sve" DataContext="filterStatusSve" x:Name="cbSve" Margin="0,10,0,0"/>
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox Content="Zaprimljen"
                                  DataContext="filterStatusZaprimljen"           Name="cbZaprimljen"/>
                        <CheckBox Content="Potvrđeno zaprimanje"
                                  DataContext="filterStatusPotvrdenoZaprimanje"  Name="cbPotvrdenoZaprimanje"/>
                        
                        <CheckBox Content="Prihvaćen"
                                  DataContext="filterStatusPrihvacen"            Name="cbPrihvacen"/>
                        <CheckBox Content="Odbijen"
                                  DataContext="filterStatusOdbijen"              Name="cbOdbijen"/>
                        
                    </WrapPanel>
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox Content="Plaćanje zaprimljeno"
          DataContext="filterStatusPlacanjeZaprimljeno"  Name="cbPlacanjeZaprimljeno"/>
                        <CheckBox Content="Ostalo"
          DataContext="filterStatusOstalo"               Name="cbOstalo"/>
                    </WrapPanel>
                    <WrapPanel Orientation="Horizontal">
                                    <CheckBox Content="Likvidiran"
                      DataContext="filterStatusLikvidiran"           Name="cbLikvidiran"/>
                                    <CheckBox Content="Nije likvidiran"
                      DataContext="filterStatusNijeLikvidiran"       Name="cbNijeLikvidiran"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Col 2 · Fiskaliziran -->
                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="Fiskaliziran:" Style="{StaticResource SectionHeader}"/>
                    <CheckBox Content="Da" DataContext="filterStatusFiskaliziranDa" x:Name="cbFiskaliziranDa"/>
                    <CheckBox Content="Ne" DataContext="filterStatusFiskaliziranNe" x:Name="cbFiskaliziranNe"/>
                </StackPanel>

                <!-- Col 3 · Odbijen -->
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Odbijen:" Style="{StaticResource SectionHeader}"/>
                    <CheckBox Content="Da"     DataContext="filterStatusOdbijenDa"     x:Name="cbOdbijenDa"/>
                    <CheckBox Content="Ne"     DataContext="filterStatusOdbijenNe"     x:Name="cbOdbijenNe"/>
                    <CheckBox Content="Greška" DataContext="filterStatusOdbijenGreska" x:Name="cbOdbijenGreska"/>
                    <CheckBox Content="Prazno" DataContext="filterStatusOdbijenPrazno" x:Name="cbOdbijenPrazno"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</Window>